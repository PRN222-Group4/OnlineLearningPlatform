@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- ═══════════ HERO ═══════════ -->
<section class="relative overflow-hidden bg-gradient-animated min-h-[520px] flex items-center">
    <!-- Floating blobs -->
    <div class="absolute top-10 right-10 w-72 h-72 bg-white/5 rounded-full anim-blob"></div>
    <div class="absolute bottom-0 left-20 w-96 h-96 bg-white/5 rounded-full anim-blob delay-300" style="animation-duration:9s"></div>
    <div class="absolute top-1/2 right-1/3 w-40 h-40 bg-white/10 rounded-full anim-float delay-500"></div>

    <!-- Spinning ring -->
    <div class="absolute -top-20 -right-20 w-80 h-80 border border-white/10 rounded-full anim-spin-slow"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20 grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left content -->
        <div>
            <div class="anim-fade-up">
                <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 text-white/90 text-sm font-medium backdrop-blur-sm mb-6">
                    <span class="w-2 h-2 rounded-full bg-green-400 anim-pulse-soft"></span>
                    Platform is live — Start learning today
                </span>
            </div>

            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight anim-fade-up delay-100">
                Learn Without
                <span class="block mt-1">
                    <span class="bg-gradient-to-r from-cyan-200 to-white bg-clip-text text-transparent">Limits</span>
                </span>
            </h1>

            <p class="mt-6 text-lg text-white/75 max-w-lg leading-relaxed anim-fade-up delay-200">
                Discover expert-led courses, build real-world skills, and accelerate your career with our cutting-edge learning platform.
            </p>

            <div class="flex flex-wrap gap-4 mt-8 anim-fade-up delay-300">
                <a href="#courses"
                   class="group inline-flex items-center gap-2 px-8 py-3.5 bg-white text-ocean-700 font-bold rounded-2xl shadow-xl shadow-black/10 hover:shadow-2xl hover:scale-[1.03] transition-all duration-300">
                    <i class="bi bi-search"></i>
                    Explore Courses
                    <i class="bi bi-arrow-right transition-transform group-hover:translate-x-1"></i>
                </a>
                <a href="/Account/Register"
                   class="group inline-flex items-center gap-2 px-8 py-3.5 glass text-white font-semibold rounded-2xl hover:bg-white/20 transition-all duration-300">
                    <i class="bi bi-person-plus"></i>
                    Join Free
                </a>
            </div>

            <!-- Stats -->
            <div class="flex gap-8 mt-10 anim-fade-up delay-400">
                <div>
                    <div class="text-2xl font-extrabold text-white">1K+</div>
                    <div class="text-xs text-white/50 uppercase tracking-wider">Students</div>
                </div>
                <div class="w-px bg-white/20"></div>
                <div>
                    <div class="text-2xl font-extrabold text-white">50+</div>
                    <div class="text-xs text-white/50 uppercase tracking-wider">Courses</div>
                </div>
                <div class="w-px bg-white/20"></div>
                <div>
                    <div class="text-2xl font-extrabold text-white">4.9</div>
                    <div class="text-xs text-white/50 uppercase tracking-wider">Rating</div>
                </div>
            </div>
        </div>

        <!-- Right illustration -->
        <div class="hidden lg:flex justify-center anim-fade-right delay-200">
            <div class="relative">
                <div class="w-80 h-80 bg-white/10 rounded-3xl backdrop-blur-sm border border-white/10 flex items-center justify-center anim-float">
                    <i class="bi bi-mortarboard-fill text-8xl text-white/40"></i>
                </div>
                <!-- Floating badges -->
                <div class="absolute -top-4 -right-4 glass rounded-2xl px-4 py-2.5 anim-float delay-200 shadow-xl">
                    <div class="flex items-center gap-2 text-white text-sm font-medium">
                        <i class="bi bi-award-fill text-yellow-300"></i> Top Rated
                    </div>
                </div>
                <div class="absolute -bottom-4 -left-4 glass rounded-2xl px-4 py-2.5 anim-float delay-400 shadow-xl">
                    <div class="flex items-center gap-2 text-white text-sm font-medium">
                        <i class="bi bi-play-circle-fill text-cyan-300"></i> HD Video
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════ COURSES ═══════════ -->
<section id="courses" class="max-w-7xl mx-auto px-6 py-16">
    <div class="text-center mb-12">
        <span class="inline-block px-4 py-1 rounded-full bg-ocean-100 text-ocean-700 text-xs font-bold uppercase tracking-wider mb-3">
            Explore
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight">
            Available <span class="text-gradient">Courses</span>
        </h2>
        <p class="mt-3 text-gray-500 max-w-lg mx-auto">
            Browse our collection of expertly crafted courses designed to boost your skills
        </p>
    </div>

    @if (!Model.Courses.Any())
    {
        <div class="text-center py-16 anim-fade-up">
            <div class="w-20 h-20 bg-gray-100 rounded-3xl flex items-center justify-center mx-auto mb-4">
                <i class="bi bi-book text-3xl text-gray-300"></i>
            </div>
            <h3 class="text-lg font-bold text-gray-600">No courses available yet</h3>
            <p class="text-gray-400 mt-1">Check back later for new courses!</p>
        </div>
    }
    else
    {
        <div class="grid lg:grid-cols-3 md:grid-cols-2 gap-6">
            @{ var idx = 0; }
            @foreach (var course in Model.Courses)
            {
                <div class="anim-fade-up delay-@(idx % 4 * 100 + 100)">
                    <div class="group bg-white rounded-2xl border border-gray-100 overflow-hidden card-shine hover:shadow-xl hover:shadow-gray-200/50 hover:-translate-y-1.5 transition-all duration-500">
                        <!-- Image -->
                        <div class="relative overflow-hidden h-48">
                            @if (!string.IsNullOrEmpty(course.Image))
                            {
                                <img src="@course.Image" alt="@course.Title"
                                     class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                            }
                            else
                            {
                                <div class="w-full h-full bg-gradient-to-br from-ocean-100 via-cyan-50 to-sky-100 flex items-center justify-center">
                                    <i class="bi bi-book text-5xl text-ocean-300 group-hover:scale-110 transition-transform duration-500"></i>
                                </div>
                            }
                            <!-- Overlay badge -->
                            <div class="absolute top-3 left-3">
                                <span class="px-3 py-1 rounded-lg bg-white/90 backdrop-blur-sm text-xs font-bold text-ocean-700 shadow-sm">
                                    @course.Category
                                </span>
                            </div>
                        </div>

                        <!-- Body -->
                        <div class="p-5">
                            <h3 class="font-bold text-gray-900 line-clamp-2 group-hover:text-ocean-600 transition-colors">
                                @course.Title
                            </h3>
                            <p class="text-sm text-gray-500 mt-2 line-clamp-2">@course.Description</p>

                            <!-- Meta -->
                            <div class="flex items-center gap-3 mt-4 text-xs text-gray-400">
                                <span class="flex items-center gap-1"><i class="bi bi-person"></i> @course.InstructorName</span>
                                <span class="flex items-center gap-1"><i class="bi bi-star-fill text-amber-400"></i> @course.Rating</span>
                            </div>

                            <!-- Footer -->
                            <div class="flex items-center justify-between mt-5 pt-4 border-t border-gray-100">
                                <div>
                                    <span class="text-xl font-extrabold text-ocean-600">@course.Price.ToString("N0")</span>
                                    <span class="text-xs text-gray-400 ml-0.5">đ</span>
                                </div>
                                <a asp-page="/Courses/Detail" asp-route-id="@course.CourseId"
                                   class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-ocean-500 to-cyan-500 hover:from-ocean-600 hover:to-cyan-600 shadow-md shadow-ocean-200 hover:shadow-lg hover:scale-[1.02] transition-all duration-300">
                                    Details <i class="bi bi-arrow-right text-xs"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                idx++;
            }
        </div>
    }
</section>
