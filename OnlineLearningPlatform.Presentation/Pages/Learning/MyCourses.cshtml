@page
@model OnlineLearningPlatform.Presentation.Pages.Learning.MyCoursesModel
@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "My Learning";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Header -->
    <div class="mb-8">
        <h1 class="font-display text-2xl font-bold text-slate-900">My Learning</h1>
        <p class="text-slate-500 text-sm mt-1">Track your progress across all enrolled courses</p>
    </div>

    @if (!Model.Enrollments.Any())
    {
        <!-- Empty state -->
        <div class="bg-white rounded-2xl border border-slate-200 py-20 text-center">
            <div class="w-16 h-16 bg-primary-50 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-graduation-cap text-primary-400 text-2xl"></i>
            </div>
            <h3 class="text-base font-semibold text-slate-700 mb-1">No courses yet</h3>
            <p class="text-sm text-slate-400 mb-6">Enroll in a course to start your learning journey</p>
            <a asp-page="/Courses/Index"
               class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary-600 text-white text-sm font-semibold rounded-xl hover:bg-primary-700 transition-colors shadow-sm">
                <i class="fas fa-search text-xs"></i> Browse Courses
            </a>
        </div>
    }
    else
    {
        <!-- Stats bar -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
            @{
                var total      = Model.Enrollments.Count;
                var completed  = Model.Enrollments.Count(e => e.ProgressPercent >= 100);
                var inProgress = Model.Enrollments.Count(e => e.ProgressPercent > 0 && e.ProgressPercent < 100);
                var notStarted = Model.Enrollments.Count(e => e.ProgressPercent == 0);
            }
            @foreach (var stat in new[] {
                new { Label = "Total",       Value = total.ToString(),      Icon = "fa-layer-group",    Bg = "bg-slate-100",   Text = "text-slate-600"   },
                new { Label = "In Progress", Value = inProgress.ToString(), Icon = "fa-spinner",        Bg = "bg-blue-50",     Text = "text-blue-600"    },
                new { Label = "Completed",   Value = completed.ToString(),  Icon = "fa-check-circle",   Bg = "bg-emerald-50",  Text = "text-emerald-600" },
                new { Label = "Not Started", Value = notStarted.ToString(), Icon = "fa-clock",          Bg = "bg-amber-50",    Text = "text-amber-600"   },
            })
            {
                <div class="bg-white rounded-xl border border-slate-200 px-5 py-4 flex items-center gap-3">
                    <div class="w-10 h-10 @stat.Bg rounded-lg flex items-center justify-center shrink-0">
                        <i class="fas @stat.Icon @stat.Text text-sm"></i>
                    </div>
                    <div>
                        <p class="text-xl font-bold text-slate-900">@stat.Value</p>
                        <p class="text-xs text-slate-400 font-medium">@stat.Label</p>
                    </div>
                </div>
            }
        </div>

        <!-- Course grid -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            @foreach (var e in Model.Enrollments)
            {
                var course   = e.Course;
                var progress = (int)e.ProgressPercent;
                var isDone   = progress >= 100;

                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5 overflow-hidden flex flex-col">

                    <!-- Thumbnail -->
                    <div class="relative h-40 bg-slate-100 overflow-hidden">
                        @if (!string.IsNullOrEmpty(course?.Image))
                        {
                            <img src="@course.Image" alt="@course.Title"
                                 class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center">
                                <i class="fas fa-book-open text-slate-300 text-4xl"></i>
                            </div>
                        }
                        <!-- Status badge -->
                        @if (isDone)
                        {
                            <div class="absolute top-3 right-3 bg-emerald-500 text-white text-[10px] font-bold px-2 py-1 rounded-full flex items-center gap-1">
                                <i class="fas fa-check text-[8px]"></i> Completed
                            </div>
                        }
                        else if (progress > 0)
                        {
                            <div class="absolute top-3 right-3 bg-blue-500 text-white text-[10px] font-bold px-2 py-1 rounded-full">
                                In Progress
                            </div>
                        }
                    </div>

                    <!-- Content -->
                    <div class="p-4 flex flex-col flex-1">
                        <h3 class="text-sm font-bold text-slate-900 line-clamp-2 mb-1 leading-snug">
                            @(course?.Title ?? "Unknown Course")
                        </h3>

                        <!-- Progress bar -->
                        <div class="mt-2 mb-3">
                            <div class="flex items-center justify-between mb-1">
                                <span class="text-xs text-slate-400">Progress</span>
                                <span class="text-xs font-semibold @(isDone ? "text-emerald-600" : "text-slate-600")">@progress%</span>
                            </div>
                            <div class="w-full bg-slate-100 rounded-full h-1.5 overflow-hidden">
                                <div class="h-full rounded-full transition-all duration-300
                                            @(isDone ? "bg-emerald-500" : "bg-primary-500")"
                                     style="width: @progress%"></div>
                            </div>
                        </div>

                        <!-- Enrolled date -->
                        <p class="text-xs text-slate-400 mb-4">
                            <i class="fas fa-calendar-alt mr-1"></i>
                            Enrolled @(e.EnrolledAt?.ToString("MMM dd, yyyy") ?? "—")
                        </p>

                        <!-- CTA -->
                        <div class="mt-auto">
                            <a asp-page="/Courses/Detail" asp-route-id="@course?.CourseId"
                               class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-semibold rounded-xl transition-colors
                                      @(isDone
                                        ? "bg-emerald-50 text-emerald-700 hover:bg-emerald-100"
                                        : "bg-primary-600 text-white hover:bg-primary-700 shadow-sm shadow-primary-500/20")">
                                <i class="fas @(isDone ? "fa-redo" : "fa-play") text-xs"></i>
                                @(isDone ? "Review Course" : (progress > 0 ? "Continue" : "Start Learning"))
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
