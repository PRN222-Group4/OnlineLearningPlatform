@page
@model OnlineLearningPlatform.Presentation.Pages.Account.LoginModel
@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Sign In";
}

<div class="min-h-[calc(100vh-64px)] flex items-center justify-center bg-slate-50 py-12 px-4">
    <div class="w-full max-w-4xl">
        <div class="bg-white rounded-2xl shadow-xl border border-slate-100 overflow-hidden flex">

            <!-- Left panel -->
            <div class="hidden md:flex md:w-5/12 bg-gradient-to-br from-primary-600 to-primary-800 flex-col items-center justify-center p-10 text-white relative overflow-hidden">
                <div class="absolute -top-16 -left-16 w-48 h-48 bg-white/5 rounded-full"></div>
                <div class="absolute -bottom-10 -right-10 w-36 h-36 bg-white/5 rounded-full"></div>
                <div class="relative z-10 text-center">
                    <svg width="96" height="96" viewBox="0 0 24 24" fill="none" class="mx-auto mb-5 opacity-90" aria-hidden="true">
                        <rect width="24" height="24" rx="5" fill="rgba(255,255,255,0.12)" />
                        <path d="M7 12h10M7 8h10M7 16h6" stroke="white" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <h4 class="font-display text-xl font-bold mb-2">Learn. Build. Grow.</h4>
                    <p class="text-primary-200 text-sm leading-relaxed">Access courses, track progress and learn from experts.</p>
                    <div class="mt-7 space-y-2.5 text-left">
                        @foreach (var item in new[] {
                                                ("fa-graduation-cap", "Access all your courses"),
                                                ("fa-chart-line",     "Track your progress"),
                                                ("fa-certificate",    "Earn certificates"),
                                                })
                        {
                            <div class="flex items-center gap-3 bg-white/10 rounded-xl px-4 py-2.5 text-sm">
                                <i class="fas @item.Item1 text-primary-200 w-4 text-center text-xs"></i>
                                <span class="text-primary-100">@item.Item2</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right panel -->
            <div class="flex-1 p-8 sm:p-10">
                <div class="text-center mb-7">
                    <a href="/" class="inline-flex items-center gap-2 no-underline group mb-3">
                        <div class="w-8 h-8 bg-slate-900 rounded-lg flex items-center justify-center group-hover:bg-primary-600 transition-colors">
                            <i class="fas fa-layer-group text-white text-sm"></i>
                        </div>
                        <span class="font-display font-bold text-lg text-slate-900">CourseSphere</span>
                    </a>
                    <p class="text-slate-500 text-sm mt-1">Welcome back — sign in to continue</p>
                </div>

                <form method="post" asp-page-handler="Login" id="loginForm" novalidate class="space-y-4">
                    @Html.AntiForgeryToken()

                    <!-- Email -->
                    <div>
                        <label for="email" class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Email address</label>
                        <div class="relative">
                            <i class="fas fa-envelope absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-xs pointer-events-none"></i>
                            <input type="email" id="email" name="Email" placeholder="name@example.com" required
                                   class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-slate-50
                                          focus:outline-none focus:bg-white focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all" />
                        </div>
                    </div>

                    <!-- Password -->
                    <div>
                        <div class="flex items-center justify-between mb-1.5">
                            <label for="password" class="block text-xs font-semibold text-slate-500 uppercase tracking-wider">Password</label>
                            <a asp-page="/Account/ForgotPassword" class="text-xs text-primary-600 hover:text-primary-700 font-medium no-underline">Forgot password?</a>
                        </div>
                        <div class="relative">
                            <i class="fas fa-lock absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-xs pointer-events-none"></i>
                            <input type="password" id="password" name="Password" placeholder="••••••••" required
                                   class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-slate-50
                                          focus:outline-none focus:bg-white focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all" />
                        </div>
                    </div>

                    <!-- Remember me -->
                    <div class="flex items-center gap-2">
                        <input class="w-4 h-4 rounded border-slate-300 text-primary-600 focus:ring-primary-500 cursor-pointer"
                               type="checkbox" value="true" id="remember" name="Remember" />
                        <label class="text-sm text-slate-600 cursor-pointer select-none" for="remember">Remember me</label>
                    </div>

                    <!-- Submit -->
                    <button type="submit" id="loginBtn"
                            class="w-full flex items-center justify-center gap-2 py-3 bg-primary-600 text-white text-sm font-semibold rounded-xl
                                   hover:bg-primary-700 focus:ring-4 focus:ring-primary-200 transition-colors shadow-lg shadow-primary-500/25">
                        <span id="loginBtnText">Sign in</span>
                        <span id="loginSpinner" class="d-none hidden w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin" role="status" aria-hidden="true"></span>
                    </button>

                    <!-- Message — id giữ nguyên để JS cũ inject vào -->
                    <div id="loginMessage" class="mt-1"></div>

                    <p class="text-center text-sm text-slate-500">
                        Don't have an account?
                        <a asp-page="/Account/Register" class="text-primary-600 font-semibold hover:text-primary-700 no-underline">Create one</a>
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        /* .d-none compat cho spinner (JS cũ dùng classList add/remove 'd-none') */
        .d-none {
            display: none !important;
        }
        /* Style cho alert-danger inject bởi JS cũ */
        #loginMessage .alert-danger {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 12px 14px;
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 12px;
            font-size: 13px;
            color: #b91c1c;
            margin-top: 4px;
        }
    </style>
    <script>
        /* JS GIỮ NGUYÊN HOÀN TOÀN TỪ FILE CŨ */
        (function () {
            const form = document.getElementById('loginForm');
            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                const data = new FormData(form);
                const payload = {
                    Email: data.get('Email'),
                    Password: data.get('Password')
                };
                const btn = document.getElementById('loginBtn');
                const spinner = document.getElementById('loginSpinner');
                const btnText = document.getElementById('loginBtnText');
                try {
                    btn.disabled = true;
                    spinner.classList.remove('d-none');
                    btnText.textContent = 'Signing in...';

                    const action = form.action;
                    const tokenEl = form.querySelector('input[name="__RequestVerificationToken"]');
                    const token = tokenEl ? tokenEl.value : null;

                    const headers = { 'Content-Type': 'application/json' };
                    if (token) headers['RequestVerificationToken'] = token;
                    headers['X-Requested-With'] = 'XMLHttpRequest';

                    const res = await fetch(action, {
                        method: 'POST',
                        headers: headers,
                        body: JSON.stringify(payload),
                        credentials: 'same-origin'
                    });
                    if (!res.ok) {
                        const text = await res.text();
                        document.getElementById('loginMessage').innerHTML = `<div class="alert alert-danger">${text}</div>`;
                        return;
                    }

                    const ct = res.headers.get('content-type') || '';
                    if (ct.indexOf('application/json') !== -1) {
                        try {
                            const obj = await res.json();
                            if (obj && obj.redirect) {
                                window.location.href = obj.redirect;
                                return;
                            }
                        } catch (e) { }
                    }

                    try {
                        const hres = await fetch('/api/ui/header', { credentials: 'same-origin' });
                        if (hres.ok) {
                            const html = await hres.text();
                            const container = document.getElementById('headerUserArea');
                            if (container) container.outerHTML = html;
                        }
                    } catch (e) { }

                    try {
                        const mainSelector = 'main[role="main"]';
                        const mainEl = document.querySelector(mainSelector);
                        if (mainEl) {
                            const home = await fetch('/', { headers: { 'X-Requested-With': 'XMLHttpRequest' }, credentials: 'same-origin' });
                            if (home.ok) {
                                const text = await home.text();
                                const parser = new DOMParser();
                                const doc = parser.parseFromString(text, 'text/html');
                                const newMain = doc.querySelector(mainSelector) || doc.querySelector('main');
                                if (newMain) mainEl.innerHTML = newMain.innerHTML;
                                const newTitle = doc.querySelector('title')?.innerText;
                                if (newTitle) document.title = newTitle;
                            } else {
                                window.location.href = '/';
                            }
                        } else {
                            window.location.href = '/';
                        }
                    } catch (e) {
                        window.location.href = '/';
                    }
                } catch (err) {
                    document.getElementById('loginMessage').innerHTML = `<div class="alert alert-danger">Error</div>`;
                } finally {
                    btn.disabled = false;
                    spinner.classList.add('d-none');
                    btnText.textContent = 'Sign in';
                }
            });
        })();
    </script>
}
