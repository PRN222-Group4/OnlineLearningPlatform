@page
@model OnlineLearningPlatform.Presentation.Pages.Account.LoginModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}

<section class="min-h-[85vh] flex items-center justify-center px-4 py-12 bg-gray-50">
    <div class="w-full max-w-5xl grid md:grid-cols-2 rounded-3xl overflow-hidden shadow-2xl shadow-gray-200/60 bg-white anim-scale">

        <!-- Left: Illustration -->
        <div class="hidden md:flex flex-col items-center justify-center bg-gradient-animated relative overflow-hidden p-10">
            <div class="absolute top-8 right-8 w-40 h-40 bg-white/5 rounded-full anim-blob"></div>
            <div class="absolute bottom-8 left-8 w-56 h-56 bg-white/5 rounded-full anim-blob delay-300" style="animation-duration:9s"></div>

            <div class="relative z-10 text-center anim-fade-up">
                <div class="w-24 h-24 glass rounded-3xl flex items-center justify-center mx-auto mb-6 anim-float">
                    <i class="bi bi-mortarboard-fill text-4xl text-white"></i>
                </div>
                <h3 class="text-2xl font-extrabold text-white mb-2">Welcome Back!</h3>
                <p class="text-white/70 text-sm max-w-xs mx-auto leading-relaxed">
                    Sign in to access your courses, track your progress, and continue learning.
                </p>

                <div class="flex justify-center gap-6 mt-8 text-white/60 text-xs">
                    <div class="text-center">
                        <div class="text-lg font-bold text-white">1K+</div>
                        <div>Students</div>
                    </div>
                    <div class="w-px bg-white/20"></div>
                    <div class="text-center">
                        <div class="text-lg font-bold text-white">50+</div>
                        <div>Courses</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Form -->
        <div class="p-8 md:p-10 flex flex-col justify-center" x-data="loginForm()" x-cloak>
            <div class="text-center mb-8 anim-fade-down">
                <a href="/" class="inline-flex items-center gap-2 mb-4">
                    <div class="w-8 h-8 bg-gradient-to-br from-ocean-500 to-cyan-400 rounded-xl flex items-center justify-center text-white shadow-md">
                        <i class="bi bi-mortarboard-fill text-sm"></i>
                    </div>
                    <span class="text-lg font-extrabold"><span class="text-gray-900">Edu</span><span class="text-gradient">Sphere</span></span>
                </a>
                <h2 class="text-2xl font-extrabold text-gray-900">Sign in</h2>
                <p class="text-sm text-gray-400 mt-1">Enter your credentials to continue</p>
            </div>

            <form id="loginForm" method="post" asp-page-handler="Login" @@submit.prevent="submit" novalidate class="space-y-5">
                @Html.AntiForgeryToken()

                <!-- Email -->
                <div class="anim-fade-up delay-100">
                    <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email address</label>
                    <div class="relative">
                        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"><i class="bi bi-envelope"></i></span>
                        <input type="email" id="email" name="Email" x-model="email" required
                               placeholder="you@example.com"
                               class="w-full pl-10 pr-4 py-3 rounded-xl border border-gray-200 text-sm focus:border-ocean-400 focus:ring-2 focus:ring-ocean-100 outline-none transition-all duration-200" />
                    </div>
                </div>

                <!-- Password -->
                <div class="anim-fade-up delay-200" x-data="{ show: false }">
                    <label for="password" class="block text-sm font-semibold text-gray-700 mb-1.5">Password</label>
                    <div class="relative">
                        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"><i class="bi bi-lock"></i></span>
                        <input :type="show ? 'text' : 'password'" id="password" name="Password" x-model="password" required
                               placeholder="••••••••"
                               class="w-full pl-10 pr-12 py-3 rounded-xl border border-gray-200 text-sm focus:border-ocean-400 focus:ring-2 focus:ring-ocean-100 outline-none transition-all duration-200" />
                        <button type="button" @@click="show = !show"
                                class="absolute right-3.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition">
                            <i class="bi" :class="show ? 'bi-eye-slash' : 'bi-eye'"></i>
                        </button>
                    </div>
                </div>

                <!-- Remember + Forgot -->
                <div class="flex items-center justify-between anim-fade-up delay-300">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" name="Remember" value="true"
                               class="w-4 h-4 rounded border-gray-300 text-ocean-500 focus:ring-ocean-200" />
                        <span class="text-sm text-gray-600">Remember me</span>
                    </label>
                    <a href="/Account/ForgotPassword" class="text-sm font-medium text-ocean-600 hover:text-ocean-700 transition">
                        Forgot password?
                    </a>
                </div>

                <!-- Submit -->
                <div class="anim-fade-up delay-400">
                    <button type="submit" :disabled="loading"
                            class="w-full py-3.5 rounded-xl font-bold text-white bg-gradient-to-r from-ocean-500 to-cyan-500 hover:from-ocean-600 hover:to-cyan-600 shadow-lg shadow-ocean-200 hover:shadow-xl hover:scale-[1.01] transition-all duration-300 flex items-center justify-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed">
                        <template x-if="loading">
                            <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                            </svg>
                        </template>
                        <span x-text="loading ? 'Signing in...' : 'Sign in'"></span>
                    </button>
                </div>

                <!-- Error message -->
                <template x-if="errorMsg">
                    <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl text-sm anim-scale"
                         x-text="errorMsg"></div>
                </template>

                <!-- Register link -->
                <div class="text-center pt-2 anim-fade-up delay-500">
                    <span class="text-sm text-gray-400">Don't have an account?</span>
                    <a asp-page="/Account/Register" class="text-sm font-semibold text-ocean-600 hover:text-ocean-700 ml-1 transition">
                        Create one
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function loginForm() {
            return {
                email: '', password: '', loading: false, errorMsg: '',
                async submit() {
                    this.errorMsg = '';
                    this.loading = true;
                    try {
                        const form = document.getElementById('loginForm');
                        const tokenEl = form.querySelector('input[name="__RequestVerificationToken"]');
                        const headers = {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        };
                        if (tokenEl) headers['RequestVerificationToken'] = tokenEl.value;

                        const res = await fetch(form.action, {
                            method: 'POST',
                            headers,
                            body: JSON.stringify({ Email: this.email, Password: this.password }),
                            credentials: 'same-origin'
                        });

                        if (!res.ok) {
                            this.errorMsg = await res.text();
                            return;
                        }

                        const ct = res.headers.get('content-type') || '';
                        if (ct.includes('application/json')) {
                            const obj = await res.json();
                            if (obj && obj.redirect) { window.location.href = obj.redirect; return; }
                        }
                        window.location.href = '/';
                    } catch (e) {
                        this.errorMsg = 'Something went wrong. Please try again.';
                    } finally {
                        this.loading = false;
                    }
                }
            }
        }
    </script>
}
