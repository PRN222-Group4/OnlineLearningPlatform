@page
@model OnlineLearningPlatform.Presentation.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="bg-slate-50 min-h-screen py-10 font-sans">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="mb-8">
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Account Settings</h1>
            <p class="text-slate-500 mt-1">Manage your personal information and preferences.</p>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="h-40 bg-gradient-to-r from-primary-600 to-indigo-700 relative">
                <button class="absolute top-4 right-4 bg-white/20 hover:bg-white/30 text-white backdrop-blur-sm px-4 py-2 rounded-xl text-sm font-semibold transition-all">
                    <i class="fas fa-camera mr-2"></i> Edit Cover
                </button>
            </div>

            <div class="px-8 pb-8">
                <div class="relative flex justify-between items-end -mt-16 mb-8">
                    <div class="flex items-end gap-6">
                        <div class="relative group">
                            <img src="@Model.Avatar" alt="@Model.Name" class="w-32 h-32 rounded-full border-4 border-white shadow-lg object-cover bg-white" />
                            <button class="absolute bottom-0 right-0 w-10 h-10 bg-slate-900 text-white rounded-full flex items-center justify-center border-2 border-white hover:bg-primary-600 transition-colors shadow-sm">
                                <i class="fas fa-pen text-xs"></i>
                            </button>
                        </div>
                        <div class="pb-2">
                            <h2 class="text-3xl font-extrabold text-slate-900 flex items-center gap-2">
                                @Model.Name
                                @if (User.IsInRole("Instructor"))
                                {
                                    <span title="Verified Instructor" class="text-blue-500 text-lg"><i class="fas fa-check-circle"></i></span>
                                }
                            </h2>
                            <p class="text-slate-500 font-medium">@Model.Email</p>

                            <div class="flex gap-2 mt-3">
                                @if (User.IsInRole("Student"))
                                {
                                    <span class="px-3 py-1 bg-emerald-100 text-emerald-700 rounded-lg text-xs font-bold tracking-wide uppercase">Student</span>
                                }
                                @if (User.IsInRole("Instructor"))
                                {
                                    <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-lg text-xs font-bold tracking-wide uppercase">Instructor</span>
                                }
                                @if (User.IsInRole("Admin"))
                                {
                                    <span class="px-3 py-1 bg-rose-100 text-rose-700 rounded-lg text-xs font-bold tracking-wide uppercase">Admin</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="w-full h-px bg-slate-100 mb-8"></div>

                <div class="grid sm:grid-cols-2 gap-4">
                    <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
                        <h3 class="font-bold text-slate-800 mb-2"><i class="fas fa-graduation-cap text-primary-500 mr-2"></i> Student Center</h3>
                        <p class="text-sm text-slate-500 mb-4">Jump back into your enrolled courses and pick up where you left off.</p>
                        <a asp-page="/Student/MyCourses" class="inline-flex w-full justify-center items-center px-4 py-2.5 bg-white border border-slate-200 text-slate-700 font-bold rounded-xl hover:bg-slate-50 hover:text-primary-600 transition-colors shadow-sm">
                            Go to My Learning
                        </a>
                    </div>

                    @if (User.IsInRole("Instructor"))
                    {
                        <div class="bg-indigo-50 p-6 rounded-2xl border border-indigo-100">
                            <h3 class="font-bold text-indigo-900 mb-2"><i class="fas fa-chalkboard-teacher text-indigo-500 mr-2"></i> Instructor Portal</h3>
                            <p class="text-sm text-indigo-700/70 mb-4">Create new courses, manage your students, and track your revenue.</p>
                            <a asp-page="/Teacher/Courses/Create" class="inline-flex w-full justify-center items-center px-4 py-2.5 bg-indigo-600 text-white font-bold rounded-xl hover:bg-indigo-700 transition-colors shadow-sm">
                                Create New Course
                            </a>
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</div>