@page
@model OnlineLearningPlatform.Presentation.Pages.Account.RegisterModel
@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Register";
}

<div class="min-h-[calc(100vh-64px)] flex items-center justify-center bg-slate-50 py-12 px-4">
    <div class="w-full max-w-4xl">
        <div class="bg-white rounded-2xl shadow-xl border border-slate-100 overflow-hidden flex">

            <!-- Left panel -->
            <div class="hidden md:flex md:w-5/12 bg-gradient-to-br from-slate-800 to-slate-900 flex-col items-center justify-center p-10 text-white relative overflow-hidden">
                <div class="absolute -top-16 -left-16 w-48 h-48 bg-white/5 rounded-full"></div>
                <div class="absolute -bottom-10 -right-10 w-36 h-36 bg-white/5 rounded-full"></div>
                <div class="relative z-10 text-center">
                    <svg width="96" height="96" viewBox="0 0 24 24" fill="none" class="mx-auto mb-5 opacity-90" aria-hidden="true">
                        <rect width="24" height="24" rx="5" fill="rgba(255,255,255,0.12)" />
                        <path d="M7 12h10M7 8h10M7 16h6" stroke="white" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <h4 class="font-display text-xl font-bold mb-2">Join CourseSphere</h4>
                    <p class="text-slate-400 text-sm leading-relaxed">Create an account and start learning today.</p>
                    <div class="mt-7 space-y-2.5 text-left">
                        @foreach (var item in new[] {
                                                ("fa-infinity",      "Lifetime course access"),
                                                ("fa-mobile-alt",    "Learn on any device"),
                                                ("fa-shield-alt",    "100% secure sign-up"),
                                                })
                        {
                            <div class="flex items-center gap-3 bg-white/8 rounded-xl px-4 py-2.5 text-sm border border-white/10">
                                <i class="fas @item.Item1 text-slate-400 w-4 text-center text-xs"></i>
                                <span class="text-slate-300">@item.Item2</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right panel -->
            <div class="flex-1 p-8 sm:p-10 overflow-y-auto">
                <div class="text-center mb-6">
                    <a href="/" class="inline-flex items-center gap-2 no-underline group mb-3">
                        <div class="w-8 h-8 bg-slate-900 rounded-lg flex items-center justify-center group-hover:bg-primary-600 transition-colors">
                            <i class="fas fa-layer-group text-white text-sm"></i>
                        </div>
                        <span class="font-display font-bold text-lg text-slate-900">CourseSphere</span>
                    </a>
                    <p class="text-slate-500 text-sm mt-1">Register a new account</p>
                </div>

                <form id="registerForm" method="post" enctype="multipart/form-data" class="space-y-4">
                    <div asp-validation-summary="ModelOnly"
                         class="p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>
                    @Html.AntiForgeryToken()

                    <!-- Full Name -->
                    <div>
                        <label for="fullName" class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Full name</label>
                        <div class="relative">
                            <i class="fas fa-user absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-xs pointer-events-none"></i>
                            <input asp-for="Input.FullName" id="fullName" placeholder="Full name" required
                                   class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-slate-50
                                          focus:outline-none focus:bg-white focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all" />
                        </div>
                        <span asp-validation-for="Input.FullName" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Email -->
                    <div>
                        <label for="email" class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Email address</label>
                        <div class="relative">
                            <i class="fas fa-envelope absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-xs pointer-events-none"></i>
                            <input asp-for="Input.Email" id="email" placeholder="name@example.com" type="email" required
                                   class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-slate-50
                                          focus:outline-none focus:bg-white focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Phone -->
                    <div>
                        <label for="phone" class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Phone <span class="text-slate-300 font-normal normal-case">(optional)</span></label>
                        <div class="relative">
                            <i class="fas fa-phone absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-xs pointer-events-none"></i>
                            <input asp-for="Input.PhoneNumber" id="phone" placeholder="Phone number"
                                   class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-slate-50
                                          focus:outline-none focus:bg-white focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all" />
                        </div>
                        <span asp-validation-for="Input.PhoneNumber" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Password -->
                    <div>
                        <label for="password" class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Password</label>
                        <div class="relative">
                            <i class="fas fa-lock absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-xs pointer-events-none"></i>
                            <input asp-for="Input.Password" id="password" placeholder="Password" type="password" required
                                   class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-slate-50
                                          focus:outline-none focus:bg-white focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div>
                        <label for="confirmPassword" class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Confirm password</label>
                        <div class="relative">
                            <i class="fas fa-lock absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-xs pointer-events-none"></i>
                            <input asp-for="Input.ConfirmPassword" id="confirmPassword" placeholder="Confirm password" type="password" required
                                   class="w-full pl-10 pr-4 py-2.5 text-sm border border-slate-200 rounded-xl bg-slate-50
                                          focus:outline-none focus:bg-white focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all" />
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Avatar -->
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Avatar <span class="text-slate-300 font-normal normal-case">(optional)</span></label>
                        <input asp-for="Input.ImageFile" class="w-full text-sm text-slate-500 border border-slate-200 rounded-xl bg-slate-50 px-3 py-2
                               file:mr-3 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold
                               file:bg-primary-50 file:text-primary-600 hover:file:bg-primary-100 transition-all cursor-pointer"
                               type="file" id="imageFile" accept="image/*" />
                        <span asp-validation-for="Input.ImageFile" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Role -->
                    <div>
                        <label for="role" class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Register as</label>
                        <select asp-for="Input.Role" id="role" required
                                class="w-full px-3 py-2.5 text-sm border border-slate-200 rounded-xl bg-slate-50
                                       focus:outline-none focus:bg-white focus:border-primary-400 focus:ring-2 focus:ring-primary-100 transition-all">
                            <option value="Student">Student</option>
                            <option value="Instructor">Instructor</option>
                        </select>
                        <span asp-validation-for="Input.Role" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Submit -->
                    <button type="submit" id="registerBtn"
                            class="w-full flex items-center justify-center gap-2 py-3 bg-slate-900 text-white text-sm font-semibold rounded-xl
                                   hover:bg-slate-800 focus:ring-4 focus:ring-slate-200 transition-colors shadow-lg">
                        <span id="registerBtnText">Create account</span>
                        <span id="registerSpinner" class="d-none hidden w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin" role="status" aria-hidden="true"></span>
                    </button>

                    <!-- Message — id giữ nguyên để JS cũ inject vào -->
                    <div id="registerMessage" class="mt-1"></div>

                    <p class="text-center text-sm text-slate-500">
                        Already have an account?
                        <a asp-page="/Account/Login" class="text-primary-600 font-semibold hover:text-primary-700 no-underline">Sign in</a>
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .d-none {
            display: none !important;
        }

        #registerMessage .alert-danger {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 12px 14px;
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 12px;
            font-size: 13px;
            color: #b91c1c;
            margin-top: 4px;
        }

    </style>
    <style>
        /* nền mờ fade */
        .success-overlay {
            animation: overlayFade .25s ease;
        }
        @@keyframes overlayFade {
            from

        {
            opacity: 0
        }

        to {
            opacity: 1
        }

        }

        /* popup scale */
        .success-card {
            animation: popScale .3s ease;
        }
        @@keyframes popScale {
            0%

        {
            transform: scale(.85);
            opacity: 0
        }

        100% {
            transform: scale(1);
            opacity: 1
        }

        }

        /* vòng tròn */
        .check-circle {
            stroke-dasharray: 166;
            stroke-dashoffset: 166;
            animation: drawCircle .6s ease forwards;
        }

        /* dấu tích */
        .check-mark {
            stroke-dasharray: 48;
            stroke-dashoffset: 48;
            animation: drawCheck .4s ease .55s forwards;
        }

        @@keyframes drawCircle {
            to

        {
            stroke-dashoffset: 0
        }

        }

        @@keyframes drawCheck {
            to

        {
            stroke-dashoffset: 0
        }

        }
    </style>
    <script>
        /* JS GIỮ NGUYÊN HOÀN TOÀN TỪ FILE CŨ */
        (function () {
            const form = document.getElementById('registerForm');
            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                const btn = document.getElementById('registerBtn');
                const spinner = document.getElementById('registerSpinner');
                const btnText = document.getElementById('registerBtnText');
                try {
                    btn.disabled = true;
                    spinner.classList.remove('d-none');
                    btnText.textContent = 'Creating...';

                    const fd = new FormData(form);

                    const res = await fetch(window.location.href, {
                        method: 'POST',
                        body: fd,
                        credentials: 'same-origin'
                    });

                    if (!res.ok) {
                        const text = await res.text();
                        document.getElementById('registerMessage').innerHTML = `<div class="alert alert-danger">${text}</div>`;
                        return;
                    }

                    try {
                        const hres = await fetch('/api/ui/header', { credentials: 'same-origin' });
                        if (hres.ok) {
                            const html = await hres.text();
                            const container = document.getElementById('headerUserArea');
                            if (container) container.outerHTML = html;
                        }
                    } catch (e) { }

                                            const box = document.createElement("div");
        box.innerHTML = `
        <div class="fixed inset-0 flex items-center justify-center bg-black/40 z-50 success-overlay">
            <div class="bg-white rounded-2xl shadow-2xl p-7 w-80 text-center success-card">

                <div class="flex justify-center mb-4">
                    <svg width="72" height="72" viewBox="0 0 52 52">
                        <circle class="check-circle"
                                cx="26"
                                cy="26"
                                r="25"
                                fill="none"
                                stroke="#22c55e"
                                stroke-width="3"/>

                        <path class="check-mark"
                              fill="none"
                              stroke="#22c55e"
                              stroke-width="4"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M14 27l7 7 16-16"/>
                    </svg>
                </div>

                <h3 class="text-lg font-semibold text-slate-800 mb-1">
                    Account Created
                </h3>

                <p class="text-sm text-slate-500">
                    Redirecting to home...
                </p>

                <div class="mt-4 h-1 bg-slate-200 rounded overflow-hidden">
                    <div id="redirectBar" class="h-full bg-green-500 w-0"></div>
                </div>

            </div>
        </div>
        `;

        document.body.appendChild(box);

        /* progress bar animation */
        const bar = document.getElementById("redirectBar");
        let progress = 0;

        const interval = setInterval(()=>{
            progress += 4;
            bar.style.width = progress + "%";
            if(progress >= 100){
                clearInterval(interval);
            }
        },60);

        setTimeout(()=>{
            window.location.href = "/";
        },1500);

                } catch (err) {
                    document.getElementById('registerMessage').innerHTML = `<div class="alert alert-danger">Error</div>`;
                } finally {
                    btn.disabled = false;
                    spinner.classList.add('d-none');
                    btnText.textContent = 'Create account';
                }
            });
        })();
    </script>
}
