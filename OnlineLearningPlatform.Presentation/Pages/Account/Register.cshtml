@page
@model OnlineLearningPlatform.Presentation.Pages.Account.RegisterModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Register";
}
<div class="row justify-content-center align-items-center" style="min-height:70vh;">
    <div class="col-lg-8">
        <div class="card shadow-sm overflow-hidden">
            <div class="row g-0">
                <div class="col-md-6 d-none d-md-flex align-items-center justify-content-center login-illustration">
                    <div class="text-center text-white px-3">
                        <svg width="120" height="120" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <rect width="24" height="24" rx="4" fill="rgba(255,255,255,0.08)" />
                            <path d="M7 12h10M7 8h10M7 16h6" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <h4 class="mt-3">Join Edu Platform</h4>
                        <p class="small opacity-75">Create an account and start learning today.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <a href="/" class="text-decoration-none"><h3 class="m-0">Edu Platform</h3></a>
                            <p class="text-muted small">Register a new account</p>
                        </div>

                        <form id="registerForm" method="post" enctype="multipart/form-data">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                            @Html.AntiForgeryToken()
                            <div class="mb-3 form-floating">
                                <input asp-for="Input.FullName" class="form-control" id="fullName" placeholder="Full name" required />
                                <label for="fullName">Full name</label>
                                <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                            </div>

                            <div class="mb-3 form-floating">
                                <input asp-for="Input.Email" class="form-control" id="email" placeholder="name@example.com" type="email" required />
                                <label for="email">Email address</label>
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3 form-floating">
                                <input asp-for="Input.PhoneNumber" class="form-control" id="phone" placeholder="Phone number" />
                                <label for="phone">Phone</label>
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                            </div>

                            <div class="mb-3 form-floating">
                                <input asp-for="Input.Password" class="form-control" id="password" placeholder="Password" type="password" required />
                                <label for="password">Password</label>
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-3 form-floating">
                                <input asp-for="Input.ConfirmPassword" class="form-control" id="confirmPassword" placeholder="Confirm password" type="password" required />
                                <label for="confirmPassword">Confirm password</label>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label small">Avatar (optional)</label>
                                <input asp-for="Input.ImageFile" class="form-control" type="file" id="imageFile" accept="image/*" />
                                <span asp-validation-for="Input.ImageFile" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label for="role" class="form-label small">Register as</label>
                                <select asp-for="Input.Role" class="form-select" id="role" required>
                                    <option value="Student">Student</option>
                                    <option value="Instructor">Instructor</option>
                                </select>
                                <span asp-validation-for="Input.Role" class="text-danger small"></span>
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-success btn-lg" id="registerBtn">
                                    <span id="registerBtnText">Create account</span>
                                    <span id="registerSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
                                </button>
                            </div>

                            <div class="text-center">
                                <small class="text-muted">Already have an account? <a asp-page="/Account/Login">Sign in</a></small>
                            </div>
                        </form>

                        <div id="registerMessage" class="mt-3"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const form = document.getElementById('registerForm');
            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                const btn = document.getElementById('registerBtn');
                const spinner = document.getElementById('registerSpinner');
                const btnText = document.getElementById('registerBtnText');
                try {
                    btn.disabled = true;
                    spinner.classList.remove('d-none');
                    btnText.textContent = 'Creating...';

                    const fd = new FormData(form);

                    const res = await fetch(window.location.href, {
                        method: 'POST',
                        body: fd,
                        credentials: 'same-origin'
                    });

                    if (!res.ok) {
                        const text = await res.text();
                        document.getElementById('registerMessage').innerHTML = `<div class="alert alert-danger">${text}</div>`;
                        return;
                    }

                    // On success, navigate to login and refresh header
                    try {
                        const hres = await fetch('/api/ui/header', { credentials: 'same-origin' });
                        if (hres.ok) {
                            const html = await hres.text();
                            const container = document.getElementById('headerUserArea');
                            if (container) container.outerHTML = html;
                        }
                    } catch (e) { }

                    // navigate to login page
                    const loginRes = await fetch('/Account/Login', { headers: { 'X-Requested-With': 'XMLHttpRequest' }, credentials: 'same-origin' });
                    if (loginRes.ok) {
                        const text = await loginRes.text();
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(text, 'text/html');
                        const mainSelector = 'main[role="main"]';
                        const newMain = doc.querySelector(mainSelector) || doc.querySelector('main');
                        const mainEl = document.querySelector(mainSelector);
                        if (newMain && mainEl) mainEl.innerHTML = newMain.innerHTML;
                        const newTitle = doc.querySelector('title')?.innerText;
                        if (newTitle) document.title = newTitle;
                    } else {
                        window.location.href = '/Account/Login';
                    }

                } catch (err) {
                    document.getElementById('registerMessage').innerHTML = `<div class="alert alert-danger">Error</div>`;
                } finally {
                    btn.disabled = false;
                    spinner.classList.add('d-none');
                    btnText.textContent = 'Create account';
                }
            });
        })();
    </script>
}
