@page
@model OnlineLearningPlatform.Presentation.Pages.Account.RegisterModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Register";
}

<section class="min-h-[85vh] flex items-center justify-center px-4 py-12 bg-gray-50">
    <div class="w-full max-w-5xl grid md:grid-cols-2 rounded-3xl overflow-hidden shadow-2xl shadow-gray-200/60 bg-white anim-scale">

        <!-- Left: Illustration -->
        <div class="hidden md:flex flex-col items-center justify-center bg-gradient-animated relative overflow-hidden p-10">
            <div class="absolute top-8 left-8 w-48 h-48 bg-white/5 rounded-full anim-blob"></div>
            <div class="absolute bottom-12 right-8 w-36 h-36 bg-white/5 rounded-full anim-blob delay-400" style="animation-duration:11s"></div>

            <div class="relative z-10 text-center anim-fade-up">
                <div class="w-24 h-24 glass rounded-3xl flex items-center justify-center mx-auto mb-6 anim-float">
                    <i class="bi bi-person-plus-fill text-4xl text-white"></i>
                </div>
                <h3 class="text-2xl font-extrabold text-white mb-2">Join EduSphere</h3>
                <p class="text-white/70 text-sm max-w-xs mx-auto leading-relaxed">
                    Create an account and start your learning journey today. Choose to learn or teach!
                </p>

                <div class="flex justify-center gap-6 mt-8 text-white/60 text-xs">
                    <div class="text-center">
                        <i class="bi bi-play-circle-fill text-lg text-cyan-300 block mb-1"></i>
                        <div>HD Video</div>
                    </div>
                    <div class="w-px bg-white/20"></div>
                    <div class="text-center">
                        <i class="bi bi-award-fill text-lg text-yellow-300 block mb-1"></i>
                        <div>Certificate</div>
                    </div>
                    <div class="w-px bg-white/20"></div>
                    <div class="text-center">
                        <i class="bi bi-infinity text-lg text-green-300 block mb-1"></i>
                        <div>Lifetime</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Form -->
        <div class="p-8 md:p-10 flex flex-col justify-center" x-data="registerForm()" x-cloak>
            <div class="text-center mb-6 anim-fade-down">
                <a href="/" class="inline-flex items-center gap-2 mb-3">
                    <div class="w-8 h-8 bg-gradient-to-br from-ocean-500 to-cyan-400 rounded-xl flex items-center justify-center text-white shadow-md">
                        <i class="bi bi-mortarboard-fill text-sm"></i>
                    </div>
                    <span class="text-lg font-extrabold"><span class="text-gray-900">Edu</span><span class="text-gradient">Sphere</span></span>
                </a>
                <h2 class="text-2xl font-extrabold text-gray-900">Create account</h2>
                <p class="text-sm text-gray-400 mt-1">Fill in your details to get started</p>
            </div>

            <form id="registerForm" method="post" enctype="multipart/form-data" @@submit.prevent="submit" class="space-y-4">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>
                @Html.AntiForgeryToken()

                <!-- Full Name -->
                <div class="anim-fade-up delay-100">
                    <label for="fullName" class="block text-sm font-semibold text-gray-700 mb-1">Full Name</label>
                    <div class="relative">
                        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"><i class="bi bi-person"></i></span>
                        <input asp-for="Input.FullName" id="fullName" required placeholder="John Doe"
                               class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:border-ocean-400 focus:ring-2 focus:ring-ocean-100 outline-none transition" />
                    </div>
                    <span asp-validation-for="Input.FullName" class="text-red-500 text-xs"></span>
                </div>

                <!-- Email -->
                <div class="anim-fade-up delay-200">
                    <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">Email</label>
                    <div class="relative">
                        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Input.Email" id="email" type="email" required placeholder="you@example.com"
                               class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:border-ocean-400 focus:ring-2 focus:ring-ocean-100 outline-none transition" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-red-500 text-xs"></span>
                </div>

                <!-- Phone -->
                <div class="anim-fade-up delay-200">
                    <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1">Phone <span class="text-gray-300 font-normal">(optional)</span></label>
                    <div class="relative">
                        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"><i class="bi bi-phone"></i></span>
                        <input asp-for="Input.PhoneNumber" id="phone" placeholder="0912 345 678"
                               class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:border-ocean-400 focus:ring-2 focus:ring-ocean-100 outline-none transition" />
                    </div>
                </div>

                <!-- Password row -->
                <div class="grid grid-cols-2 gap-3 anim-fade-up delay-300">
                    <div x-data="{ show: false }">
                        <label for="password" class="block text-sm font-semibold text-gray-700 mb-1">Password</label>
                        <div class="relative">
                            <input asp-for="Input.Password" :type="show ? 'text' : 'password'" id="password" required placeholder="••••••"
                                   class="w-full pl-3 pr-9 py-2.5 rounded-xl border border-gray-200 text-sm focus:border-ocean-400 focus:ring-2 focus:ring-ocean-100 outline-none transition" />
                            <button type="button" @@click="show = !show" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition">
                                <i class="bi text-xs" :class="show ? 'bi-eye-slash' : 'bi-eye'"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-red-500 text-xs"></span>
                    </div>
                    <div>
                        <label for="confirmPassword" class="block text-sm font-semibold text-gray-700 mb-1">Confirm</label>
                        <input asp-for="Input.ConfirmPassword" type="password" id="confirmPassword" required placeholder="••••••"
                               class="w-full px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:border-ocean-400 focus:ring-2 focus:ring-ocean-100 outline-none transition" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-xs"></span>
                    </div>
                </div>

                <!-- Role + Avatar row -->
                <div class="grid grid-cols-2 gap-3 anim-fade-up delay-400">
                    <div>
                        <label for="role" class="block text-sm font-semibold text-gray-700 mb-1">Register as</label>
                        <select asp-for="Input.Role" id="role" required
                                class="w-full px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:border-ocean-400 outline-none transition bg-white">
                            <option value="Student">🎓 Student</option>
                            <option value="Instructor">👨‍🏫 Instructor</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Avatar <span class="text-gray-300 font-normal">(opt.)</span></label>
                        <input asp-for="Input.ImageFile" type="file" accept="image/*"
                               class="w-full text-xs file:mr-2 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-ocean-50 file:text-ocean-600 hover:file:bg-ocean-100 transition cursor-pointer" />
                    </div>
                </div>

                <!-- Submit -->
                <div class="pt-2 anim-fade-up delay-500">
                    <button type="submit" :disabled="loading"
                            class="w-full py-3 rounded-xl font-bold text-white bg-gradient-to-r from-ocean-500 to-cyan-500 hover:from-ocean-600 hover:to-cyan-600 shadow-lg shadow-ocean-200 hover:shadow-xl hover:scale-[1.01] transition-all duration-300 flex items-center justify-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed">
                        <template x-if="loading">
                            <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                            </svg>
                        </template>
                        <span x-text="loading ? 'Creating...' : 'Create account'"></span>
                    </button>
                </div>

                <!-- Error -->
                <template x-if="errorMsg">
                    <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl text-sm anim-scale"
                         x-text="errorMsg"></div>
                </template>

                <!-- Login link -->
                <div class="text-center pt-1 anim-fade-up delay-600">
                    <span class="text-sm text-gray-400">Already have an account?</span>
                    <a asp-page="/Account/Login" class="text-sm font-semibold text-ocean-600 hover:text-ocean-700 ml-1 transition">
                        Sign in
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function registerForm() {
            return {
                loading: false, errorMsg: '',
                async submit() {
                    this.errorMsg = '';
                    this.loading = true;
                    try {
                        const form = document.getElementById('registerForm');
                        const fd = new FormData(form);

                        const res = await fetch(window.location.href, {
                            method: 'POST',
                            body: fd,
                            credentials: 'same-origin'
                        });

                        if (!res.ok) {
                            const text = await res.text();
                            this.errorMsg = text || 'Registration failed';
                            return;
                        }

                        // Success — redirect to home (auto signed-in)
                        window.location.href = '/';
                    } catch (e) {
                        this.errorMsg = 'Something went wrong. Please try again.';
                    } finally {
                        this.loading = false;
                    }
                }
            }
        }
    </script>
}
