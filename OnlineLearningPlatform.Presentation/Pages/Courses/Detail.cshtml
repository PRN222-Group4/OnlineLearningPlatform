@page "{id:guid}"
@model OnlineLearningPlatform.Presentation.Pages.Courses.DetailModel
@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Course?.Title ?? "Course detail";
}

<div class="container">
    <div class="row">
        <div class="col-md-8">
            <h2>@Model.Course?.Title</h2>
            <p>@Model.Course?.Description</p>
            <p class="fw-bold">Price: @Model.Course?.Price.ToString("N0") đ</p>

            <h5>Modules</h5>
            @if (Model.Course?.Modules != null && Model.Course.Modules.Any())
            {
                <ul>
                    @foreach (var m in Model.Course.Modules)
                    {
                        <li>@m.Title
                            <ul>
                                @foreach (var l in m.Lessons)
                                {
                                    <li>@l.Title (@l.Duration)</li>
                                }
                            </ul>
                        </li>
                    }
                </ul>
            }

            <form method="post" asp-page-handler="Pay">
                <input type="hidden" asp-for="CourseId" />
                <input type="hidden" asp-for="Amount" />
                <button class="btn btn-primary">Pay / Enroll</button>
            </form>
        </div>
        <div class="col-md-4">
            <img src="@Model.Course?.Image" class="img-fluid rounded" />
            <div class="mt-3">
                <p>Instructor: @Model.Course?.InstructorName</p>
                <p>Students: @Model.Course?.Students</p>
            </div>
        </div>
    </div>
</div>