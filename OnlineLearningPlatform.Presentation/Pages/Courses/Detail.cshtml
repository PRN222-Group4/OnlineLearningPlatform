@page "{id:guid}"
@model OnlineLearningPlatform.Presentation.Pages.Courses.DetailModel
@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Course?.Title ?? "Course Detail";
}

<!-- Hero Banner -->
<section class="relative bg-gradient-animated overflow-hidden">
    <div class="absolute inset-0 bg-black/10"></div>
    <div class="absolute top-10 right-10 w-64 h-64 bg-white/5 rounded-full anim-blob"></div>
    <div class="absolute bottom-0 left-10 w-48 h-48 bg-white/5 rounded-full anim-blob delay-300"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 py-12">
        <nav class="flex items-center gap-2 text-sm text-white/60 mb-6 anim-fade-down">
            <a href="/" class="hover:text-white transition"><i class="bi bi-house-door"></i> Home</a>
            <i class="bi bi-chevron-right text-xs"></i>
            <span class="text-white/90">@Model.Course?.Title</span>
        </nav>

        <div class="max-w-2xl anim-fade-up">
            <h1 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight">@Model.Course?.Title</h1>
            <p class="mt-4 text-white/75 text-lg leading-relaxed">@Model.Course?.Description</p>

            <div class="flex flex-wrap items-center gap-5 mt-6 text-sm text-white/70">
                <span class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded-full bg-white/20 flex items-center justify-center">
                        <i class="bi bi-person-fill text-xs"></i>
                    </div>
                    @Model.Course?.InstructorName
                </span>
                <span class="flex items-center gap-2">
                    <i class="bi bi-people-fill"></i> @Model.Course?.Students students
                </span>
                <span class="flex items-center gap-2">
                    <i class="bi bi-star-fill text-yellow-300"></i> @Model.Course?.Rating
                </span>
            </div>
        </div>
    </div>
</section>

<!-- Content -->
<div class="max-w-7xl mx-auto px-6 -mt-6 relative z-20 pb-16">
    <div class="grid lg:grid-cols-3 gap-8">
        <!-- Left: Curriculum -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-lg shadow-gray-200/30 p-6 anim-fade-up delay-100">
                <h3 class="text-xl font-extrabold text-gray-900 flex items-center gap-2 mb-6">
                    <i class="bi bi-list-check text-ocean-500"></i> Course Curriculum
                </h3>

                @if (Model.Course?.Modules != null && Model.Course.Modules.Any())
                {
                    <div class="space-y-3" x-data="{ openModule: 0 }">
                        @{ var mIdx = 0; }
                        @foreach (var m in Model.Course.Modules)
                        {
                            <div class="border border-gray-100 rounded-xl overflow-hidden anim-fade-up delay-@(mIdx * 100 + 200)">
                                <button @@click="openModule = openModule === @mIdx ? -1 : @mIdx"
                                        class="w-full flex items-center justify-between px-5 py-4 bg-gray-50 hover:bg-gray-100 transition-colors text-left">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-lg bg-ocean-100 text-ocean-600 flex items-center justify-center text-sm font-bold">
                                            @(mIdx + 1)
                                        </div>
                                        <span class="font-bold text-gray-900">@m.Title</span>
                                    </div>
                                    <div class="flex items-center gap-3">
                                        <span class="text-xs text-gray-400 font-medium bg-gray-200 px-2.5 py-1 rounded-full">
                                            @m.Lessons.Count() lessons
                                        </span>
                                        <i class="bi bi-chevron-down text-gray-400 transition-transform duration-300"
                                           :class="openModule === @mIdx ? 'rotate-180' : ''"></i>
                                    </div>
                                </button>

                                <div x-show="openModule === @mIdx"
                                     x-transition:enter="transition ease-out duration-300"
                                     x-transition:enter-start="opacity-0 -translate-y-2"
                                     x-transition:enter-end="opacity-100 translate-y-0"
                                     style="display: none;">
                                    @foreach (var l in m.Lessons)
                                    {
                                        <div class="flex items-center gap-3 px-5 py-3 border-t border-gray-50 hover:bg-ocean-50/50 transition-colors group">
                                            <div class="w-8 h-8 rounded-lg bg-blue-50 text-blue-500 flex items-center justify-center text-sm group-hover:bg-blue-100 transition">
                                                <i class="bi bi-play-circle-fill"></i>
                                            </div>
                                            <span class="text-sm text-gray-700 flex-1">@l.Title</span>
                                            <i class="bi bi-lock-fill text-xs text-gray-300"></i>
                                        </div>
                                    }
                                </div>
                            </div>
                            mIdx++;
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-10">
                        <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-3">
                            <i class="bi bi-journal-text text-2xl text-gray-300"></i>
                        </div>
                        <p class="text-gray-400 text-sm">Course content will be available soon.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Right: Sidebar -->
        <div class="lg:col-span-1">
            <div class="sticky top-20">
                <div class="bg-white rounded-2xl border border-gray-100 shadow-xl shadow-gray-200/40 overflow-hidden anim-fade-up delay-200">
                    @if (!string.IsNullOrEmpty(Model.Course?.Image))
                    {
                        <img src="@Model.Course.Image" class="w-full h-48 object-cover" alt="" />
                    }
                    else
                    {
                        <div class="w-full h-48 bg-gradient-to-br from-ocean-100 to-cyan-50 flex items-center justify-content-center">
                            <i class="bi bi-book text-5xl text-ocean-300 mx-auto my-auto"></i>
                        </div>
                    }

                    <div class="p-6">
                        <div class="flex items-baseline gap-2 mb-5">
                            <span class="text-3xl font-extrabold text-ocean-600">@Model.Course?.Price.ToString("N0")</span>
                            <span class="text-sm text-gray-400">đ</span>
                        </div>

                        <form method="post" asp-page-handler="Pay">
                            <input type="hidden" asp-for="CourseId" />
                            <button type="submit"
                                    class="w-full py-3.5 rounded-xl font-bold text-white bg-gradient-to-r from-ocean-500 to-cyan-500 hover:from-ocean-600 hover:to-cyan-600 shadow-lg shadow-ocean-200 hover:shadow-xl hover:scale-[1.01] transition-all duration-300 flex items-center justify-center gap-2">
                                <i class="bi bi-cart-check-fill"></i> Enroll Now
                            </button>
                        </form>

                        <div class="mt-6 space-y-3 text-sm">
                            <div class="flex items-center justify-between py-2.5 border-b border-gray-100">
                                <span class="text-gray-500"><i class="bi bi-person mr-2 text-ocean-400"></i>Instructor</span>
                                <span class="font-semibold text-gray-900">@Model.Course?.InstructorName</span>
                            </div>
                            <div class="flex items-center justify-between py-2.5 border-b border-gray-100">
                                <span class="text-gray-500"><i class="bi bi-clock mr-2 text-ocean-400"></i>Duration</span>
                                <span class="font-semibold text-gray-900">@Model.Course?.Duration</span>
                            </div>
                            <div class="flex items-center justify-between py-2.5 border-b border-gray-100">
                                <span class="text-gray-500"><i class="bi bi-bar-chart mr-2 text-ocean-400"></i>Level</span>
                                <span class="font-semibold text-gray-900">@Model.Course?.Level</span>
                            </div>
                            <div class="flex items-center justify-between py-2.5">
                                <span class="text-gray-500"><i class="bi bi-patch-check mr-2 text-ocean-400"></i>Certificate</span>
                                <span class="font-semibold text-green-600">Yes ✓</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>