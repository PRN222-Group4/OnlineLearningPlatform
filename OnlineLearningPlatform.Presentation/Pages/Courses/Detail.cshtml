@page "{id:guid}"
@model OnlineLearningPlatform.Presentation.Pages.Courses.DetailModel
@{
    Layout = "~/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Course?.Title ?? "Course Detail";

    var c = Model.Course;
    var totalLessons = c?.Modules.Sum(m => m.Lessons.Count) ?? 0;
    var moduleCount = c?.Modules.Count ?? 0;
}

@if (c == null)
{
    <div class="max-w-2xl mx-auto px-4 py-24 text-center">
        <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <i class="fas fa-exclamation text-slate-400 text-xl"></i>
        </div>
        <p class="text-slate-500 font-medium">Course not found.</p>
        <a asp-page="/Courses/Index" class="mt-4 inline-block text-primary-600 hover:underline text-sm">← Back to courses</a>
    </div>
}
else
{
    <div class="bg-slate-900 text-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid lg:grid-cols-3 gap-10 items-start">

                <div class="lg:col-span-2">
                    <a asp-page="/Courses/Index"
                       class="inline-flex items-center gap-1.5 text-slate-400 hover:text-white text-sm mb-5 transition-colors no-underline">
                        <i class="fas fa-arrow-left text-xs"></i> All Courses
                    </a>

                    <div class="flex flex-wrap gap-2 mb-4">
                        @if (!string.IsNullOrEmpty(c.Category))
                        {
                            <span class="bg-primary-500/20 text-primary-300 text-xs font-semibold px-3 py-1 rounded-full">@c.Category</span>
                        }
                        @if (!string.IsNullOrEmpty(c.Level))
                        {
                            <span class="bg-white/10 text-slate-300 text-xs font-semibold px-3 py-1 rounded-full">@c.Level</span>
                        }
                    </div>

                    <h1 class="font-display text-3xl lg:text-4xl font-extrabold leading-tight mb-4">@c.Title</h1>

                    @if (!string.IsNullOrEmpty(c.Description))
                    {
                        <p class="text-slate-300 text-base leading-relaxed mb-6 max-w-2xl">@c.Description</p>
                    }

                    <div class="flex flex-wrap items-center gap-5 text-sm text-slate-300">
                        @if (c.Rating > 0)
                        {
                            <span class="flex items-center gap-1.5">
                                <i class="fas fa-star text-yellow-400 text-xs"></i>
                                <span class="text-white font-semibold">@c.Rating.ToString("F1")</span> rating
                            </span>
                        }
                        @if (c.Students > 0)
                        {
                            <span class="flex items-center gap-1.5">
                                <i class="fas fa-users text-xs"></i>
                                <span class="text-white font-semibold">@c.Students.ToString("N0")</span> students
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(c.Duration))
                        {
                            <span class="flex items-center gap-1.5">
                                <i class="fas fa-clock text-xs"></i> @c.Duration
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(c.InstructorName))
                        {
                            <span class="flex items-center gap-1.5">
                                <i class="fas fa-chalkboard-teacher text-xs"></i> @c.InstructorName
                            </span>
                        }
                    </div>
                </div>

                <div class="hidden lg:block">
                    <div class="bg-white text-slate-900 rounded-2xl shadow-2xl overflow-hidden">
                        @if (!string.IsNullOrEmpty(c.Image))
                        {
                            <img src="@c.Image" alt="@c.Title" class="w-full h-44 object-cover" />
                        }
                        else
                        {
                            <div class="w-full h-44 bg-slate-100 flex items-center justify-center">
                                <i class="fas fa-book-open text-slate-300 text-4xl"></i>
                            </div>
                        }
                        <div class="p-5">
                            <p class="text-3xl font-extrabold text-slate-900 mb-1">
                                @(c.Price == 0 ? "Free" : c.Price.ToString("N0") + " ₫")
                            </p>
                            @if (c.Price > 0)
                            {
                                <p class="text-xs text-slate-400 mb-4">One-time payment · Lifetime access</p>
                            }
                            else
                            {
                                <p class="text-xs text-slate-400 mb-4">No payment required</p>
                            }

                            @if (Model.UserRole == 0 || Model.UserRole == 1) // Staff hoặc Admin không được mua
                            {
                                <button disabled class="w-full flex items-center justify-center gap-2 py-3 bg-slate-100 text-slate-400 text-sm font-bold rounded-xl border border-slate-200 cursor-not-allowed">
                                    <i class="fas fa-ban text-xs"></i> Staff Cannot Enroll
                                </button>
                            }
                            @if (Model.UserRole == 0 || Model.UserRole == 1)
                            {
                            }
                            else if (Model.IsEnrolled)
                            {
                                <div class="space-y-3">
                                    <a asp-page="/Student/Learn" asp-route-courseId="@Model.CourseId"
                                       class="w-full flex items-center justify-center gap-2 py-3 bg-emerald-600 text-white text-sm font-bold rounded-xl hover:bg-emerald-700 transition-colors shadow-sm">
                                        <i class="fas fa-play-circle text-xs"></i> Go to Course
                                    </a>

                                    @if (c.Price > 0)
                                    {
                                        <a asp-page="/Student/Message" asp-route-partnerId="@Model.CourseAuthorId"
                                           class="w-full flex items-center justify-center gap-2 py-3 bg-purple-600 text-white text-sm font-bold rounded-xl hover:bg-purple-700 transition-colors shadow-sm">
                                            <i class="fas fa-comments text-xs"></i> Chat 1:1 with Instructor
                                        </a>
                                    }
                                    else
                                    {
                                        <button disabled title="This feature is only for Premium Paid Courses"
                                                class="w-full flex items-center justify-center gap-2 py-3 bg-slate-100 text-slate-400 text-sm font-bold rounded-xl border border-slate-200 cursor-not-allowed">
                                            <i class="fas fa-lock text-xs"></i> Premium Support (Paid Only)
                                        </button>
                                    }
                                </div>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="Pay" asp-route-id="@Model.CourseId">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Amount" value="@(c?.Price ?? 0)" />

                                    <button type="submit"
                                            class="w-full flex items-center justify-center gap-2 py-3 bg-primary-600 text-white text-sm font-bold rounded-xl hover:bg-primary-700 transition-colors shadow-lg shadow-primary-500/25">
                                        <i class="fas @(c?.Price == 0 ? "fa-bolt" : "fa-credit-card") text-xs"></i>
                                        @(c?.Price == 0 ? "Enroll for Free" : "Pay & Enroll")
                                    </button>
                                </form>
                            }

                            @if (TempData["Error"] is string err)
                            {
                                <p class="text-xs text-red-500 mt-2 text-center font-bold">@err</p>
                            }

                            <p class="text-xs text-slate-400 text-center mt-3">
                                <i class="fas fa-shield-alt mr-1"></i> 30-day money-back guarantee
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="grid lg:grid-cols-3 gap-8 items-start">

            <div class="lg:col-span-2 space-y-6">

                <div class="lg:hidden bg-white rounded-2xl border border-slate-200 p-5 shadow-sm">
                    <div class="flex items-baseline gap-2 mb-3">
                        <span class="text-2xl font-extrabold text-slate-900">
                            @(c.Price == 0 ? "Free" : c.Price.ToString("N0") + " ₫")
                        </span>
                    </div>

                    @if (Model.UserRole == 0 || Model.UserRole == 1)
                    {
                        <button disabled class="w-full flex items-center justify-center gap-2 py-3 bg-slate-100 text-slate-400 text-sm font-bold rounded-xl border border-slate-200 cursor-not-allowed">
                            <i class="fas fa-ban text-xs"></i> Staff Cannot Enroll
                        </button>
                    }
                    else if (Model.IsEnrolled)
                    {
                        <a asp-page="/Student/Learn" asp-route-courseId="@Model.CourseId"
                           class="w-full flex items-center justify-center gap-2 py-3 bg-emerald-600 text-white text-sm font-bold rounded-xl hover:bg-emerald-700 transition-colors shadow-sm">
                            <i class="fas fa-play-circle text-xs"></i> Go to Course
                        </a>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Pay" asp-route-id="@Model.CourseId">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Amount" value="@(c?.Price ?? 0)" />

                            <button type="submit"
                                    class="w-full flex items-center justify-center gap-2 py-3 bg-primary-600 text-white text-sm font-bold rounded-xl hover:bg-primary-700 transition-colors shadow-lg shadow-primary-500/25">
                                <i class="fas @(c?.Price == 0 ? "fa-bolt" : "fa-credit-card") text-xs"></i>
                                @(c?.Price == 0 ? "Enroll for Free" : "Pay & Enroll")
                            </button>
                        </form>
                    }
                </div>

                <div class="bg-white rounded-2xl border border-slate-200 p-6">
                    <h2 class="font-display text-lg font-bold text-slate-900 mb-4">This course includes</h2>
                    <div class="grid sm:grid-cols-2 gap-3">
                        <div class="flex items-center gap-3 text-sm text-slate-700">
                            <i class="fas fa-layer-group text-primary-500 w-4 text-center"></i>
                            <span><strong>@moduleCount</strong> modules</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm text-slate-700">
                            <i class="fas fa-list-ul text-primary-500 w-4 text-center"></i>
                            <span><strong>@totalLessons</strong> lessons</span>
                        </div>
                        @if (!string.IsNullOrEmpty(c.Duration))
                        {
                            <div class="flex items-center gap-3 text-sm text-slate-700">
                                <i class="fas fa-clock text-amber-500 w-4 text-center"></i>
                                <span>@c.Duration total</span>
                            </div>
                        }
                        <div class="flex items-center gap-3 text-sm text-slate-700">
                            <i class="fas fa-infinity text-emerald-500 w-4 text-center"></i>
                            <span>Lifetime access</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm text-slate-700">
                            <i class="fas fa-mobile-alt text-slate-400 w-4 text-center"></i>
                            <span>Mobile & desktop</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm text-slate-700">
                            <i class="fas fa-certificate text-rose-500 w-4 text-center"></i>
                            <span>Certificate of completion</span>
                        </div>
                    </div>
                </div>

                @if (c.Modules.Any())
                {
                    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
                        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
                            <h2 class="font-display text-lg font-bold text-slate-900">Course Curriculum</h2>
                            <span class="text-xs text-slate-400">@moduleCount modules · @totalLessons lessons</span>
                        </div>

                        <div class="divide-y divide-slate-100" x-data="{ open: 0 }">
                            @for (int mi = 0; mi < c.Modules.Count; mi++)
                            {
                                var m = c.Modules[mi];
                                var idx = mi;
                                <div>
                                    <button type="button"
                                    @@click ="open === @idx ? open = -1 : open = @idx"
                                            class="w-full flex items-center justify-between px-6 py-4 hover:bg-slate-50 transition-colors text-left">
                                        <div class="flex items-center gap-3">
                                            <div class="w-7 h-7 bg-primary-100 rounded-lg flex items-center justify-center text-primary-700 font-bold text-xs shrink-0">
                                                @(mi + 1)
                                            </div>
                                            <span class="text-sm font-semibold text-slate-900">@m.Title</span>
                                            <span class="text-xs text-slate-400">@m.Lessons.Count lesson@(m.Lessons.Count != 1 ? "s" : "")</span>
                                        </div>
                                        <i class="fas fa-chevron-down text-slate-400 text-xs transition-transform duration-200"
                                           :class="open === @idx ? 'rotate-180' : ''"></i>
                                    </button>

                                    <div x-show="open === @idx" x-cloak
                                         class="bg-slate-50 border-t border-slate-100">
                                        @if (m.Lessons.Any())
                                        {
                                            @foreach (var l in m.Lessons)
                                            {
                                                var icon = l.Type?.ToLower() switch
                                                {
                                                    "video" => ("fa-play-circle", "text-blue-500"),
                                                    "reading" => ("fa-file-alt", "text-violet-500"),
                                                    "quiz" => ("fa-tasks", "text-amber-500"),
                                                    _ => ("fa-circle", "text-slate-400")
                                                };
                                                <div class="flex items-center justify-between px-6 py-3 border-b border-slate-100 last:border-0 hover:bg-white transition-colors">
                                                    <div class="flex items-center gap-3">
                                                        <i class="fas @icon.Item1 @icon.Item2 text-xs w-4 text-center"></i>
                                                        <span class="text-sm text-slate-700">@l.Title</span>
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(l.Duration))
                                                    {
                                                        <span class="text-xs text-slate-400 shrink-0">@l.Duration</span>
                                                    }
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <p class="px-6 py-3 text-xs text-slate-400">No lessons yet.</p>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="hidden lg:block sticky top-20 space-y-4">

                @if (!string.IsNullOrEmpty(c.InstructorName))
                {
                    <div class="bg-white rounded-2xl border border-slate-200 p-5">
                        <h3 class="text-sm font-semibold text-slate-700 mb-3">Your instructor</h3>
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold text-sm shrink-0">
                                @c.InstructorName[0].ToString().ToUpper()
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-slate-900">@c.InstructorName</p>
                                <p class="text-xs text-slate-400">Course Instructor</p>
                            </div>
                        </div>
                        @if (c.Rating > 0)
                        {
                            <div class="mt-3 flex items-center gap-1.5 text-xs text-slate-500">
                                <i class="fas fa-star text-yellow-400"></i>
                                <span><strong class="text-slate-700">@c.Rating.ToString("F1")</strong> instructor rating</span>
                            </div>
                        }
                        @if (c.Students > 0)
                        {
                            <div class="mt-1.5 flex items-center gap-1.5 text-xs text-slate-500">
                                <i class="fas fa-users text-slate-400"></i>
                                <span><strong class="text-slate-700">@c.Students.ToString("N0")</strong> students</span>
                            </div>
                        }
                    </div>
                }

                <div class="bg-white rounded-2xl border border-slate-200 p-5">
                    <h3 class="text-sm font-semibold text-slate-700 mb-3">Share this course</h3>
                    <div class="flex gap-2">
                        <button onclick="navigator.clipboard.writeText(window.location.href).then(()=>alert('Link copied!'))"
                                class="flex-1 py-2 bg-slate-50 text-slate-600 text-xs font-semibold rounded-lg hover:bg-slate-100 transition-colors">
                            <i class="fas fa-link mr-1"></i> Copy link
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}