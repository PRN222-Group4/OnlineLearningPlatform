@page
@model OnlineLearningPlatform.Presentation.Pages.Courses.IndexModel
@{
    ViewData["Title"] = "Explore Courses";
}

<div x-data="{ mobileFiltersOpen: false }" class="bg-slate-50 min-h-screen pb-20 font-sans">

    <div class="bg-slate-900 pt-16 pb-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-3xl md:text-4xl font-display font-extrabold text-white mb-4 tracking-tight">Explore Knowledge</h1>
            <p class="text-slate-400 max-w-2xl mx-auto text-sm md:text-base">Find the perfect course to level up your career. From coding to design, learn from top industry experts.</p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-12">
        <div class="flex flex-col lg:flex-row gap-8">

            <div class="hidden lg:block w-64 shrink-0">
                <form method="get" id="filterForm" class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5 sticky top-24">
                    <input type="hidden" asp-for="Filter.SearchTerm" />
                    <input type="hidden" asp-for="Filter.SortBy" />

                    <div class="flex items-center justify-between mb-6">
                        <h2 class="font-bold text-slate-900 flex items-center gap-2"><i class="fas fa-filter text-slate-400"></i> Filters</h2>
                        <a href="/Courses" class="text-xs font-semibold text-primary-600 hover:text-primary-700">Clear all</a>
                    </div>

                    <div class="mb-6 border-b border-slate-100 pb-6">
                        <h3 class="text-sm font-bold text-slate-900 mb-3">Level</h3>
                        <div class="space-y-2.5">
                            @foreach (var level in new[] { 0, 1, 2, 3 })
                            {
                                bool isChecked = Model.Filter.Levels != null && Model.Filter.Levels.Contains(level);
                                <label class="flex items-center gap-3 group cursor-pointer">
                                    <input type="checkbox" name="Filter.Levels" value="@level" checked="@isChecked" onchange="document.getElementById('filterForm').submit();"
                                           class="w-4 h-4 rounded border-slate-300 text-primary-600 focus:ring-primary-500/30 cursor-pointer" />
                                    <span class="text-sm text-slate-600 group-hover:text-slate-900 transition-colors">@Model.GetLevelString(level)</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div>
                        <h3 class="text-sm font-bold text-slate-900 mb-3">Price</h3>
                        <div class="space-y-2.5">
                            <label class="flex items-center gap-3 group cursor-pointer">
                                <input type="radio" name="Filter.IsFree" value="" checked="@(Model.Filter.IsFree == null)" onchange="document.getElementById('filterForm').submit();" class="w-4 h-4 border-slate-300 text-primary-600 cursor-pointer" />
                                <span class="text-sm text-slate-600 group-hover:text-slate-900">All Prices</span>
                            </label>
                            <label class="flex items-center gap-3 group cursor-pointer">
                                <input type="radio" name="Filter.IsFree" value="false" checked="@(Model.Filter.IsFree == false)" onchange="document.getElementById('filterForm').submit();" class="w-4 h-4 border-slate-300 text-primary-600 cursor-pointer" />
                                <span class="text-sm text-slate-600 group-hover:text-slate-900">Paid</span>
                            </label>
                            <label class="flex items-center gap-3 group cursor-pointer">
                                <input type="radio" name="Filter.IsFree" value="true" checked="@(Model.Filter.IsFree == true)" onchange="document.getElementById('filterForm').submit();" class="w-4 h-4 border-slate-300 text-primary-600 cursor-pointer" />
                                <span class="text-sm text-slate-600 group-hover:text-slate-900">Free</span>
                            </label>
                        </div>
                    </div>
                </form>
            </div>

            <div class="flex-1">

                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-3 mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                    <div class="flex items-center gap-4">
                        <button @@click ="mobileFiltersOpen = true" class="lg:hidden inline-flex items-center gap-2 px-4 py-2 bg-slate-100 text-slate-700 text-sm font-semibold rounded-xl hover:bg-slate-200 transition-colors">
                            <i class="fas fa-sliders-h"></i> Filters
                        </button>
                        <p class="text-sm font-semibold text-slate-700 hidden sm:block">
                            Showing <span class="text-slate-900">@Model.CourseData.TotalItems</span> courses
                        </p>
                    </div>

                    <form method="get" class="flex items-center gap-3 w-full sm:w-auto">
                        @if (Model.Filter.Levels != null)
                        {
                            foreach (var l in Model.Filter.Levels)
                            {
                                <input type="hidden" name="Filter.Levels" value="@l" />
                            }
                        }
                        @if (Model.Filter.IsFree.HasValue)
                        {
                            <input type="hidden" name="Filter.IsFree" value="@Model.Filter.IsFree.ToString().ToLower()" />
                        }

                        <div class="relative flex-1 sm:w-64">
                            <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs"></i>
                            <input type="text" asp-for="Filter.SearchTerm" placeholder="Search courses..." class="w-full pl-8 pr-3 py-2 text-sm bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-primary-100 focus:border-primary-400 transition-all" />
                        </div>

                        <select asp-for="Filter.SortBy" onchange="this.form.submit()" class="px-4 py-2 bg-slate-50 border border-slate-200 text-slate-700 text-sm font-semibold rounded-lg outline-none">
                            <option value="newest">Newest</option>
                            <option value="price_asc">Price: Low to High</option>
                        </select>
                    </form>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                    @foreach (var c in Model.CourseData.Courses)
                    {
                        <a asp-page="/Courses/Detail" asp-route-id="@c.CourseId"
                           class="group bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow-xl hover:border-primary-200 hover:-translate-y-1 transition-all duration-300 flex flex-col overflow-hidden no-underline relative">

                            <div class="relative h-48 overflow-hidden bg-slate-100 shrink-0">
                                @if (!string.IsNullOrEmpty(c.Image))
                                {
                                    <img src="@c.Image" alt="@c.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out" />
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center text-slate-300">
                                        <i class="fas fa-image text-4xl"></i>
                                    </div>
                                }
                                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                            </div>

                            <div class="p-5 flex flex-col flex-1">
                                <div class="flex items-center gap-3 text-[11px] font-semibold text-slate-500 uppercase tracking-wider mb-3">
                                    <span class="flex items-center gap-1"><i class="fas fa-signal text-primary-500"></i> @Model.GetLevelString(int.Parse(c.Level ?? "0"))</span>
                                </div>

                                <h3 class="text-base font-bold text-slate-900 leading-snug mb-2 group-hover:text-primary-700 transition-colors line-clamp-2">
                                    @c.Title
                                </h3>

                                <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between">
                                    <div class="flex flex-col items-end w-full">
                                        @if (c.Price == 0)
                                        {
                                            <span class="text-lg font-display font-extrabold text-emerald-600">Free</span>
                                        }
                                        else
                                        {
                                            <span class="text-lg font-display font-extrabold text-slate-900">@c.Price.ToString("N0") ₫</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>

                @if (Model.CourseData.TotalPages > 1)
                {
                    <div class="mt-10 flex justify-center">
                        <nav class="flex items-center gap-1 bg-white p-1 rounded-xl shadow-sm border border-slate-200">
                            @for (int i = 1; i <= Model.CourseData.TotalPages; i++)
                            {
                                <a asp-page="./Index"
                                   asp-route-Filter.PageNumber="@i"
                                   asp-route-Filter.SearchTerm="@Model.Filter.SearchTerm"
                                   asp-route-Filter.IsFree="@Model.Filter.IsFree"
                                   asp-route-Filter.SortBy="@Model.Filter.SortBy"
                                   class="w-9 h-9 flex items-center justify-center rounded-lg font-semibold text-sm transition-colors
                                          @(i == Model.CourseData.CurrentPage ? "bg-primary-600 text-white shadow-md" : "text-slate-600 hover:bg-slate-100")">
                                    @i
                                </a>
                            }
                        </nav>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/realtimeHub")
            .withAutomaticReconnect()
            .build();

        connection.on("PublicCourseListChanged", async () => {
            showUpdateToast();

            try {
                const response = await fetch(window.location.href);
                const htmlText = await response.text();

                const parser = new DOMParser();
                const doc = parser.parseFromString(htmlText, 'text/html');

                const newGrid = doc.querySelector('.grid.grid-cols-1.md\\:grid-cols-2.xl\\:grid-cols-3');
                const currentGrid = document.querySelector('.grid.grid-cols-1.md\\:grid-cols-2.xl\\:grid-cols-3');
                if (newGrid && currentGrid) {
                    currentGrid.innerHTML = newGrid.innerHTML;
                }

                const newCounter = doc.querySelector('.text-sm.font-semibold.text-slate-700.hidden.sm\\:block');
                const currentCounter = document.querySelector('.text-sm.font-semibold.text-slate-700.hidden.sm\\:block');
                if (newCounter && currentCounter) {
                    currentCounter.innerHTML = newCounter.innerHTML;
                }

                const newPagination = doc.querySelector('nav.flex.items-center.gap-1');
                const currentPagination = document.querySelector('nav.flex.items-center.gap-1');
                if (newPagination && currentPagination) {
                    currentPagination.innerHTML = newPagination.innerHTML;
                } else if (newPagination && !currentPagination) {
                    location.reload();
                }

            } catch (error) {
                console.error("SignalR Realtime DOM Update Error:", error);
            }
        });

        connection.start()
            .then(() => console.log("✅ SignalR Connected (Explore Courses - Realtime DOM)"))
            .catch(err => console.error("SignalR error: ", err));

        function showUpdateToast() {
            const toast = document.createElement('div');
            toast.className = 'fixed bottom-5 right-5 z-[200] flex items-center gap-3 px-6 py-4 rounded-xl shadow-2xl border text-sm font-bold bg-indigo-600 border-indigo-500 text-white transition-all transform translate-y-10 opacity-0';
            document.body.appendChild(toast);

            setTimeout(() => { toast.classList.remove('translate-y-10', 'opacity-0'); }, 10);

            setTimeout(() => {
                toast.classList.add('translate-y-10', 'opacity-0');
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }
    </script>
}