@page
@model OnlineLearningPlatform.Presentation.Pages.Courses.IndexModel
@{
    ViewData["Title"] = "Explore Courses";

    // MOCK DATA: Chạy UI cho mượt trước, sau này bạn đổi thành Model.Courses là xong
    var categories = new[] { "Web Development", "Data Science", "Mobile Dev", "UI/UX Design", "DevOps", "Marketing" };
    var levels = new[] { "All Levels", "Beginner", "Intermediate", "Advanced" };

    var dummyCourses = new[]
    {
        new { Id = 1, Title = "The Complete Web Development Bootcamp 2026", Instructor = "Nam Dang", Rating = 4.9, Reviews = "12.4k", Level = "All Levels", Price = 499000, OriginalPrice = 1200000, Badge = "Bestseller", Image = "https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=600&q=80", Duration = "64h 30m" },
        new { Id = 2, Title = "AWS Certified Solutions Architect - Associate", Instructor = "HuyShop Team", Rating = 4.8, Reviews = "8.2k", Level = "Intermediate", Price = 599000, OriginalPrice = 1500000, Badge = "New", Image = "https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=600&q=80", Duration = "22h 15m" },
        new { Id = 3, Title = "Mastering UI/UX Design with Figma", Instructor = "Sarah Jenkins", Rating = 4.7, Reviews = "3.1k", Level = "Beginner", Price = 0, OriginalPrice = 0, Badge = "", Image = "https://images.unsplash.com/photo-1561070791-2526d30994b5?auto=format&fit=crop&w=600&q=80", Duration = "12h 45m" },
        new { Id = 4, Title = "DevOps Masterclass: CI/CD with Docker & K8s", Instructor = "Nam Dang", Rating = 4.9, Reviews = "5.5k", Level = "Advanced", Price = 799000, OriginalPrice = 2000000, Badge = "Hot", Image = "https://images.unsplash.com/photo-1618401471353-b98afee0b2eb?auto=format&fit=crop&w=600&q=80", Duration = "40h 00m" },
        new { Id = 5, Title = "Python for Data Science and Machine Learning", Instructor = "Dr. Alex Rivera", Rating = 4.6, Reviews = "9.8k", Level = "Beginner", Price = 350000, OriginalPrice = 800000, Badge = "", Image = "https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=600&q=80", Duration = "35h 20m" },
        new { Id = 6, Title = "React Native: Build Cross-Platform Apps", Instructor = "CodeMasters", Rating = 4.8, Reviews = "2.2k", Level = "Intermediate", Price = 450000, OriginalPrice = 900000, Badge = "", Image = "https://images.unsplash.com/photo-1555099962-4199c345e5dd?auto=format&fit=crop&w=600&q=80", Duration = "28h 10m" },
    };
}

<div x-data="{ mobileFiltersOpen: false }" class="bg-slate-50 min-h-screen pb-20 font-sans">

    <div class="bg-slate-900 pt-16 pb-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-3xl md:text-4xl font-display font-extrabold text-white mb-4 tracking-tight">Explore 10,000+ Courses</h1>
            <p class="text-slate-400 max-w-2xl mx-auto text-sm md:text-base">Find the perfect course to level up your career. From coding to design, learn from top industry experts.</p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-12">
        <div class="flex flex-col lg:flex-row gap-8">

            <div class="hidden lg:block w-64 shrink-0">
                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5 sticky top-24">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="font-bold text-slate-900 flex items-center gap-2"><i class="fas fa-filter text-slate-400"></i> Filters</h2>
                        <button class="text-xs font-semibold text-primary-600 hover:text-primary-700">Clear all</button>
                    </div>

                    <div class="mb-6 border-b border-slate-100 pb-6">
                        <h3 class="text-sm font-bold text-slate-900 mb-3">Category</h3>
                        <div class="space-y-2.5">
                            @foreach (var cat in categories)
                            {
                                <label class="flex items-center gap-3 group cursor-pointer">
                                    <input type="checkbox" class="w-4 h-4 rounded border-slate-300 text-primary-600 focus:ring-primary-500/30 transition-colors cursor-pointer" />
                                    <span class="text-sm text-slate-600 group-hover:text-slate-900 transition-colors">@cat</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="mb-6 border-b border-slate-100 pb-6">
                        <h3 class="text-sm font-bold text-slate-900 mb-3">Level</h3>
                        <div class="space-y-2.5">
                            @foreach (var level in levels)
                            {
                                <label class="flex items-center gap-3 group cursor-pointer">
                                    <input type="checkbox" class="w-4 h-4 rounded border-slate-300 text-primary-600 focus:ring-primary-500/30 transition-colors cursor-pointer" />
                                    <span class="text-sm text-slate-600 group-hover:text-slate-900 transition-colors">@level</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div>
                        <h3 class="text-sm font-bold text-slate-900 mb-3">Price</h3>
                        <div class="space-y-2.5">
                            <label class="flex items-center gap-3 group cursor-pointer">
                                <input type="radio" name="price" class="w-4 h-4 border-slate-300 text-primary-600 focus:ring-primary-500/30 transition-colors cursor-pointer" />
                                <span class="text-sm text-slate-600 group-hover:text-slate-900 transition-colors">Paid</span>
                            </label>
                            <label class="flex items-center gap-3 group cursor-pointer">
                                <input type="radio" name="price" class="w-4 h-4 border-slate-300 text-primary-600 focus:ring-primary-500/30 transition-colors cursor-pointer" />
                                <span class="text-sm text-slate-600 group-hover:text-slate-900 transition-colors">Free</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div x-show="mobileFiltersOpen" x-cloak class="fixed inset-0 flex z-50 lg:hidden" role="dialog" aria-modal="true">
                <div x-show="mobileFiltersOpen" x-transition:enter="transition-opacity ease-linear duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition-opacity ease-linear duration-300" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm" @@click ="mobileFiltersOpen = false"></div>
                <div x-show="mobileFiltersOpen" x-transition:enter="transition ease-in-out duration-300 transform" x-transition:enter-start="translate-y-full" x-transition:enter-end="translate-y-0" x-transition:leave="transition ease-in-out duration-300 transform" x-transition:leave-start="translate-y-0" x-transition:leave-end="translate-y-full" class="relative ml-auto w-full h-[85vh] mt-auto max-w-none bg-white rounded-t-3xl flex flex-col py-4 pb-6 shadow-xl">
                    <div class="flex items-center justify-between px-4 pb-3 border-b border-slate-100">
                        <h2 class="text-lg font-bold text-slate-900">Filters</h2>
                        <button type="button" @@click ="mobileFiltersOpen = false" class="w-8 h-8 flex items-center justify-center rounded-full bg-slate-100 text-slate-500">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="px-4 py-4 overflow-y-auto flex-1">
                        <p class="text-slate-500 text-sm">Filter options go here...</p>
                    </div>
                    <div class="px-4 pt-4 border-t border-slate-100">
                        <button @@click ="mobileFiltersOpen = false" class="w-full py-3 bg-primary-600 text-white rounded-xl font-bold shadow-lg shadow-primary-500/30">Apply Filters</button>
                    </div>
                </div>
            </div>

            <div class="flex-1">

                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-3 mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">

                    <div class="flex items-center gap-4">
                        <button @@click ="mobileFiltersOpen = true" class="lg:hidden inline-flex items-center gap-2 px-4 py-2 bg-slate-100 text-slate-700 text-sm font-semibold rounded-xl hover:bg-slate-200 transition-colors">
                            <i class="fas fa-sliders-h"></i> Filters
                        </button>
                        <p class="text-sm font-semibold text-slate-700 hidden sm:block">
                            Showing <span class="text-slate-900">@dummyCourses.Length</span> courses
                        </p>
                    </div>

                    <div class="flex items-center gap-3 w-full sm:w-auto">
                        <div class="relative flex-1 sm:w-64">
                            <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs"></i>
                            <input type="text" placeholder="Search specifically..." class="w-full pl-8 pr-3 py-2 text-sm bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-primary-100 focus:border-primary-400 transition-all" />
                        </div>

                        <div class="relative shrink-0" x-data="{ sortOpen: false }">
                            <button @@click ="sortOpen = !sortOpen" @@click.away ="sortOpen = false" class="flex items-center gap-2 px-4 py-2 bg-slate-50 border border-slate-200 text-slate-700 text-sm font-semibold rounded-lg hover:bg-slate-100 transition-colors">
                                <span>Most Popular</span>
                                <i class="fas fa-chevron-down text-[10px] text-slate-400"></i>
                            </button>
                            <div x-show="sortOpen" x-cloak class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-xl ring-1 ring-slate-200 py-1.5 z-20">
                                <a href="#" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-primary-600 font-medium">Most Popular</a>
                                <a href="#" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-primary-600 font-medium">Highest Rated</a>
                                <a href="#" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-primary-600 font-medium">Newest</a>
                                <a href="#" class="block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-primary-600 font-medium">Price: Low to High</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                    @foreach (var c in dummyCourses)
                    {
                        <a asp-page="/Courses/Detail" asp-route-id="@c.Id"
                           class="group bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow-xl hover:border-primary-200 hover:-translate-y-1 transition-all duration-300 flex flex-col overflow-hidden no-underline relative">

                            <div class="relative h-48 overflow-hidden bg-slate-100 shrink-0">
                                <img src="@c.Image" alt="@c.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out" />

                                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

                                @if (!string.IsNullOrEmpty(c.Badge))
                                {
                                    <div class="absolute top-3 left-3 bg-amber-400 text-amber-950 text-[10px] font-extrabold uppercase tracking-widest px-2.5 py-1 rounded-md shadow-sm">
                                        @c.Badge
                                    </div>
                                }

                                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                    <div class="w-12 h-12 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center text-primary-600 shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                                        <i class="fas fa-play ml-1"></i>
                                    </div>
                                </div>
                            </div>

                            <div class="p-5 flex flex-col flex-1">
                                <div class="flex items-center gap-3 text-[11px] font-semibold text-slate-500 uppercase tracking-wider mb-3">
                                    <span class="flex items-center gap-1"><i class="fas fa-signal text-primary-500"></i> @c.Level</span>
                                    <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                                    <span class="flex items-center gap-1"><i class="far fa-clock text-slate-400"></i> @c.Duration</span>
                                </div>

                                <h3 class="text-base font-bold text-slate-900 leading-snug mb-2 group-hover:text-primary-700 transition-colors line-clamp-2">
                                    @c.Title
                                </h3>

                                <p class="text-xs text-slate-500 mb-4">By <span class="font-semibold text-slate-700">@c.Instructor</span></p>

                                <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between">
                                    <div class="flex flex-col">
                                        <div class="flex items-center gap-1 text-xs font-bold text-slate-700">
                                            <span class="text-amber-400"><i class="fas fa-star"></i></span>
                                            <span>@c.Rating</span>
                                            <span class="text-slate-400 font-medium font-sans">(@c.Reviews)</span>
                                        </div>
                                    </div>
                                    <div class="flex flex-col items-end">
                                        @if (c.Price == 0)
                                        {
                                            <span class="text-lg font-display font-extrabold text-emerald-600">Free</span>
                                        }
                                        else
                                        {
                                            <span class="text-lg font-display font-extrabold text-slate-900">@c.Price.ToString("N0") ₫</span>
                                            @if (c.OriginalPrice > c.Price)
                                            {
                                                <span class="text-[10px] text-slate-400 line-through">@c.OriginalPrice.ToString("N0") ₫</span>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>

                <div class="mt-10 flex justify-center">
                    <nav class="flex items-center gap-1 bg-white p-1 rounded-xl shadow-sm border border-slate-200">
                        <button class="w-9 h-9 flex items-center justify-center rounded-lg text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-colors disabled:opacity-50" disabled>
                            <i class="fas fa-chevron-left text-xs"></i>
                        </button>
                        <button class="w-9 h-9 flex items-center justify-center rounded-lg bg-primary-600 text-white font-bold text-sm shadow-md">1</button>
                        <button class="w-9 h-9 flex items-center justify-center rounded-lg text-slate-600 font-semibold text-sm hover:bg-slate-100 transition-colors">2</button>
                        <button class="w-9 h-9 flex items-center justify-center rounded-lg text-slate-600 font-semibold text-sm hover:bg-slate-100 transition-colors">3</button>
                        <span class="px-2 text-slate-400">...</span>
                        <button class="w-9 h-9 flex items-center justify-center rounded-lg text-slate-600 font-semibold text-sm hover:bg-slate-100 transition-colors">8</button>
                        <button class="w-9 h-9 flex items-center justify-center rounded-lg text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition-colors">
                            <i class="fas fa-chevron-right text-xs"></i>
                        </button>
                    </nav>
                </div>

            </div>
        </div>
    </div>
</div>