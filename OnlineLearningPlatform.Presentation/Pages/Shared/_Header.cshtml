@using System.Security.Claims

<nav class="sticky top-0 z-50 w-full backdrop-blur-md bg-white/85 border-b border-slate-200 transition-all duration-300 font-sans"
     x-data="{ mobileOpen: false, profileOpen: false, scrolled: false }"
     x-on:scroll.window="scrolled = (window.pageYOffset > 10)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 gap-6">

            <a asp-page="/Index" class="flex items-center gap-2.5 shrink-0 no-underline group outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-lg">
                <div class="w-8 h-8 bg-gradient-to-br from-slate-800 to-slate-900 rounded-xl flex items-center justify-center group-hover:from-primary-600 group-hover:to-primary-700 transition-all shadow-sm">
                    <i class="fas fa-layer-group text-white text-sm"></i>
                </div>
                <span class="font-display font-extrabold text-xl text-slate-900 tracking-tight group-hover:text-primary-700 transition-colors">CourseSphere</span>
            </a>

            <div class="hidden md:flex items-center gap-1.5 shrink-0">
                <a asp-page="/Courses/Index"
                   class="px-3.5 py-2 text-sm font-semibold rounded-lg transition-all duration-200
                          @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Courses") == true
                            ? "text-primary-700 bg-primary-50/80"
                            : "text-slate-600 hover:text-slate-900 hover:bg-slate-100/80")">
                    Explore
                </a>

                @if (User.IsInRole("Student"))
                {
                    <a asp-page="/Student/MyCourses"
                       class="px-3.5 py-2 text-sm font-semibold rounded-lg transition-all duration-200
                              @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Student") == true
                                ? "text-primary-700 bg-primary-50/80"
                                : "text-slate-600 hover:text-slate-900 hover:bg-slate-100/80")">
                        My Learning
                    </a>
                }

                @if (User.IsInRole("Instructor"))
                {
                    <a asp-page="/Teacher/Courses/Create"
                       class="px-3.5 py-2 text-sm font-semibold rounded-lg transition-all duration-200
                              @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Teacher/Courses/Create") == true
                                ? "text-primary-700 bg-primary-50/80"
                                : "text-slate-600 hover:text-slate-900 hover:bg-slate-100/80")">
                        Create Course
                    </a>
                }
            </div>

            <div class="hidden lg:flex flex-1 max-w-md mx-auto">
                <div class="relative w-full group">
                    <i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 text-sm group-focus-within:text-primary-500 transition-colors pointer-events-none"></i>
                    <input type="text" placeholder="Search for courses, skills, or mentors..."
                           class="w-full pl-10 pr-4 py-2 text-sm text-slate-800 bg-slate-100/80 border border-transparent rounded-xl
                                  focus:outline-none focus:bg-white focus:border-primary-300 focus:ring-4 focus:ring-primary-500/10 transition-all placeholder:text-slate-400" />
                    <div class="absolute right-2 top-1/2 -translate-y-1/2 hidden xl:flex items-center gap-1">
                        <span class="px-1.5 py-0.5 rounded border border-slate-200 text-[10px] text-slate-400 font-mono font-medium bg-white">Ctrl</span>
                        <span class="px-1.5 py-0.5 rounded border border-slate-200 text-[10px] text-slate-400 font-mono font-medium bg-white">K</span>
                    </div>
                </div>
            </div>

            <div class="flex items-center gap-3 shrink-0">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var avatarUrl = User.FindFirst("Avatar")?.Value;
                    var fullName = User.Identity?.Name ?? "User";
                    var email = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
                    var initial = fullName.Length > 0 ? fullName[0].ToString().ToUpper() : "U";

                    @if (User.IsInRole("Instructor"))
                    {
                        <a asp-page="/Teacher/Dashboard" class="hidden md:flex items-center gap-2 px-3.5 py-1.5 text-sm font-bold text-slate-600 hover:text-primary-700 hover:bg-primary-50 rounded-lg transition-all">
                            <i class="fas fa-chalkboard-teacher text-xs"></i> Instructor
                        </a>
                        <div class="hidden md:block w-px h-5 bg-slate-200 mx-1"></div>
                    }

                    <button class="relative p-2 text-slate-500 hover:text-slate-900 hover:bg-slate-100 rounded-xl transition-all focus:outline-none focus:ring-2 focus:ring-primary-500/20">
                        <i class="far fa-bell text-[17px]"></i>
                        <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-rose-500 rounded-full border-2 border-white ring-2 ring-white/50 animate-pulse"></span>
                    </button>

                    <div class="relative">
                        <button x-on:click="profileOpen = !profileOpen" x-on:click.away="profileOpen = false"
                                class="flex items-center gap-2 p-1 rounded-full hover:bg-slate-100 transition-all focus:outline-none focus:ring-2 focus:ring-primary-500/20">
                            @if (!string.IsNullOrEmpty(avatarUrl))
                            {
                                <img src="@avatarUrl" alt="@fullName" class="w-8 h-8 rounded-full object-cover ring-1 ring-slate-200 shadow-sm" />
                            }
                            else
                            {
                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-primary-100 to-primary-200 flex items-center justify-center text-primary-800 font-extrabold text-xs ring-1 ring-slate-200">
                                    @initial
                                </div>
                            }
                        </button>

                        <div x-show="profileOpen" x-cloak
                             x-transition:enter="transition ease-out duration-200"
                             x-transition:enter-start="opacity-0 translate-y-2 scale-95"
                             x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                             x-transition:leave="transition ease-in duration-150"
                             x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                             x-transition:leave-end="opacity-0 translate-y-2 scale-95"
                             class="absolute right-0 mt-3 w-64 bg-white rounded-2xl shadow-2xl border border-slate-100 divide-y divide-slate-100/80 z-50 origin-top-right">

                            <div class="px-5 py-4 flex items-center gap-3">
                                @if (!string.IsNullOrEmpty(avatarUrl))
                                {
                                    <img src="@avatarUrl" class="w-11 h-11 rounded-full object-cover ring-2 ring-slate-100 shrink-0" />
                                }
                                else
                                {
                                    <div class="w-11 h-11 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold shrink-0 ring-2 ring-white">@initial</div>
                                }
                                <div class="min-w-0">
                                    <p class="text-sm font-bold text-slate-900 truncate">@fullName</p>
                                    <p class="text-xs font-medium text-slate-500 truncate">@email</p>
                                </div>
                            </div>

                            <div class="p-2">
                                @if (User.IsInRole("Student"))
                                {
                                    <a asp-page="/Student/MyCourses" class="flex items-center gap-3 px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary-700 hover:bg-slate-50 rounded-xl transition-colors">
                                        <div class="w-7 h-7 rounded-lg bg-white shadow-sm border border-slate-100 flex items-center justify-center text-slate-400">
                                            <i class="fas fa-play-circle text-[10px]"></i>
                                        </div>
                                        My Learning
                                    </a>
                                }
                                <a asp-page="/Account/Profile" class="flex items-center gap-3 px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary-700 hover:bg-slate-50 rounded-xl transition-colors">
                                    <div class="w-7 h-7 rounded-lg bg-white shadow-sm border border-slate-100 flex items-center justify-center text-slate-400">
                                        <i class="fas fa-user text-[10px]"></i>
                                    </div>
                                    Account Settings
                                </a>
                            </div>

                            @if (User.IsInRole("Instructor") || User.IsInRole("Admin"))
                            {
                                <div class="p-2">
                                    <p class="px-3 pt-1 pb-2 text-[10px] font-bold tracking-wider text-slate-400 uppercase">Management</p>
                                    @if (User.IsInRole("Instructor"))
                                    {
                                        <a asp-page="/Teacher/Dashboard" class="flex items-center gap-3 px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary-700 hover:bg-slate-50 rounded-xl transition-colors">
                                            <i class="fas fa-chart-line w-5 text-center text-slate-400"></i> Dashboard
                                        </a>
                                        <a asp-page="/Teacher/Courses/Create" class="flex items-center gap-3 px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary-700 hover:bg-slate-50 rounded-xl transition-colors">
                                            <i class="fas fa-plus-circle w-5 text-center text-slate-400"></i> Create Course
                                        </a>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-page="/Admin/Overview" class="flex items-center gap-3 px-3 py-2 text-sm font-semibold text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-colors">
                                            <i class="fas fa-shield-alt w-5 text-center text-slate-400"></i> Admin Panel
                                        </a>
                                    }
                                </div>
                            }

                            <div class="p-2">
                                <form method="post" action="/Account/Logout">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="w-full flex items-center gap-3 px-3 py-2 text-sm font-semibold text-rose-600 hover:bg-rose-50 rounded-xl transition-colors">
                                        <div class="w-7 h-7 rounded-lg bg-white shadow-sm border border-rose-100 flex items-center justify-center text-rose-400">
                                            <i class="fas fa-sign-out-alt text-[10px]"></i>
                                        </div>
                                        Sign out
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <a asp-page="/Account/Login" class="hidden sm:inline-flex px-4 py-2 text-sm font-bold text-slate-600 hover:text-slate-900 transition-colors">
                        Log in
                    </a>
                    <a asp-page="/Account/Register" class="inline-flex items-center justify-center px-4 py-2 text-sm font-bold text-white bg-slate-900 rounded-xl hover:bg-primary-600 hover:shadow-lg hover:shadow-primary-500/25 transition-all">
                        Sign up
                    </a>
                }

                <button x-on:click="mobileOpen = !mobileOpen" class="md:hidden p-2 text-slate-500 hover:text-slate-900 hover:bg-slate-100 rounded-xl transition-colors focus:outline-none">
                    <i class="fas" :class="mobileOpen ? 'fa-times' : 'fa-bars'"></i>
                </button>
            </div>
        </div>
    </div>

    <div x-show="mobileOpen" x-cloak
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-4"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 -translate-y-4"
         class="md:hidden absolute top-full left-0 w-full bg-white border-b border-slate-200 shadow-xl pb-4 pt-2 px-4">

        <div class="flex flex-col gap-1">
            <a asp-page="/Index" class="px-4 py-3 text-sm font-bold text-slate-700 rounded-xl hover:bg-slate-50 transition-colors">Home</a>
            <a asp-page="/Courses/Index" class="px-4 py-3 text-sm font-bold text-slate-700 rounded-xl hover:bg-slate-50 transition-colors">Explore Courses</a>

            @if (User.IsInRole("Student"))
            {
                <a asp-page="/Student/MyCourses" class="px-4 py-3 text-sm font-bold text-slate-700 rounded-xl hover:bg-slate-50 transition-colors">My Learning</a>
            }
            @if (User.IsInRole("Instructor"))
            {
                <a asp-page="/Teacher/Courses/Create" class="px-4 py-3 text-sm font-bold text-slate-700 rounded-xl hover:bg-slate-50 transition-colors">Create Course</a>
                <a asp-page="/Teacher/Dashboard" class="px-4 py-3 text-sm font-bold text-slate-700 rounded-xl hover:bg-slate-50 transition-colors">Teacher Dashboard</a>
            }
        </div>

        @if (User.Identity?.IsAuthenticated != true)
        {
            <div class="mt-4 grid grid-cols-2 gap-3 pt-4 border-t border-slate-100">
                <a asp-page="/Account/Login" class="text-center px-4 py-2.5 text-sm font-bold text-slate-700 bg-slate-50 border border-slate-200 rounded-xl hover:bg-slate-100">Log in</a>
                <a asp-page="/Account/Register" class="text-center px-4 py-2.5 text-sm font-bold text-white bg-slate-900 rounded-xl hover:bg-primary-600 shadow-md shadow-primary-500/20">Sign up</a>
            </div>
        }
    </div>
</nav>