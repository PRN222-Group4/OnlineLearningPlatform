@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] - Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root{ --sidebar-bg:#0b1220; --accent:#2563eb; --muted:#9aa6bf }
        body{ margin:0; font-family:Inter, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial }
        .admin-wrapper{ display:flex; min-height:100vh; }

        /* SIDEBAR */
        .sidebar{ width:260px; background:linear-gradient(180deg,var(--sidebar-bg),#051224); color:#e6eef8; padding:20px 12px; display:flex; flex-direction:column; position:fixed; left:0; top:0; height:100vh; z-index:1050 }
        .brand{ font-weight:700; font-size:18px; color:#fff; padding:8px 16px; margin-bottom:8px }
        .user-box{ text-align:center; padding:12px 8px; border-radius:10px; margin-bottom:10px }
        .user-box img{ width:64px; height:64px; border-radius:50%; object-fit:cover; border:2px solid rgba(255,255,255,0.06) }
        .user-name{ font-weight:600; color:#fff }
        .user-role{ color:var(--muted); font-size:13px }

        .nav-links{ display:flex; flex-direction:column; gap:4px; margin-top:6px }
        .nav-links a{ color:rgba(255,255,255,0.85); padding:10px 14px; display:flex; gap:12px; align-items:center; border-radius:8px; text-decoration:none }
        .nav-links a:hover{ background:rgba(255,255,255,0.03); color:#fff }
        .nav-links a.active{ background:var(--accent); box-shadow:0 6px 18px rgba(37,99,235,0.12) }

        .sidebar-bottom{ margin-top:auto; padding:12px }
        .btn-ghost{ background:transparent; border:1px solid rgba(255,255,255,0.06); color:#fff }

        /* MAIN */
        .main{ flex:1; margin-left:260px; display:flex; flex-direction:column; background:#f6f8fb }
        .topbar{ height:64px; display:flex; align-items:center; justify-content:space-between; padding:0 20px; background:#fff; border-bottom:1px solid #eef2f6 }
        .topbar .actions{ display:flex; align-items:center; gap:10px }
        .content{ padding:24px }
        /* Page container should fill the available width inside .main (no extra calc) */
        .page-container{ max-width:none; margin:0; width:100%; }

        /* responsive */
        @@media (max-width: 992px){
            .sidebar{ position:fixed; left:-280px; top:0; height:100vh; z-index:1100; transition:left .22s ease }
            .sidebar.open{ left:0 }
            .main{ margin-left:0 }
            .topbar .btn-toggle{ display:inline-flex }
        }
        .topbar .btn-toggle{ display:none }
    </style>
</head>
<body>
    <div class="admin-wrapper">

        <aside class="sidebar" id="adminSidebar">
            <div class="brand">Edu Platform — Admin</div>

            @if (User.Identity?.IsAuthenticated ?? false)
            {
                var avatar = User.FindFirst("Avatar")?.Value ?? "/images/default-avatar.png";
                var name = User.Identity?.Name ?? "Admin";
                var role = User.FindFirst(ClaimTypes.Role)?.Value;
                <div class="user-box">
                    <img src="@avatar" alt="avatar" />
                    <div class="mt-2 user-name">@name</div>
                    <div class="user-role">@role</div>
                </div>
            }

            <nav class="nav-links">
                <a asp-page="/Admin/Index" class="@(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Admin/Index") == true ? "active" : "")"><i class="bi bi-speedometer2"></i> Overview</a>
                <a asp-page="/Admin/Courses" class="@(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Admin/Courses") == true ? "active" : "")"><i class="bi bi-book"></i> Courses</a>
                <a asp-page="/Admin/Users" class="@(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Admin/Users") == true ? "active" : "")"><i class="bi bi-people"></i> Users</a>
                <a asp-page="/Admin/Dashboard" class="@(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Admin/Dashboard") == true ? "active" : "")"><i class="bi bi-bar-chart"></i> Analytics</a>
            </nav>

            <div class="sidebar-bottom">
                <a href="/" class="d-block mb-2 text-decoration-none text-muted"><i class="bi bi-house"></i> Back to site</a>

                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <form method="post" action="/Account/Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger w-100 d-flex align-items-center justify-content-center gap-2"><i class="bi bi-box-arrow-right"></i> Logout</button>
                    </form>
                }
            </div>
        </aside>

        <div class="main">
        <!-- header removed for admin layout -->

            <div class="content">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function(){
            const btn = document.getElementById('sidebarToggle');
            const sidebar = document.getElementById('adminSidebar');
            if (btn && sidebar) btn.addEventListener('click', ()=> sidebar.classList.toggle('open'));
        })();
    </script>

    @RenderSection("Scripts", false)
</body>
</html>
