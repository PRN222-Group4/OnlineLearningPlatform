@page
@model OnlineLearningPlatform.Presentation.Pages.Teacher.Wallet.IndexModel
@{
    Layout = "~/Pages/Teacher/_TeacherLayout.cshtml";
    ViewData["Title"] = "My Wallet";
}

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 font-sans">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
            <p class="text-xs font-semibold text-primary-600 uppercase tracking-widest mb-1">Financial Center</p>
            <h1 class="font-display text-3xl font-extrabold text-slate-900">Revenue Overview</h1>
            <p class="text-slate-500 text-sm mt-1">Track your course sales and monthly settlements.</p>
        </div>
        <div class="px-5 py-3 bg-indigo-50 border border-indigo-100 rounded-xl flex items-center gap-3">
            <i class="fas fa-info-circle text-indigo-500 text-lg"></i>
            <p class="text-sm font-bold text-indigo-800">Payouts are processed automatically on the 5th of every month.</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 mb-6 font-semibold shadow-sm">
            <i class="fas fa-exclamation-circle text-red-500 shrink-0 text-lg"></i> @Model.ErrorMessage
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="bg-gradient-to-br from-emerald-600 to-teal-800 rounded-3xl p-8 shadow-xl relative overflow-hidden transform transition-all hover:-translate-y-1">
            <div class="absolute -right-4 -bottom-4 opacity-10"><i class="fas fa-vault text-9xl text-white"></i></div>
            <div class="flex items-center justify-between mb-2 relative z-10">
                <p class="text-emerald-50 text-sm font-semibold">Unpaid Earnings</p>
                <span class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center backdrop-blur-sm"><i class="fas fa-money-bill text-white text-xs"></i></span>
            </div>
            <h2 class="text-4xl sm:text-5xl font-black text-white relative z-10 tracking-tight mb-1">
                @Model.MyWallet.Balance.ToString("N0") <span class="text-2xl opacity-80">₫</span>
            </h2>
            <p class="text-emerald-100 text-xs font-bold relative z-10 uppercase tracking-wider mt-4">
                To be paid next cycle
            </p>
        </div>

        <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-sm relative overflow-hidden transform transition-all hover:-translate-y-1">
            <div class="flex items-center justify-between mb-2">
                <p class="text-slate-500 text-sm font-semibold">Next Settlement</p>
                <span class="w-8 h-8 bg-amber-50 text-amber-500 rounded-full flex items-center justify-center"><i class="fas fa-calendar-alt text-xs"></i></span>
            </div>
            <h2 class="text-3xl sm:text-4xl font-black text-slate-800 tracking-tight mb-1">
                5th
            </h2>
            <p class="text-amber-600 text-xs font-bold uppercase tracking-wider mt-4 flex items-center gap-1.5">
                <i class="fas fa-sync fa-spin"></i> Processed automatically
            </p>
        </div>

        <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-sm relative overflow-hidden transform transition-all hover:-translate-y-1">
            <div class="flex items-center justify-between mb-2">
                <p class="text-slate-500 text-sm font-semibold">Lifetime Earnings</p>
                <span class="w-8 h-8 bg-indigo-50 text-indigo-500 rounded-full flex items-center justify-center"><i class="fas fa-chart-line text-xs"></i></span>
            </div>
            <h2 class="text-3xl sm:text-4xl font-black text-slate-800 tracking-tight mb-1">
                @Model.MyWallet.TotalEarnings.ToString("N0") <span class="text-xl text-slate-400">₫</span>
            </h2>
            <p class="text-indigo-600 text-xs font-bold uppercase tracking-wider mt-4">
                Total Net Income (70%)
            </p>
        </div>
    </div>
    <!-- Filter -->
    <form method="get" class="flex flex-wrap items-center gap-2 mb-6">
        <div class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-3 py-2">
            <i class="fas fa-calendar text-slate-400 text-xs"></i>
            <input type="date" name="FromDate" value="@Model.FromDate"
                   class="text-sm text-slate-700 outline-none bg-transparent w-32" />
            <span class="text-slate-300 text-xs">→</span>
            <input type="date" name="ToDate" value="@Model.ToDate"
                   class="text-sm text-slate-700 outline-none bg-transparent w-32" />
        </div>
        <button type="submit"
                class="px-4 py-2 bg-slate-900 text-white text-sm font-bold rounded-xl hover:bg-primary-600 transition-colors flex items-center gap-2">
            <i class="fas fa-filter text-xs"></i> Apply
        </button>
        <a asp-page="/Teacher/Wallet/Index"
           class="px-4 py-2 bg-slate-100 text-slate-600 text-sm font-bold rounded-xl hover:bg-slate-200 transition-colors flex items-center gap-2">
            <i class="fas fa-undo text-xs"></i> Reset
        </a>
        @if (!string.IsNullOrEmpty(Model.FromDate) && !string.IsNullOrEmpty(Model.ToDate))
        {
            <span class="text-xs text-primary-600 font-bold bg-primary-50 px-3 py-1.5 rounded-lg border border-primary-100">
                <i class="fas fa-calendar-check mr-1"></i>
                @DateTime.Parse(Model.FromDate).ToString("dd/MM/yyyy") → @DateTime.Parse(Model.ToDate).ToString("dd/MM/yyyy")
            </span>
        }
    </form>

    <!-- Chart 1: Revenue + Gross + Enrollments -->
    <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden mb-6">
        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50 flex items-center gap-3">
            <div class="w-8 h-8 bg-emerald-100 rounded-xl flex items-center justify-center">
                <i class="fas fa-chart-line text-emerald-600 text-sm"></i>
            </div>
            <div>
                <h3 class="font-extrabold text-slate-900">Performance Over Time</h3>
                <p class="text-xs text-slate-500">Revenue (70%), Gross & Enrollments</p>
            </div>
        </div>
        <div class="p-6">
            <div id="performanceChart" style="height: 320px; width: 100%;"></div>
        </div>
    </div>

    <!-- Chart 2: Top Courses -->
    <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden mb-6">
        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50 flex items-center gap-3">
            <div class="w-8 h-8 bg-amber-100 rounded-xl flex items-center justify-center">
                <i class="fas fa-trophy text-amber-600 text-sm"></i>
            </div>
            <div>
                <h3 class="font-extrabold text-slate-900">Top Courses</h3>
                <p class="text-xs text-slate-500">By enrollments — selected period</p>
            </div>
        </div>
        <div class="p-6">
            @if (Model.TopCourses.Any())
            {
                <div id="topCoursesChart" style="height: 260px; width: 100%;"></div>
            }
            else
            {
                <div class="py-10 text-center text-slate-400 text-sm">No data for selected period</div>
            }
        </div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
            <h3 class="font-extrabold text-slate-900 text-lg tracking-tight">Transaction History</h3>
            <button class="text-sm font-bold text-primary-600 hover:text-primary-800 transition-colors">Download Statement</button>
        </div>

        @if (Model.MyWallet.Transactions != null && Model.MyWallet.Transactions.Any())
        {
            <div class="divide-y divide-slate-100">
                @foreach (var tx in Model.MyWallet.Transactions)
                {
                    var isIncome = tx.TransactionType == 0;
                    var iconBg = isIncome ? "bg-emerald-50 text-emerald-600" : "bg-rose-50 text-rose-600";
                    var iconClass = isIncome ? "fa-arrow-down" : "fa-arrow-up";
                    var amountColor = isIncome ? "text-emerald-600" : "text-rose-600";
                    var sign = isIncome ? "+" : "-";

                    <div class="px-6 py-4 flex items-center justify-between hover:bg-slate-50 transition-colors">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl @iconBg flex items-center justify-center shrink-0">
                                <i class="fas @iconClass"></i>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-slate-900">@tx.Description</p>
                                <p class="text-xs text-slate-500 mt-0.5">
                                    <i class="far fa-clock mr-1"></i> @tx.CreatedAt.ToString("MMM dd, yyyy • hh:mm tt")
                                </p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-base font-black @amountColor">@sign @Math.Abs(tx.Amount).ToString("N0") ₫</p>
                            <p class="text-xs text-slate-400 font-mono mt-0.5">Balance: @tx.BalanceAfterTransaction.ToString("N0") ₫</p>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="py-16 text-center">
                <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-receipt text-slate-300 text-2xl"></i>
                </div>
                <h3 class="text-base font-bold text-slate-700 mb-1">No transactions yet</h3>
                <p class="text-sm text-slate-500 max-w-sm mx-auto">When students purchase your courses, the revenue will appear here.</p>
            </div>
        }
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
    <script>
        const labels       = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartLabels));
        const revenueData  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueData));
        const grossData    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.GrossData));
        const enrollData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.EnrollData));

        const topTitles    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopCourses.Select(x => x.Title).ToList()));
        const topEnrolls   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopCourses.Select(x => x.Enrollments).ToList()));
        const topRevenue   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopCourses.Select(x => x.Revenue).ToList()));

        // Performance chart (dual axis)
        echarts.init(document.getElementById('performanceChart')).setOption({
            tooltip: {
                trigger: 'axis',
                backgroundColor: '#fff', borderColor: '#e2e8f0', borderWidth: 1,
                textStyle: { color: '#1e293b', fontSize: 12 },
                formatter: function(params) {
                    let res = `<div style="font-weight:bold;margin-bottom:4px">${params[0].name}</div>`;
                    params.forEach(p => {
                        const val = p.seriesName === 'Enrollments'
                            ? `${p.value} enrollments`
                            : `${Number(p.value).toLocaleString('vi-VN')} ₫`;
                        res += `<div><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:${p.color};margin-right:4px"></span>${p.seriesName}: <b>${val}</b></div>`;
                    });
                    return res;
                }
            },
            legend: { data: ['My Revenue (70%)', 'Gross Revenue', 'Enrollments'], top: 0, textStyle: { fontSize: 11, color: '#94a3b8' } },
            grid: { left: 12, right: 60, top: 36, bottom: 6, containLabel: true },
            xAxis: {
                type: 'category', data: labels,
                axisLine: { lineStyle: { color: '#e2e8f0' } },
                axisLabel: { color: '#94a3b8', fontSize: 10, rotate: 30, interval: 0 },
                splitLine: { show: false }
            },
            yAxis: [
                {
                    type: 'value', name: '₫',
                    axisLabel: { color: '#94a3b8', fontSize: 10, formatter: v => v >= 1000000 ? (v/1000000).toFixed(1)+'M' : v >= 1000 ? (v/1000).toFixed(0)+'K' : v },
                    splitLine: { lineStyle: { color: '#f1f5f9', type: 'dashed' } },
                    axisLine: { show: false }
                },
                {
                    type: 'value', name: 'Enrollments', position: 'right',
                    axisLabel: { color: '#94a3b8', fontSize: 10 },
                    splitLine: { show: false },
                    axisLine: { show: false },
                    minInterval: 1
                }
            ],
            series: [
                {
                    name: 'My Revenue (70%)', data: revenueData, type: 'line', smooth: true,
                    yAxisIndex: 0, symbol: 'circle', symbolSize: 6,
                    lineStyle: { color: '#10b981', width: 3 },
                    itemStyle: { color: '#10b981', borderColor: '#fff', borderWidth: 2 },
                    areaStyle: { color: { type: 'linear', x: 0, y: 0, x2: 0, y2: 1, colorStops: [{ offset: 0, color: '#10b98133' }, { offset: 1, color: '#10b98100' }] } }
                },
                {
                    name: 'Gross Revenue', data: grossData, type: 'line', smooth: true,
                    yAxisIndex: 0, symbol: 'circle', symbolSize: 5,
                    lineStyle: { color: '#6366f1', width: 2, type: 'dashed' },
                    itemStyle: { color: '#6366f1', borderColor: '#fff', borderWidth: 2 }
                },
                {
                    name: 'Enrollments', data: enrollData, type: 'bar',
                    yAxisIndex: 1, barMaxWidth: 20, borderRadius: [4, 4, 0, 0],
                    itemStyle: { color: { type: 'linear', x: 0, y: 0, x2: 0, y2: 1, colorStops: [{ offset: 0, color: '#f59e0b' }, { offset: 1, color: '#fcd34d' }] } }
                }
            ]
        });

        // Top courses chart
        if (document.getElementById('topCoursesChart')) {
            echarts.init(document.getElementById('topCoursesChart')).setOption({
                tooltip: {
                    trigger: 'axis', axisPointer: { type: 'shadow' },
                    backgroundColor: '#fff', borderColor: '#e2e8f0', borderWidth: 1,
                    textStyle: { color: '#1e293b', fontSize: 12 },
                    formatter: function(params) {
                        const i = params[0].dataIndex;
                        return `<b>${params[0].name}</b><br/>
                            Enrollments: <b>${topEnrolls[i]}</b><br/>
                            Revenue: <b>${Number(topRevenue[i]).toLocaleString('vi-VN')} ₫</b>`;
                    }
                },
                grid: { left: 12, right: 80, top: 8, bottom: 8, containLabel: true },
                xAxis: { type: 'value', show: false },
                yAxis: {
                    type: 'category', data: topTitles,
                    axisLabel: { color: '#475569', fontSize: 11, width: 140, overflow: 'truncate' },
                    axisLine: { show: false }, axisTick: { show: false }
                },
                series: [{
                    data: topEnrolls, type: 'bar', barMaxWidth: 28, barCategoryGap: '40%', borderRadius: [0, 6, 6, 0],
                    itemStyle: { color: { type: 'linear', x: 0, y: 0, x2: 1, y2: 0, colorStops: [{ offset: 0, color: '#f59e0b' }, { offset: 1, color: '#fcd34d' }] } },
                    label: { show: true, position: 'right', color: '#475569', fontSize: 11,
                        formatter: p => `${p.value} enrolls` }
                }]
            });
        }

        window.addEventListener('resize', () => {
            ['performanceChart', 'topCoursesChart'].forEach(id => {
                const el = document.getElementById(id);
                if (el) echarts.getInstanceByDom(el)?.resize();
            });
        });
    </script>
}