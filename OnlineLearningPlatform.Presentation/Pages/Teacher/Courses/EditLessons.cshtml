@page
@model OnlineLearningPlatform.Presentation.Pages.Teacher.Courses.EditLessonsModel
@{
    ViewData["Title"] = "Manage Lessons";
    var currentStep = 2;
}

<div class="max-w-4xl mx-auto py-8 px-4">
    <!-- ═══════════ STEPPER ═══════════ -->
    <nav class="mb-10">
        <ol class="flex items-center w-full">
            @for (int i = 1; i <= 3; i++)
            {
                var stepNames = new[] { "", "Course Info", "Lessons", "Materials" };
                var icons = new[] { "", "fa-info-circle", "fa-list-ol", "fa-puzzle-piece" };
                var isActive = i == currentStep;
                var isCompleted = i < currentStep;
                <li class="flex items-center @(i < 3 ? "flex-1" : "")">
                    <div class="flex flex-col items-center gap-1.5">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold transition-all duration-300
                            @(isActive ? "bg-indigo-600 text-white shadow-lg shadow-indigo-200 ring-4 ring-indigo-100"
                                : isCompleted ? "bg-emerald-500 text-white"
                                : "bg-zinc-100 text-zinc-400 border border-zinc-200")">
                            @if (isCompleted) { <i class="fas fa-check text-xs"></i> }
                            else { <i class="fas @icons[i] text-xs"></i> }
                        </div>
                        <span class="text-xs font-semibold @(isActive ? "text-indigo-600" : isCompleted ? "text-emerald-600" : "text-zinc-400")">
                            @stepNames[i]
                        </span>
                    </div>
                    @if (i < 3)
                    {
                        <div class="flex-1 mx-3 h-0.5 rounded @(i < currentStep ? "bg-emerald-400" : "bg-zinc-200")"></div>
                    }
                </li>
            }
        </ol>
    </nav>

    <!-- ═══════════ NOTIFICATIONS ═══════════ -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-6 rounded-xl bg-emerald-50 border border-emerald-100 p-4 flex items-center gap-3">
            <i class="fas fa-check-circle text-emerald-500"></i>
            <span class="text-sm text-emerald-700 font-medium">@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-6 rounded-xl bg-red-50 border border-red-100 p-4 flex items-center gap-3">
            <i class="fas fa-exclamation-circle text-red-500"></i>
            <span class="text-sm text-red-700 font-medium">@TempData["Error"]</span>
        </div>
    }

    <!-- ═══════════ MAIN CARD ═══════════ -->
    <div class="bg-white rounded-2xl shadow-sm border border-zinc-100 overflow-hidden">
        <div class="border-b border-zinc-100 px-8 py-5 bg-gradient-to-r from-indigo-50/50 to-white">
            <h2 class="text-xl font-bold text-zinc-900 flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center">
                    <i class="fas fa-list-ol text-sm"></i>
                </div>
                Manage Lessons
            </h2>
            <p class="text-sm text-zinc-500 mt-1 ml-11">Add lessons to structure your course content</p>
        </div>

        <div class="p-8">
            <!-- ─── Add Lesson Form ─── -->
            <div x-data="{ showForm: false }" class="mb-8">
                @if (!Model.IsReadOnly)
                {
                <button @@click="showForm = !showForm"
                        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition">
                    <i class="fas fa-plus text-xs"></i> Add Lesson
                </button>
                }
                else
                {
                <span class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-zinc-100 text-zinc-500 text-sm font-medium">
                    <i class="fas fa-lock text-xs"></i> Read-only (not Draft)
                </span>
                }

                @if (!Model.IsReadOnly)
                {
                <div x-show="showForm" x-transition class="mt-5 p-6 bg-zinc-50 rounded-xl border border-zinc-200" x-cloak>
                    <form method="post" asp-page-handler="AddLesson" asp-route-courseId="@Model.CourseId">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div class="md:col-span-2">
                                <label class="block text-sm font-semibold text-zinc-700 mb-1.5">Lesson Title <span class="text-red-500">*</span></label>
                                <input type="text" asp-for="LessonTitle" required placeholder="e.g. Introduction to Variables"
                                       class="w-full px-4 py-2.5 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none text-sm" />
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-zinc-700 mb-1.5">Duration (min)</label>
                                <input type="number" asp-for="EstimatedMinutes" min="1" max="300"
                                       class="w-full px-4 py-2.5 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none text-sm" />
                            </div>
                        </div>
                        <div class="flex justify-end gap-3 mt-4">
                            <button type="button" @@click="showForm = false"
                                    class="px-4 py-2 rounded-xl text-sm font-medium text-zinc-600 bg-white border border-zinc-200 hover:bg-zinc-50 transition">
                                Cancel
                            </button>
                            <button type="submit"
                                    class="px-5 py-2 rounded-xl bg-emerald-600 text-white text-sm font-semibold hover:bg-emerald-700 transition">
                                <i class="fas fa-check text-xs mr-1"></i> Add
                            </button>
                        </div>
                    </form>
                </div>
                }
            </div>

            <!-- ─── Lessons List ─── -->
            @if (Model.Lessons.Any())
            {
                <div class="space-y-3">
                    @foreach (var (lesson, index) in Model.Lessons.Select((l, i) => (l, i)))
                    {
                        <div class="flex items-center justify-between p-4 rounded-xl border border-zinc-100 bg-zinc-50/50 hover:bg-zinc-50 transition group">
                            <div class="flex items-center gap-4">
                                <div class="w-8 h-8 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center text-sm font-bold">
                                    @(index + 1)
                                </div>
                                <div>
                                    <p class="font-semibold text-zinc-800 text-sm">@lesson.Title</p>
                                    <p class="text-xs text-zinc-400 mt-0.5 flex items-center gap-2">
                                        <i class="far fa-clock"></i> @lesson.EstimatedMinutes min
                                    </p>
                                </div>
                            </div>
                            @if (!Model.IsReadOnly)
                            {
                                <form method="post" asp-page-handler="DeleteLesson"
                                      asp-route-courseId="@Model.CourseId" asp-route-lessonId="@lesson.LessonId"
                                      onsubmit="return confirm('Bạn có chắc muốn xóa bài học này?')">
                                    <button type="submit"
                                            class="opacity-0 group-hover:opacity-100 transition p-2 rounded-lg text-red-400 hover:bg-red-50 hover:text-red-600">
                                        <i class="fas fa-trash-alt text-xs"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-12 text-zinc-400">
                    <i class="fas fa-inbox text-4xl mb-3 block"></i>
                    <p class="font-medium">No lessons yet</p>
                    <p class="text-sm mt-1">Click "Add Lesson" button to get started</p>
                </div>
            }
        </div>

        <!-- ─── Navigation ─── -->
        <div class="flex items-center justify-between px-8 py-5 border-t border-zinc-100 bg-zinc-50/50">
            <a asp-page="/Teacher/Courses/Create" asp-route-courseId="@Model.CourseId"
               class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium text-zinc-600 bg-white border border-zinc-200 hover:bg-zinc-50 transition">
                <i class="fas fa-arrow-left text-xs"></i> Back to Info
            </a>
            <a asp-page="/Teacher/Courses/EditMaterials" asp-route-courseId="@Model.CourseId"
               class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition @(Model.Lessons.Any() ? "" : "opacity-50 pointer-events-none")">
                Continue to Materials <i class="fas fa-arrow-right text-xs"></i>
            </a>
        </div>
    </div>
</div>
