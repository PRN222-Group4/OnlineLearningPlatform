@page "{courseId:guid}"
@model OnlineLearningPlatform.Presentation.Pages.Teacher.Courses.EditModulesModel
@{
    ViewData["Title"] = "Curriculum Builder";
    var courseId = RouteData.Values["courseId"];
}

<div class="bg-slate-50 min-h-screen pb-20 font-sans relative"
     x-data="curriculumBuilder()">

    <div x-show="isUploading" x-cloak class="fixed inset-0 z-[200] bg-slate-900/60 backdrop-blur-sm flex items-center justify-center">
        <div class="bg-white rounded-2xl p-8 flex flex-col items-center shadow-2xl max-w-sm mx-4 text-center">
            <i class="fas fa-circle-notch fa-spin text-4xl text-indigo-600 mb-4"></i>
            <h3 class="text-lg font-bold text-slate-900 mb-1">Processing Content...</h3>
            <p class="text-sm text-slate-500">Please wait while we securely upload your materials. Do not close this window.</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div x-data="{ show: true }" x-show="show" x-init="setTimeout(() => show = false, 3000)" class="fixed top-4 right-4 z-[100] bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl shadow-xl flex items-center gap-3" x-transition>
            <i class="fas fa-check-circle text-emerald-500 text-lg"></i>
            <span class="font-bold text-sm">@TempData["Success"]</span>
            <button @@click="show = false" class="text-emerald-400 hover:text-emerald-600"><i class="fas fa-times"></i></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div x-data="{ show: true }" x-show="show" x-init="setTimeout(() => show = false, 5000)" class="fixed top-4 right-4 z-[100] bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-xl shadow-xl flex items-center gap-3" x-transition>
            <i class="fas fa-exclamation-circle text-rose-500 text-lg"></i>
            <span class="font-bold text-sm">@TempData["Error"]</span>
            <button @@click="show = false" class="text-rose-400 hover:text-rose-600"><i class="fas fa-times"></i></button>
        </div>
    }

    <div class="max-w-5xl mx-auto py-8 px-4">
        <div class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-display font-extrabold text-slate-900 tracking-tight">Curriculum Builder</h1>
                <p class="text-sm text-slate-500 mt-1">Organize your course into Modules, Lessons, and Materials.</p>
            </div>
            <div class="flex gap-3">
                <a asp-page="/Teacher/Dashboard" class="px-5 py-2.5 bg-white border border-slate-200 text-slate-600 text-sm font-bold rounded-xl hover:bg-slate-50 transition shadow-sm">
                    <i class="fas fa-arrow-left mr-2"></i> Dashboard
                </a>
                <a asp-page="/Teacher/Courses/Create" asp-route-courseId="@courseId" class="px-5 py-2.5 bg-indigo-50 text-indigo-700 text-sm font-bold rounded-xl hover:bg-indigo-100 transition shadow-sm">
                    <i class="fas fa-cog mr-2"></i> Settings
                </a>
            </div>
        </div>

        <div class="space-y-6 mb-8">
            @if (Model.Modules != null && Model.Modules.Any())
            {
                @foreach (var mod in Model.Modules.OrderBy(m => m.Index))
                {
                    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm" x-data="{ modExpanded: true }">
                        <div class="px-6 py-4 bg-slate-50/80 border-b border-slate-100 flex items-center justify-between cursor-pointer hover:bg-slate-100 transition rounded-t-2xl"
                             @@click="modExpanded = !modExpanded">
                            <div class="flex items-center gap-4">
                                <div class="w-8 h-8 rounded-lg bg-slate-900 text-white flex items-center justify-center text-xs font-bold shadow-inner">@mod.Index</div>
                                <div>
                                    <h3 class="font-bold text-slate-900 text-base">@mod.Name</h3>
                                    @if (!string.IsNullOrEmpty(mod.Description))
                                    {
                                        <p class="text-xs text-slate-500 mt-0.5 line-clamp-1">@mod.Description</p>
                                    }
                                </div>
                            </div>
                            <div class="flex items-center gap-4">
                                <i class="fas fa-chevron-down text-slate-400 transition-transform duration-300" :class="modExpanded ? 'rotate-180' : ''"></i>
                            </div>
                        </div>

                        <div x-show="modExpanded" x-collapse class="p-6 space-y-4">
                            @if (mod.Lessons != null && mod.Lessons.Any())
                            {
                                <div class="space-y-3">
                                    @foreach (var lesson in mod.Lessons.OrderBy(l => l.OrderIndex))
                                    {
                                        <div class="bg-white border border-slate-200 rounded-xl p-4 flex flex-col gap-3 group hover:border-indigo-300 transition shadow-sm" x-data="{ lesExpanded: false }">
                                            <div class="flex items-center justify-between cursor-pointer" @@click ="lesExpanded = !lesExpanded">
                                                <div class="flex items-center gap-3">
                                                    <i class="fas fa-book-reader text-slate-400 group-hover:text-indigo-500 transition-colors"></i>
                                                    <span class="font-bold text-slate-800 text-sm">@lesson.Title</span>
                                                </div>

                                                <div class="flex items-center gap-2" x-data="{ showMatMenu: false }">
                                                    <div class="relative" @@click.away ="showMatMenu = false">
                                                        <button type="button" @@click.stop ="showMatMenu = !showMatMenu" class="text-xs font-bold text-indigo-600 bg-indigo-50 px-3 py-1.5 rounded-lg hover:bg-indigo-100 transition flex items-center gap-1.5 shadow-sm opacity-0 group-hover:opacity-100 focus:opacity-100">
                                                            <i class="fas fa-plus"></i> Add Material <i class="fas fa-chevron-down text-[9px] transition-transform" :class="showMatMenu ? 'rotate-180' : ''"></i>
                                                        </button>

                                                        <div x-show="showMatMenu" x-cloak
                                                             x-transition:enter="transition ease-out duration-200"
                                                             x-transition:enter-start="opacity-0 translate-y-1 scale-95"
                                                             x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                                                             x-transition:leave="transition ease-in duration-150"
                                                             x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                                                             x-transition:leave-end="opacity-0 translate-y-1 scale-95"
                                                             class="absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-xl border border-slate-100 py-1.5 z-20 overflow-hidden">

                                                            <div class="px-3 py-1.5 text-[10px] font-bold text-slate-400 uppercase tracking-widest">Learning</div>
                                                            <button type="button" @@click ="openMaterialSheet('@lesson.LessonId', 'video'); showMatMenu = false" class="w-full text-left px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-indigo-600 transition flex items-center gap-3">
                                                                <div class="w-6 text-center text-rose-500"><i class="fas fa-video"></i></div> Video Lesson
                                                            </button>
                                                            <button type="button" @@click ="openMaterialSheet('@lesson.LessonId', 'reading'); showMatMenu = false" class="w-full text-left px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-blue-600 transition flex items-center gap-3">
                                                                <div class="w-6 text-center text-blue-500"><i class="fas fa-book-open"></i></div> Reading Article
                                                            </button>

                                                            <div class="h-px bg-slate-100 my-1.5"></div>
                                                            <div class="px-3 py-1.5 text-[10px] font-bold text-slate-400 uppercase tracking-widest">Practice & Graded</div>

                                                            <button type="button" @@click ="openMaterialSheet('@lesson.LessonId', 'quiz'); showMatMenu = false" class="w-full text-left px-4 py-2 text-sm text-slate-700 hover:bg-amber-50 hover:text-amber-700 transition flex items-center gap-3">
                                                                <div class="w-6 text-center text-amber-500"><i class="fas fa-tasks"></i></div> Quiz (Auto-graded)
                                                            </button>
                                                            <button type="button" @@click ="openMaterialSheet('@lesson.LessonId', 'writing'); showMatMenu = false" class="w-full text-left px-4 py-2 text-sm text-slate-700 hover:bg-purple-50 hover:text-purple-700 transition flex items-center gap-3">
                                                                <div class="w-6 text-center text-purple-500"><i class="fas fa-pen-fancy"></i></div> IELTS Writing Task
                                                            </button>
                                                            <button type="button" @@click ="openMaterialSheet('@lesson.LessonId', 'speaking'); showMatMenu = false" class="w-full text-left px-4 py-2 text-sm text-slate-700 hover:bg-emerald-50 hover:text-emerald-700 transition flex items-center gap-3">
                                                                <div class="w-6 text-center text-emerald-500"><i class="fas fa-microphone"></i></div> IELTS Speaking Task
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div x-show="lesExpanded" x-collapse class="pl-8 pt-3 pb-2 space-y-2 border-t border-slate-50 mt-3">
                                                @if (lesson.LessonItems != null && lesson.LessonItems.Any())
                                                {
                                                    @foreach (var item in lesson.LessonItems.OrderBy(i => i.OrderIndex))
                                                    {
                                                        string iconClass = item.Type switch
                                                        {
                                                            0 => "fa-video text-rose-500",
                                                            1 => "fa-book-open text-blue-500",
                                                            2 => "fa-tasks text-amber-500",
                                                            3 => "fa-pen-fancy text-purple-500",
                                                            4 => "fa-microphone text-emerald-500",
                                                            _ => "fa-file text-slate-500"
                                                        };
                                                        string bgClass = item.Type switch
                                                        {
                                                            0 => "bg-rose-50",
                                                            1 => "bg-blue-50",
                                                            2 => "bg-amber-50",
                                                            3 => "bg-purple-50",
                                                            4 => "bg-emerald-50",
                                                            _ => "bg-slate-50"
                                                        };
                                                        string typeName = item.Type switch
                                                        {
                                                            0 => "Video Lesson",
                                                            1 => "Reading Article",
                                                            2 => "Quiz Assessment",
                                                            3 => "IELTS Writing",
                                                            4 => "IELTS Speaking",
                                                            _ => "Material"
                                                        };

                                                        <div class="flex items-center justify-between p-3 bg-white border border-slate-100 rounded-xl hover:shadow-md transition group">
                                                            <div class="flex items-center gap-3">
                                                                <div class="w-8 h-8 rounded-lg flex items-center justify-center @bgClass">
                                                                    <i class="fas @iconClass text-xs"></i>
                                                                </div>
                                                                <div>
                                                                    <span class="text-sm font-bold text-slate-700">@typeName</span>
                                                                    <span class="text-[10px] font-medium text-slate-400 block">Index: @item.OrderIndex</span>
                                                                </div>
                                                            </div>
                                                            <div class="opacity-0 group-hover:opacity-100 transition-opacity">
                                                                <button type="button" class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-300 hover:bg-rose-50 hover:text-rose-500 transition">
                                                                    <i class="fas fa-trash-alt text-xs"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <p class="text-[10px] text-slate-400 uppercase font-bold tracking-widest mt-1">Empty Lesson</p>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            <div x-data="{ isAddingLesson: false }" class="mt-4 border-t border-slate-100 pt-4">
                                <button x-show="!isAddingLesson" @@click="isAddingLesson = true" class="text-xs font-bold text-indigo-600 flex items-center gap-2 hover:bg-indigo-50 px-3 py-2 rounded-lg transition">
                                    <i class="fas fa-plus-circle"></i> Add New Lesson
                                </button>

                                <form x-show="isAddingLesson" x-collapse class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex gap-3"
                                      method="post" asp-page-handler="CreateLesson" asp-route-courseId="@courseId" x-on:submit="isUploading = true">
                                    <input type="hidden" name="LessonInput.ModuleId" value="@mod.ModuleId" />
                                    <input type="text" name="LessonInput.Title" required placeholder="Lesson title (e.g. Setting up Environment)" class="flex-1 px-4 py-2 text-sm rounded-lg border border-slate-200 outline-none focus:ring-2 focus:ring-indigo-100 focus:border-indigo-400" />
                                    <button type="button" @@click="isAddingLesson = false" class="px-4 py-2 text-sm font-bold text-slate-500 hover:bg-slate-200 rounded-lg transition">Cancel</button>
                                    <button type="submit" class="px-4 py-2 text-sm font-bold text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg shadow-sm transition">Save</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-20 bg-white border-2 border-dashed border-slate-200 rounded-3xl">
                    <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 text-slate-300">
                        <i class="fas fa-cubes text-2xl"></i>
                    </div>
                    <h3 class="text-slate-900 font-bold text-lg">No Modules Found</h3>
                    <p class="text-slate-500 text-sm mt-1">Start structuring your course by creating the first module below.</p>
                </div>
            }
        </div>

        <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6" x-data="{ isAddingModule: false }">
            <button x-show="!isAddingModule" @@click="isAddingModule = true" class="w-full py-4 border-2 border-dashed border-indigo-200 rounded-2xl text-indigo-600 font-bold hover:bg-indigo-50 transition flex items-center justify-center gap-2">
                <i class="fas fa-plus text-lg"></i> Create New Module (Section)
            </button>

            <form x-show="isAddingModule" x-collapse class="space-y-4" method="post" asp-page-handler="CreateModule" asp-route-courseId="@courseId" x-on:submit="isUploading = true">
                <div class="flex items-center gap-2 text-slate-900 font-bold mb-2">
                    <i class="fas fa-folder-plus text-indigo-500 text-lg"></i> New Module Details
                </div>
                <input type="text" name="Input.Name" required placeholder="Section Title (e.g. Getting Started)" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 outline-none transition font-semibold" />
                <textarea name="Input.Description" placeholder="Briefly describe what students will learn..." class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 outline-none transition resize-none"></textarea>
                <div class="flex justify-end gap-3 pt-2">
                    <button type="button" @@click="isAddingModule = false" class="px-5 py-2.5 text-sm font-bold text-slate-500 hover:bg-slate-100 rounded-xl transition">Cancel</button>
                    <button type="submit" class="px-6 py-2.5 text-sm font-bold text-white bg-slate-900 hover:bg-indigo-600 rounded-xl shadow-lg transition-all">Save Module</button>
                </div>
            </form>
        </div>

        <div class="mt-12 pt-8 border-t border-slate-200 flex items-center justify-between">
            <p class="text-sm text-slate-500 max-w-md font-medium">Once you've added all your modules and materials, review your course before submitting to Admin.</p>
            <a asp-page="/Teacher/Courses/Preview" asp-route-courseId="@courseId"
               class="px-8 py-4 bg-indigo-600 text-white font-extrabold rounded-2xl hover:bg-indigo-700 shadow-xl shadow-indigo-200 transition-all flex items-center gap-3 group">
                <span>Review & Submit Course</span>
                <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </a>
        </div>
    </div>

    <div x-show="sheetOpen" x-cloak class="fixed inset-0 z-[100] overflow-hidden">
        <div class="absolute inset-0 overflow-hidden">
            <div x-show="sheetOpen" x-transition.opacity.duration.400ms class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" @@click="sheetOpen = false"></div>

            <div class="pointer-events-none fixed inset-y-0 right-0 flex max-w-full pl-10">
                <div x-show="sheetOpen" 
                     x-transition:enter="transform transition ease-in-out duration-400" 
                     x-transition:enter-start="translate-x-full" 
                     x-transition:enter-end="translate-x-0" 
                     x-transition:leave="transform transition ease-in-out duration-400" 
                     x-transition:leave-start="translate-x-0" 
                     x-transition:leave-end="translate-x-full" 
                     class="pointer-events-auto w-screen max-w-2xl"> <div class="flex h-full flex-col bg-white shadow-2xl overflow-y-auto">
                        <div class="px-8 py-6 bg-slate-50 border-b border-slate-100 flex items-center justify-between sticky top-0 z-10 shadow-sm">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white shadow-inner"
                                     :class="{
                                         'bg-rose-500': selectedType === 'video',
                                         'bg-blue-500': selectedType === 'reading',
                                         'bg-amber-500': selectedType === 'quiz',
                                         'bg-purple-500': selectedType === 'writing',
                                         'bg-emerald-500': selectedType === 'speaking'
                                     }">
                                    <i class="fas text-lg" :class="{
                                        'fa-video': selectedType === 'video',
                                        'fa-book-open': selectedType === 'reading',
                                        'fa-tasks': selectedType === 'quiz',
                                        'fa-pen-fancy': selectedType === 'writing',
                                        'fa-microphone': selectedType === 'speaking'
                                    }"></i>
                                </div>
                                <div>
                                    <h2 class="text-xl font-bold text-slate-900" x-text="getSheetTitle()"></h2>
                                    <p class="text-xs text-slate-500 mt-0.5" x-text="getSheetSubtitle()"></p>
                                </div>
                            </div>
                            <button type="button" @@click="sheetOpen = false" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-slate-200 text-slate-400 transition bg-white border border-slate-200 shadow-sm">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>

                        <div class="px-8 py-8 bg-white flex-1">

                            <form x-show="selectedType === 'video'" method="post" asp-page-handler="CreateVideo" asp-route-courseId="@courseId" enctype="multipart/form-data" class="space-y-6" x-on:submit="isUploading = true">
                                <input type="hidden" name="VideoInput.LessonId" :value="selectedLessonId" />
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-2">Video Title</label>
                                    <input type="text" name="VideoInput.Title" required placeholder="e.g. Introduction to UI/UX" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 outline-none transition font-medium" />
                                </div>
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-2">MP4 Video File</label>
                                    <div class="mt-1 flex justify-center px-6 pt-8 pb-8 border-2 border-slate-200 border-dashed rounded-2xl hover:bg-indigo-50/30 hover:border-indigo-300 transition-colors">
                                        <div class="space-y-2 text-center">
                                            <i class="fas fa-cloud-upload-alt text-indigo-300 text-4xl mb-2"></i>
                                            <div class="flex text-sm text-slate-600 justify-center">
                                                <label class="relative cursor-pointer bg-white px-4 py-2 border border-slate-200 rounded-lg font-bold text-indigo-600 hover:text-indigo-700 hover:bg-slate-50 focus-within:outline-none transition shadow-sm">
                                                    <span>Select MP4 file</span>
                                                    <input type="file" name="VideoInput.VideoFile" accept="video/mp4" required class="sr-only">
                                                </label>
                                            </div>
                                            <p class="text-xs text-slate-400 font-medium pt-2">Maximum file size: 500MB</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="pt-4 border-t border-slate-100">
                                    <button type="submit" class="w-full py-4 bg-indigo-600 text-white rounded-xl font-bold hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition-all flex justify-center items-center gap-2">
                                        <i class="fas fa-upload"></i> Upload & Save Video
                                    </button>
                                </div>
                            </form>

                            <form x-show="selectedType === 'reading'" method="post" asp-page-handler="CreateReading" asp-route-courseId="@courseId" class="space-y-6" x-on:submit="isUploading = true">
                                <input type="hidden" name="ReadingInput.LessonId" :value="selectedLessonId" />
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-2">Article Title</label>
                                    <input type="text" name="ReadingInput.Title" required placeholder="e.g. Principles of Design" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 outline-none transition font-medium" />
                                </div>
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-2">Article Content</label>
                                    <textarea name="ReadingInput.Content" rows="12" required placeholder="Write or paste your article content here..." class="w-full px-4 py-4 border border-slate-200 rounded-xl focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 outline-none transition resize-y"></textarea>
                                </div>
                                <div class="pt-4 border-t border-slate-100">
                                    <button type="submit" class="w-full py-4 bg-blue-600 text-white rounded-xl font-bold hover:bg-blue-700 shadow-lg shadow-blue-200 transition-all">Save Article</button>
                                </div>
                            </form>

                            <form x-show="selectedType === 'writing'" method="post" asp-page-handler="CreateWriting" asp-route-courseId="@courseId" class="space-y-6" x-on:submit="isUploading = true">
                                <input type="hidden" name="WritingInput.LessonId" :value="selectedLessonId" />
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-2">Writing Task Title</label>
                                    <input type="text" name="WritingInput.Title" placeholder="e.g. Writing Task 2 - Technology" required class="w-full px-4 py-3 border border-slate-200 rounded-xl outline-none focus:ring-4 focus:ring-purple-50 focus:border-purple-400 font-medium transition" />
                                </div>
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-2">Task Prompt (The Question)</label>
                                    <textarea name="WritingInput.Prompt" rows="8" placeholder="Describe the topic for students to write about..." required class="w-full px-4 py-4 border border-slate-200 rounded-xl outline-none focus:ring-4 focus:ring-purple-50 focus:border-purple-400 resize-none transition leading-relaxed"></textarea>
                                </div>
                                <div class="p-4 bg-slate-50 rounded-xl flex items-start gap-3 border border-slate-200">
                                    <i class="fas fa-info-circle text-slate-400 mt-1"></i>
                                    <p class="text-xs text-slate-600 leading-relaxed font-medium">Students will submit their text based on this prompt. The system will automatically evaluate it based on official IELTS criteria and provide detailed feedback.</p>
                                </div>
                                <div class="pt-4 border-t border-slate-100">
                                    <button type="submit" class="w-full py-4 bg-purple-600 text-white rounded-xl font-bold hover:bg-purple-700 shadow-lg shadow-purple-200 transition-all">Save Writing Task</button>
                                </div>
                            </form>

                            <form x-show="selectedType === 'speaking'" method="post" asp-page-handler="CreateSpeaking" asp-route-courseId="@courseId" class="space-y-6" x-on:submit="isUploading = true">
                                <input type="hidden" name="SpeakingInput.LessonId" :value="selectedLessonId" />
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-2">Speaking Task Title</label>
                                    <input type="text" name="SpeakingInput.Title" placeholder="e.g. Speaking Part 1 - Hometown" required class="w-full px-4 py-3 border border-slate-200 rounded-xl outline-none focus:ring-4 focus:ring-emerald-50 focus:border-emerald-400 font-medium transition" />
                                </div>
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-2">Task Prompt (What to say)</label>
                                    <textarea name="SpeakingInput.Prompt" rows="6" placeholder="Describe the topic students need to talk about..." required class="w-full px-4 py-4 border border-slate-200 rounded-xl outline-none focus:ring-4 focus:ring-emerald-50 focus:border-emerald-400 resize-none transition leading-relaxed"></textarea>
                                </div>
                                <div class="p-4 bg-slate-50 rounded-xl flex items-start gap-3 border border-slate-200">
                                    <i class="fas fa-info-circle text-slate-400 mt-1"></i>
                                    <p class="text-xs text-slate-600 leading-relaxed font-medium">Students will record their audio directly on the platform. The system will analyze pronunciation, fluency, and vocabulary automatically.</p>
                                </div>
                                <div class="pt-4 border-t border-slate-100">
                                    <button type="submit" class="w-full py-4 bg-emerald-600 text-white rounded-xl font-bold hover:bg-emerald-700 shadow-lg shadow-emerald-200 transition-all">Save Speaking Task</button>
                                </div>
                            </form>

                            <form x-show="selectedType === 'quiz'" method="post" asp-page-handler="CreateQuiz" asp-route-courseId="@courseId" class="space-y-8" x-on:submit="isUploading = true">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="QuizInput.LessonId" :value="selectedLessonId" />
                                <div>
                                    <label class="block text-sm font-bold text-slate-700 mb-2">Quiz Title</label>
                                    <input type="text" name="QuizInput.Title" required placeholder="e.g. Module 1 Assessment" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-4 focus:ring-amber-50 focus:border-amber-400 outline-none font-medium transition" />
                                </div>

                                <div x-data="quizFormAI()" class="space-y-6">

                                    <div class="bg-gradient-to-r from-indigo-50 to-purple-50 p-5 rounded-xl border-2 border-dashed border-indigo-200 relative overflow-hidden mb-2">
                                        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 relative z-10">
                                            <div>
                                                <h5 class="font-bold text-indigo-900 flex items-center gap-2 mb-1">
                                                    <i class="fas fa-magic text-indigo-500"></i> Auto-Generate with AI
                                                </h5>
                                                <p class="text-xs text-indigo-700/70">Upload PDF to instantly generate Q&A flashcards.</p>
                                            </div>
                                            <div class="flex items-center gap-2 w-full sm:w-auto">
                                                <input type="file" accept="application/pdf" id="pdfInputAuto" class="text-xs w-full sm:w-48 file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-indigo-100 file:text-indigo-700 hover:file:bg-indigo-200 cursor-pointer" :disabled="isGenerating" />
                                                <button type="button" @@click="generateAI()" :disabled="isGenerating"
                                                        class="shrink-0 px-4 py-2 bg-indigo-600 text-white text-xs font-bold rounded-lg hover:bg-indigo-700 disabled:opacity-50 transition flex items-center gap-2 shadow-md">
                                                    <i class="fas" :class="isGenerating ? 'fa-spinner fa-spin' : 'fa-bolt'"></i>
                                                    <span x-text="isGenerating ? 'Analyzing...' : 'Generate'"></span>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="flex items-center justify-between border-b border-slate-200 pb-2">
                                        <h3 class="font-bold text-slate-800 text-lg">Questions</h3>
                                        <span class="text-xs font-bold bg-amber-100 text-amber-700 px-2.5 py-1 rounded" x-text="questions.length + ' Qs'"></span>
                                    </div>

                                    <template x-for="(q, qIndex) in questions" :key="q.id">
                                        <div class="bg-slate-50 border border-slate-200 rounded-xl p-5 relative group">

                                            <button type="button" @@click="removeQuestion(qIndex)" x-show="questions.length > 1" class="absolute top-4 right-4 text-slate-300 hover:text-rose-500 transition opacity-0 group-hover:opacity-100">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>

                                            <div class="flex gap-4 mb-4">
                                                <div class="w-8 h-8 rounded-full bg-slate-200 text-slate-600 flex items-center justify-center font-bold text-sm shrink-0" x-text="qIndex + 1"></div>
                                                <div class="flex-1 space-y-3">
                                                    <textarea :name="`QuizInput.Questions[${qIndex}].Content`" x-model="q.content" required rows="2" placeholder="Enter your question here..." class="w-full px-4 py-2 border border-slate-200 rounded-lg outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-50 resize-y text-sm font-medium"></textarea>
                                                    <div class="flex items-center gap-3">
                                                        <span class="text-xs font-bold text-slate-500">Points:</span>
                                                        <input type="number" :name="`QuizInput.Questions[${qIndex}].Points`" x-model="q.points" min="1" class="w-20 px-3 py-1 border border-slate-200 rounded-md text-sm outline-none focus:border-amber-400" />
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="pl-12 space-y-2">
                                                <template x-for="(opt, oIndex) in q.options" :key="opt.id">
                                                    <div class="flex items-center gap-3">
                                                        <input type="radio" :name="`correct_${q.id}`" :checked="opt.isCorrect" @@change="setCorrectOption(qIndex, oIndex)" class="w-4 h-4 text-amber-500 focus:ring-amber-400 cursor-pointer">
                                                        <input type="hidden" :name="`QuizInput.Questions[${qIndex}].Options[${oIndex}].IsCorrect`" :value="opt.isCorrect ? 'true' : 'false'" />

                                                        <input type="text" :name="`QuizInput.Questions[${qIndex}].Options[${oIndex}].Text`" x-model="opt.text" :required="oIndex === 0" :placeholder="oIndex === 0 ? 'Correct Answer (Auto-filled)' : 'Distractor Option...'" class="flex-1 px-3 py-1.5 border border-slate-200 rounded-md text-sm outline-none focus:border-amber-400 focus:ring-1 focus:ring-amber-100 transition" :class="opt.isCorrect ? 'border-amber-300 bg-amber-50/30 font-medium' : ''" />

                                                        <button type="button" @@click="removeOption(qIndex, oIndex)" x-show="q.options.length > 2" class="text-slate-300 hover:text-rose-500 transition px-2">
                                                            <i class="fas fa-times text-xs"></i>
                                                        </button>
                                                    </div>
                                                </template>

                                                <button type="button" @@click="addOption(qIndex)" class="text-xs font-bold text-amber-600 hover:text-amber-700 mt-2 flex items-center gap-1 pl-1">
                                                    <i class="fas fa-plus text-[10px]"></i> Add Option
                                                </button>
                                            </div>
                                        </div>
                                    </template>

                                    <button type="button" @@click="addQuestion()" class="w-full py-3 border-2 border-dashed border-amber-200 rounded-xl text-amber-600 font-bold hover:bg-amber-50 transition flex items-center justify-center gap-2">
                                        <i class="fas fa-plus"></i> Add Another Question
                                    </button>
                                </div>

                                <div class="pt-6 border-t border-slate-100 mt-8">
                                    <button type="submit" class="w-full py-4 bg-amber-500 text-white rounded-xl font-bold hover:bg-amber-600 shadow-lg shadow-amber-200 transition-all flex items-center justify-center gap-2">
                                        <i class="fas fa-save"></i> Save Auto-Graded Quiz
                                    </button>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function curriculumBuilder() {
        return {
            sheetOpen: false,
            selectedType: '',
            selectedLessonId: '',
            isUploading: false,

            openMaterialSheet(lessonId, type) {
                this.selectedLessonId = lessonId;
                this.selectedType = type;
                this.sheetOpen = true;
            },
            
            getSheetTitle() {
                const titles = {
                    'video': 'Upload Video',
                    'reading': 'Write Article',
                    'writing': 'IELTS Writing Task',
                    'speaking': 'IELTS Speaking Task',
                    'quiz': 'Create Quiz'
                };
                return titles[this.selectedType] || 'Add Content';
            },
            
            getSheetSubtitle() {
                const subs = {
                    'video': 'Add high-quality MP4 video content.',
                    'reading': 'Provide text-based learning material.',
                    'writing': 'Smart Evaluator will grade student essays.',
                    'speaking': 'Smart Evaluator will analyze student voice.',
                    'quiz': 'Build multiple-choice assessments.'
                };
                return subs[this.selectedType] || '';
            }
        }
    }

    function quizFormAI() {
        return {
            isGenerating: false,
            questions: [{ id: Date.now(), content: '', points: 10, options: [{id: Date.now()+1, text: '', isCorrect: true}, {id: Date.now()+2, text: '', isCorrect: false}] }],

            addQuestion() {
                this.questions.push({ id: Date.now(), content: '', points: 10, options: [{id: Date.now()+1, text: '', isCorrect: true}, {id: Date.now()+2, text: '', isCorrect: false}] })
            },

            removeQuestion(index) {
                if(this.questions.length > 1) this.questions.splice(index, 1)
            },

            addOption(qIndex) {
                this.questions[qIndex].options.push({id: Date.now(), text: '', isCorrect: false})
            },

            removeOption(qIndex, oIndex) {
                if(this.questions[qIndex].options.length > 2) this.questions[qIndex].options.splice(oIndex, 1)
            },

            setCorrectOption(qIndex, oIndex) {
                this.questions[qIndex].options.forEach((opt, idx) => opt.isCorrect = (idx === oIndex));
            },

            async generateAI() {
                const fileInput = document.getElementById('pdfInputAuto');
                if (!fileInput.files || fileInput.files.length === 0) {
                    alert('Xin sếp vui lòng chọn file PDF trước!');
                    return;
                }

                this.isGenerating = true;
                const formData = new FormData();
                formData.append('pdfFile', fileInput.files[0]);

                const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                const token = tokenElement ? tokenElement.value : '';

                try {
                    const response = await fetch('?handler=GenerateQuizFromPdf', {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token },
                        body: formData
                    });

                    const data = await response.json();

                    if (data.status === 'success' && data.flashcards) {
                        this.questions = data.flashcards.map((fc, index) => ({
                            id: Date.now() + index,
                            content: fc.question,
                            points: 10,
                            options: [
                                { id: Date.now() + 1000 + index, text: fc.answer, isCorrect: true },
                                { id: Date.now() + 2000 + index, text: '', isCorrect: false },
                                { id: Date.now() + 3000 + index, text: '', isCorrect: false },
                                { id: Date.now() + 4000 + index, text: '', isCorrect: false }
                            ]
                        }));
                    } else {
                        alert(data);
                    }
                } catch (error) {
                    console.error(error);
                    alert('Lỗi kết nối Server! Vui lòng thử lại.');
                } finally {
                    this.isGenerating = false;
                }
            }
        };
    }
</script>
}