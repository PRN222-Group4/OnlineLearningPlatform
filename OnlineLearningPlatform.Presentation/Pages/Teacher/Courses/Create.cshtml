@page
@model OnlineLearningPlatform.Presentation.Pages.Teacher.Courses.CreateModel
@{
    ViewData["Title"] = Model.CourseId.HasValue ? "Edit Course" : "Create New Course";
    var currentStep = 1;
}

<div class="max-w-4xl mx-auto py-8 px-4">
    <!-- ═══════════ STEPPER ═══════════ -->
    <nav class="mb-10" x-data="{ current: @currentStep }">
        <ol class="flex items-center w-full">
            @for (int i = 1; i <= 3; i++)
            {
                var stepNames = new[] { "", "Course Info", "Lessons", "Materials" };
                var icons = new[] { "", "fa-info-circle", "fa-list-ol", "fa-puzzle-piece" };
                var isActive = i == currentStep;
                var isCompleted = i < currentStep;
                <li class="flex items-center @(i < 3 ? "flex-1" : "")">
                    <div class="flex flex-col items-center gap-1.5">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold transition-all duration-300
                            @(isActive ? "bg-indigo-600 text-white shadow-lg shadow-indigo-200 ring-4 ring-indigo-100"
                                : isCompleted ? "bg-emerald-500 text-white"
                                : "bg-zinc-100 text-zinc-400 border border-zinc-200")">
                            @if (isCompleted)
                            {
                                <i class="fas fa-check text-xs"></i>
                            }
                            else
                            {
                                <i class="fas @icons[i] text-xs"></i>
                            }
                        </div>
                        <span class="text-xs font-semibold @(isActive ? "text-indigo-600" : isCompleted ? "text-emerald-600" : "text-zinc-400")">
                            @stepNames[i]
                        </span>
                    </div>
                    @if (i < 3)
                    {
                        <div class="flex-1 mx-3 h-0.5 rounded @(i < currentStep ? "bg-emerald-400" : "bg-zinc-200")"></div>
                    }
                </li>
            }
        </ol>
    </nav>

    <!-- ═══════════ FORM CARD ═══════════ -->
    <div class="bg-white rounded-2xl shadow-sm border border-zinc-100 overflow-hidden">
        <div class="border-b border-zinc-100 px-8 py-5 bg-gradient-to-r from-indigo-50/50 to-white">
            <h2 class="text-xl font-bold text-zinc-900 flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center">
                    <i class="fas fa-plus-circle text-sm"></i>
                </div>
                @(Model.CourseId.HasValue ? "Edit Course Information" : "Create New Course")
            </h2>
            <p class="text-sm text-zinc-500 mt-1 ml-11">Fill in the basic information about your course</p>
        </div>

        <form method="post" enctype="multipart/form-data" class="px-8 py-6 space-y-6"
              asp-route-courseId="@Model.CourseId">
            <input type="hidden" asp-for="Input.LanguageId" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="rounded-xl bg-red-50 border border-red-100 p-4">
                    <div class="flex items-start gap-3">
                        <i class="fas fa-exclamation-circle text-red-500 mt-0.5"></i>
                        <div asp-validation-summary="All" class="text-sm text-red-700"></div>
                    </div>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="rounded-xl bg-red-50 border border-red-100 p-4">
                    <p class="text-sm text-red-700 flex items-center gap-2">
                        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                    </p>
                </div>
            }

            <!-- Title -->
            <div>
                <label for="title" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Title <span class="text-red-500">*</span>
                </label>
                <input type="text" asp-for="Input.Title" id="title" placeholder="e.g. Complete Python Bootcamp"
                       class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition text-zinc-800 placeholder-zinc-400" />
                <span asp-validation-for="Input.Title" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Subtitle -->
            <div>
                <label for="subtitle" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                    Subtitle
                </label>
                <input type="text" asp-for="Input.Subtitle" id="subtitle" placeholder="A brief subtitle for your course"
                       class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition text-zinc-800 placeholder-zinc-400" />
            </div>

            <!-- Description -->
            <div>
                <label for="description" class="block text-sm font-semibold text-zinc-700 mb-1.5">Description</label>
                <textarea asp-for="Input.Description" id="description" rows="4"
                          placeholder="Describe what students will learn..."
                          class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition text-zinc-800 placeholder-zinc-400 resize-none"></textarea>
            </div>

            <!-- Price & Level row -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="price" class="block text-sm font-semibold text-zinc-700 mb-1.5">
                        Price (VND) <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-zinc-400 text-sm font-medium">₫</span>
                        <input type="number" asp-for="Input.Price" id="price" min="0" step="1000"
                               class="w-full pl-10 pr-4 py-3 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition text-zinc-800" />
                    </div>
                    <span asp-validation-for="Input.Price" class="text-xs text-red-500 mt-1 block"></span>
                </div>
                <div>
                    <label for="level" class="block text-sm font-semibold text-zinc-700 mb-1.5">Level</label>
                    <select asp-for="Input.Level" id="level"
                            class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition text-zinc-800 bg-white">
                        <option value="0">Beginner</option>
                        <option value="1">Intermediate</option>
                        <option value="2">Advanced</option>
                        <option value="3">All Levels</option>
                    </select>
                </div>
            </div>

            <!-- Tags -->
            <div>
                <label for="tags" class="block text-sm font-semibold text-zinc-700 mb-1.5">Tags</label>
                <input type="text" asp-for="Input.Tags" id="tags" placeholder="python, web-development, beginner (comma-separated)"
                       class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition text-zinc-800 placeholder-zinc-400" />
                <p class="text-xs text-zinc-400 mt-1">Separate tags with commas</p>
            </div>

            <!-- Thumbnail -->
            <div x-data="{ preview: '@(Model.ExistingCourse?.Image ?? "")' }">
                <label class="block text-sm font-semibold text-zinc-700 mb-1.5">Course Thumbnail</label>
                <div class="flex items-start gap-6">
                    <template x-if="preview">
                        <img :src="preview" class="w-32 h-20 object-cover rounded-xl border border-zinc-200 shadow-sm" />
                    </template>
                    <template x-if="!preview">
                        <div class="w-32 h-20 rounded-xl border-2 border-dashed border-zinc-200 flex items-center justify-center text-zinc-300">
                            <i class="fas fa-image text-2xl"></i>
                        </div>
                    </template>
                    <div class="flex-1">
                        <label class="flex flex-col items-center justify-center w-full h-20 border-2 border-dashed border-zinc-200 rounded-xl cursor-pointer hover:border-indigo-300 hover:bg-indigo-50/30 transition">
                            <div class="flex items-center gap-2 text-sm text-zinc-500">
                                <i class="fas fa-cloud-upload-alt text-indigo-400"></i>
                                <span>Click to upload image</span>
                            </div>
                            <input type="file" name="Input.ImageFile" accept="image/*" class="hidden"
                                   @@change="preview = URL.createObjectURL($event.target.files[0])" />
                        </label>
                        <p class="text-xs text-zinc-400 mt-1.5">PNG, JPG, WebP. Recommended 1280×720.</p>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center justify-between pt-4 border-t border-zinc-100">
                <a asp-page="/Teacher/Dashboard"
                   class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium text-zinc-600 bg-zinc-100 hover:bg-zinc-200 transition">
                    <i class="fas fa-arrow-left text-xs"></i> Back
                </a>
                <button type="submit"
                        class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition">
                    Save & Continue <i class="fas fa-arrow-right text-xs"></i>
                </button>
            </div>
        </form>
    </div>
</div>
