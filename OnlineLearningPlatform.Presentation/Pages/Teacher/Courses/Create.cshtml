@page
@model OnlineLearningPlatform.Presentation.Pages.Teacher.Courses.CreateModel
@{
    ViewData["Title"] = Model.CourseId.HasValue ? "Edit Course" : "Create New Course";
}

<div class="max-w-4xl mx-auto py-8 px-4"
     x-data="{
        step: 1,
        isFree: @(Model.Input.Price == 0 ? "true" : "false"),
        price: @(Model.Input.Price),
        formatVND(val) {
            return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(val);
        }
     }">

    <nav class="mb-10">
        <ol class="flex items-center w-full">
            <li class="flex items-center flex-1">
                <div class="flex flex-col items-center gap-1.5">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold transition-all duration-300"
                         :class="step >= 1 ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-200 ring-4 ring-indigo-100' : 'bg-zinc-100 text-zinc-400 border border-zinc-200'">
                        <i class="fas" :class="step > 1 ? 'fa-check' : 'fa-info-circle'"></i>
                    </div>
                    <span class="text-xs font-semibold" :class="step >= 1 ? 'text-indigo-600' : 'text-zinc-400'">Metadata</span>
                </div>
                <div class="flex-1 mx-3 h-0.5 rounded transition-colors duration-300" :class="step > 1 ? 'bg-indigo-400' : 'bg-zinc-200'"></div>
            </li>
            <li class="flex items-center flex-1">
                <div class="flex flex-col items-center gap-1.5">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold transition-all duration-300"
                         :class="step >= 2 ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-200 ring-4 ring-indigo-100' : 'bg-zinc-100 text-zinc-400 border border-zinc-200'">
                        <i class="fas fa-tag"></i>
                    </div>
                    <span class="text-xs font-semibold" :class="step >= 2 ? 'text-indigo-600' : 'text-zinc-400'">Pricing</span>
                </div>
                <div class="flex-1 mx-3 h-0.5 rounded bg-zinc-200"></div>
            </li>
            <li class="flex items-center">
                <div class="flex flex-col items-center gap-1.5 opacity-50">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold bg-zinc-100 text-zinc-400 border border-zinc-200">
                        <i class="fas fa-list-ol"></i>
                    </div>
                    <span class="text-xs font-semibold text-zinc-400">Curriculum</span>
                </div>
            </li>
        </ol>
    </nav>

    <div class="bg-white rounded-2xl shadow-sm border border-zinc-100 overflow-hidden">
        <div class="border-b border-zinc-100 px-8 py-5 bg-gradient-to-r from-indigo-50/50 to-white">
            <h2 class="text-xl font-bold text-zinc-900 flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center">
                    <i class="fas fa-magic text-sm"></i>
                </div>
                @(Model.CourseId.HasValue ? "Edit Course Draft" : "Start a New Course")
            </h2>
            <p class="text-sm text-zinc-500 mt-1 ml-11" x-text="step === 1 ? 'Enter the metadata to make your course discoverable.' : 'Set a price that reflects the value of your content.'"></p>
        </div>

        <form method="post" enctype="multipart/form-data" class="px-8 py-6" asp-route-courseId="@Model.CourseId">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="rounded-xl bg-red-50 border border-red-100 p-4 mb-6">
                    <div class="flex items-start gap-3">
                        <i class="fas fa-exclamation-circle text-red-500 mt-0.5"></i>
                        <div asp-validation-summary="All" class="text-sm text-red-700 font-medium"></div>
                    </div>
                </div>
            }

            <div x-show="step === 1" x-transition.opacity>
                <div class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-semibold text-zinc-700 mb-1.5">Title <span class="text-rose-500">*</span></label>
                            <input type="text" asp-for="Input.Title" placeholder="e.g. Master C# and .NET Core" required
                                   class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition" />
                            <span asp-validation-for="Input.Title" class="text-xs text-rose-500 mt-1 block"></span>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-zinc-700 mb-1.5">Language <span class="text-rose-500">*</span></label>
                            <select asp-for="Input.LanguageId" asp-items="Model.LanguageOptions" required
                                    class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition bg-white">
                                <option value="">Select Language...</option>
                            </select>
                            <span asp-validation-for="Input.LanguageId" class="text-xs text-rose-500 mt-1 block"></span>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-zinc-700 mb-1.5">Subtitle</label>
                        <input type="text" asp-for="Input.Subtitle" placeholder="A catchy tagline for your course"
                               class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition" />
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-zinc-700 mb-1.5">Description</label>
                        <textarea asp-for="Input.Description" rows="4" placeholder="What will students achieve?"
                                  class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition resize-none"></textarea>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-semibold text-zinc-700 mb-1.5">Tags</label>
                            <input type="text" asp-for="Input.Tags" placeholder="C#, .NET, Web (comma-separated)"
                                   class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-zinc-700 mb-1.5">Level</label>
                            <select asp-for="Input.Level" class="w-full px-4 py-3 rounded-xl border border-zinc-200 focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none transition bg-white">
                                <option value="0">Beginner</option>
                                <option value="1">Intermediate</option>
                                <option value="2">Advanced</option>
                                <option value="3">All Levels</option>
                            </select>
                        </div>
                    </div>

                    <div x-data="{ preview: '@(Model.ExistingCourse?.Image ?? "")' }">
                        <label class="block text-sm font-semibold text-zinc-700 mb-1.5">Course Thumbnail</label>
                        <div class="flex items-start gap-6">
                            <template x-if="preview">
                                <img :src="preview" class="w-32 h-20 object-cover rounded-xl border border-zinc-200 shadow-sm" />
                            </template>
                            <template x-if="!preview">
                                <div class="w-32 h-20 rounded-xl border-2 border-dashed border-zinc-200 flex items-center justify-center text-zinc-300 bg-zinc-50">
                                    <i class="fas fa-image text-2xl"></i>
                                </div>
                            </template>
                            <div class="flex-1">
                                <label class="flex flex-col items-center justify-center w-full h-20 border-2 border-dashed border-indigo-200 rounded-xl cursor-pointer hover:bg-indigo-50/50 hover:border-indigo-300 transition">
                                    <div class="flex items-center gap-2 text-sm text-indigo-600 font-semibold">
                                        <i class="fas fa-cloud-upload-alt text-lg"></i>
                                        <span>Click to upload image</span>
                                    </div>
                                    <input type="file" name="Input.ImageFile" accept="image/*" class="hidden"
                                           @@change="preview = URL.createObjectURL($event.target.files[0])" />
                                </label>
                                <p class="text-[11px] text-zinc-400 mt-2 font-medium">PNG, JPG, WebP. Recommended 1280×720.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-between pt-8 mt-8 border-t border-zinc-100">
                    <a asp-page="/Teacher/Dashboard" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold text-zinc-600 hover:bg-zinc-100 transition">
                        <i class="fas fa-times"></i> Cancel
                    </a>

                    <button type="button" @@click="if($event.target.closest('form').checkValidity()) { step = 2; } else { $event.target.closest('form').reportValidity(); }"
                            class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-bold hover:bg-indigo-700 shadow-lg shadow-indigo-200 transition">
                        Next: Pricing <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </div>

            <div x-show="step === 2" x-cloak x-transition.opacity>
                <div class="space-y-8 min-h-[400px]">

                    <div class="flex items-center justify-between p-5 rounded-2xl border-2 transition-all cursor-pointer select-none"
                         :class="isFree ? 'border-emerald-500 bg-emerald-50/30' : 'border-zinc-200 bg-zinc-50/50'"
                         @@click="isFree = !isFree; if(isFree) { price = 0; $refs.priceInput.value = 0; }">
                        <div>
                            <h3 class="font-bold text-zinc-900 text-lg" :class="isFree ? 'text-emerald-700' : ''">Free Course</h3>
                            <p class="text-sm text-zinc-500">Offer your course for free to build your audience.</p>
                        </div>
                        <div class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" class="sr-only peer" x-model="isFree">
                            <div class="w-14 h-7 bg-zinc-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-zinc-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all peer-checked:bg-emerald-500"></div>
                        </div>
                    </div>

                    <div x-show="!isFree" x-transition.opacity>
                        <label class="block text-sm font-bold text-zinc-900 mb-3">Set your price (VND)</label>

                        <div class="grid grid-cols-3 gap-3 mb-5">
                            <button type="button" @@click="price = 199000; $refs.priceInput.value = 199000" class="py-3 border-2 rounded-xl font-bold transition-all" :class="price == 199000 ? 'border-indigo-600 bg-indigo-50 text-indigo-700' : 'border-zinc-200 text-zinc-600 hover:border-indigo-300 hover:bg-zinc-50'">199,000 ₫</button>
                            <button type="button" @@click="price = 499000; $refs.priceInput.value = 499000" class="py-3 border-2 rounded-xl font-bold transition-all" :class="price == 499000 ? 'border-indigo-600 bg-indigo-50 text-indigo-700' : 'border-zinc-200 text-zinc-600 hover:border-indigo-300 hover:bg-zinc-50'">499,000 ₫</button>
                            <button type="button" @@click="price = 999000; $refs.priceInput.value = 999000" class="py-3 border-2 rounded-xl font-bold transition-all" :class="price == 999000 ? 'border-indigo-600 bg-indigo-50 text-indigo-700' : 'border-zinc-200 text-zinc-600 hover:border-indigo-300 hover:bg-zinc-50'">999,000 ₫</button>
                        </div>

                        <div class="relative max-w-sm">
                            <span class="absolute left-5 top-1/2 -translate-y-1/2 text-zinc-400 font-bold text-lg">₫</span>
                            <input type="hidden" asp-for="Input.Price" x-ref="priceInput" :value="price" />
                            <input type="number" x-model="price" min="0" step="1000"
                                   class="w-full pl-12 pr-4 py-4 rounded-xl border-2 border-zinc-200 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 outline-none transition text-zinc-900 text-xl font-black tracking-tight shadow-inner" />
                        </div>

                        <div class="mt-8 bg-gradient-to-br from-slate-800 to-slate-900 rounded-2xl p-6 text-white shadow-xl relative overflow-hidden ring-1 ring-white/10">
                            <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-indigo-500 rounded-full blur-3xl opacity-20 pointer-events-none"></div>

                            <h4 class="font-bold text-indigo-200 mb-6 uppercase tracking-widest text-xs flex items-center gap-2">
                                <i class="fas fa-chart-pie"></i> Estimated Earnings
                            </h4>

                            <div class="flex justify-between items-end mb-3">
                                <span class="text-zinc-400 font-medium">Course Price</span>
                                <span class="font-bold text-lg" x-text="formatVND(price)"></span>
                            </div>
                            <div class="flex justify-between items-end mb-5 pb-5 border-b border-zinc-700/50">
                                <span class="text-zinc-400 font-medium flex items-center gap-2">
                                    Platform Fee
                                    <span class="px-2 py-0.5 bg-zinc-800 rounded text-[10px] text-zinc-300">30%</span>
                                </span>
                                <span class="text-rose-400 font-bold" x-text="'- ' + formatVND(price * 0.3)"></span>
                            </div>
                            <div class="flex justify-between items-end">
                                <span class="font-bold text-zinc-300 text-lg">You Receive</span>
                                <span class="text-3xl font-display font-extrabold text-emerald-400 drop-shadow-md" x-text="formatVND(price * 0.7)"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-between pt-8 border-t border-zinc-100 mt-8">
                    <button type="button" @@click="step = 1"
                            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold text-zinc-600 hover:bg-zinc-100 transition">
                        <i class="fas fa-arrow-left"></i> Back
                    </button>

                    <button type="submit"
                            class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-indigo-600 text-white text-sm font-extrabold hover:bg-indigo-700 shadow-xl shadow-indigo-200 transition-all group focus:ring-4 focus:ring-indigo-100">
                        Save Draft & Continue <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>