@page
@model OnlineLearningPlatform.Presentation.Pages.Teacher.DashboardModel
@{
    Layout = "~/Pages/Teacher/_TeacherLayout.cshtml";
    ViewData["Title"] = "Teacher Dashboard";

    var statusMap = new Dictionary<int, (string label, string bg, string dot)>
    {
        [0] = ("Draft",     "bg-zinc-100 text-zinc-600",    "bg-zinc-400"),
        [1] = ("Pending",   "bg-blue-50 text-blue-600",     "bg-blue-500"),
        [2] = ("Published", "bg-emerald-50 text-emerald-700","bg-emerald-500"),
        [3] = ("Rejected",  "bg-red-50 text-red-600",       "bg-red-500"),
    };
}

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
            <p class="text-xs font-semibold text-primary-600 uppercase tracking-widest mb-1">Instructor Panel</p>
            <h1 class="font-display text-2xl font-extrabold text-slate-900">My Courses</h1>
            <p class="text-slate-500 text-sm mt-1">Manage and track all your created courses</p>
        </div>
        <a asp-page="/Teacher/Courses/Create"
           class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-900 text-white text-sm font-semibold rounded-xl
                  hover:bg-primary-600 transition-colors shadow-lg shadow-slate-900/20 shrink-0 no-underline">
            <i class="fas fa-plus text-xs"></i> Create Course
        </a>
    </div>

    <!-- Error -->
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 mb-6">
            <i class="fas fa-exclamation-circle text-red-400 shrink-0"></i>
            @Model.ErrorMessage
        </div>
    }

    @if (Model.Courses?.Any() == true)
    {
        <!-- Stats -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
            @{
                var total     = Model.Courses.Count;
                var published = Model.Courses.Count(c => c.Status == 2);
                var pending   = Model.Courses.Count(c => c.Status == 1);
                var draft     = Model.Courses.Count(c => c.Status == 0);
            }
            @foreach (var s in new[] {
                new { Label = "Total",     Value = total.ToString(),     Icon = "fa-layer-group",  Bg = "bg-slate-100",  Cl = "text-slate-600"   },
                new { Label = "Published", Value = published.ToString(), Icon = "fa-check-circle", Bg = "bg-emerald-50", Cl = "text-emerald-600" },
                new { Label = "Pending",   Value = pending.ToString(),   Icon = "fa-clock",        Bg = "bg-blue-50",    Cl = "text-blue-600"    },
                new { Label = "Draft",     Value = draft.ToString(),     Icon = "fa-pencil-alt",   Bg = "bg-zinc-100",   Cl = "text-zinc-500"    },
            })
            {
                <div class="bg-white rounded-xl border border-slate-200 px-5 py-4 flex items-center gap-3 shadow-sm">
                    <div class="w-9 h-9 @s.Bg rounded-lg flex items-center justify-center shrink-0">
                        <i class="fas @s.Icon @s.Cl text-sm"></i>
                    </div>
                    <div>
                        <p class="text-xl font-bold text-slate-900 leading-tight">@s.Value</p>
                        <p class="text-xs text-slate-400 font-medium">@s.Label</p>
                    </div>
                </div>
            }
        </div>

        <!-- Grid -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            @foreach (var c in Model.Courses)
            {
                var (statusLabel, statusCls, dotCls) = statusMap.TryGetValue(c.Status, out var sv)
                    ? sv : ("Unknown", "bg-slate-100 text-slate-500", "bg-slate-400");

                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow-md hover:-translate-y-0.5
                            transition-all duration-200 overflow-hidden flex flex-col group">

                    <!-- Thumbnail -->
                    <div class="relative h-40 bg-slate-100 overflow-hidden shrink-0">
                        @if (!string.IsNullOrEmpty(c.Image))
                        {
                            <img src="@c.Image" alt="@c.Title"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center">
                                <i class="fas fa-book-open text-slate-200 text-4xl"></i>
                            </div>
                        }
                        <span class="absolute top-3 left-3 inline-flex items-center gap-1 px-2.5 py-1 @statusCls text-[10px] font-bold rounded-full shadow-sm">
                            <span class="w-1.5 h-1.5 rounded-full @dotCls"></span>
                            @statusLabel
                        </span>
                        <span class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-2.5 py-1 rounded-lg text-xs font-bold text-slate-800 shadow-sm">
                            @(c.Price == 0 ? "Free" : c.Price.ToString("N0") + " ₫")
                        </span>
                    </div>

                    <!-- Body -->
                    <div class="p-4 flex flex-col flex-1">
                        <h3 class="text-sm font-bold text-slate-900 line-clamp-2 leading-snug mb-1.5">@c.Title</h3>
                        @if (!string.IsNullOrEmpty(c.Description))
                        {
                            <p class="text-xs text-slate-400 line-clamp-2 leading-relaxed mb-3">@c.Description</p>
                        }

                        <!-- Actions -->
                        <div class="mt-auto flex items-center gap-2 pt-3 border-t border-slate-100">
                            <a asp-page="/Teacher/Courses/Edit" asp-route-courseId="@c.CourseId"
                               class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 bg-slate-50 text-slate-700
                                      text-xs font-semibold rounded-lg hover:bg-slate-100 transition-colors no-underline">
                                <i class="fas fa-pencil-alt text-[10px]"></i> Edit
                            </a>
                            <a asp-page="/Teacher/Courses/Detail" asp-route-courseId="@c.CourseId"
                               class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 bg-primary-50 text-primary-700
                                      text-xs font-semibold rounded-lg hover:bg-primary-100 transition-colors no-underline">
                                <i class="fas fa-eye text-[10px]"></i> View
                            </a>
                            @if (c.Status == 0 || c.Status == 3)
                            {
                                <form method="post" asp-page-handler="Submit" class="flex-1">
                                    <input type="hidden" name="courseId" value="@c.CourseId" />
                                    <button type="submit"
                                            class="w-full inline-flex items-center justify-center gap-1.5 px-3 py-2 bg-emerald-50 text-emerald-700
                                                   text-xs font-semibold rounded-lg hover:bg-emerald-100 transition-colors">
                                        <i class="fas fa-paper-plane text-[10px]"></i> Submit
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty -->
        <div class="bg-white rounded-2xl border border-slate-200 py-20 text-center shadow-sm">
            <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-chalkboard-teacher text-slate-300 text-2xl"></i>
            </div>
            <h3 class="text-base font-semibold text-slate-700 mb-1">No courses yet</h3>
            <p class="text-sm text-slate-400 mb-6 max-w-xs mx-auto">Create your first course and start sharing knowledge with students.</p>
            <a asp-page="/Teacher/Courses/Create"
               class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary-600 text-white text-sm font-semibold rounded-xl
                      hover:bg-primary-700 transition-colors no-underline">
                <i class="fas fa-plus text-xs"></i> Create your first course
            </a>
        </div>
    }
</div>
