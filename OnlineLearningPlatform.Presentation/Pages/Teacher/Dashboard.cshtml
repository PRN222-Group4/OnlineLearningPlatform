@page
@model OnlineLearningPlatform.Presentation.Pages.Teacher.DashboardModel
@{
    Layout = "~/Pages/Teacher/_TeacherLayout.cshtml";
    ViewData["Title"] = "Teacher Dashboard";
}

<div class="container">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2>Teacher Dashboard</h2>
        <div>
            <a class="btn btn-primary" asp-page="/Teacher/CreateCourse">＋ Create Course</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.Courses == null || !Model.Courses.Any())
    {
        <div class="alert alert-info">You have not created any courses yet.</div>
    }
    else
    {
        <div class="row">
            @foreach (var c in Model.Courses)
            {
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="row g-0">
                            <div class="col-4">
                                <img src="@c.Image" class="img-fluid rounded-start" style="height:130px;object-fit:cover;" />
                            </div>
                            <div class="col-8">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title">@c.Title</h5>
                                    <p class="card-text text-muted small mb-2">@c.Description</p>
                                    <div class="mt-auto d-flex justify-content-between align-items-center">
                                        <div>
                                            <small class="text-muted">Price: @c.Price.ToString("N0") đ</small>
                                        </div>
                                        <div>
                                            <a class="btn btn-sm btn-outline-primary" asp-page="/Teacher/CoursesEdit" asp-route-id="@c.CourseId">Edit</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
