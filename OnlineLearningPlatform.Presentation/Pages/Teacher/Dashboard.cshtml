@page
@model OnlineLearningPlatform.Presentation.Pages.Teacher.DashboardModel
@{
    Layout = "~/Pages/Teacher/_TeacherLayout.cshtml";
    ViewData["Title"] = "Instructor Dashboard";

    var statusMap = new Dictionary<int, (string label, string bg, string dot)>
            {
                [0] = ("Draft", "bg-zinc-100 text-zinc-600", "bg-zinc-400"),
                [1] = ("Pending", "bg-blue-50 text-blue-600", "bg-blue-500"),
                [2] = ("Published", "bg-emerald-50 text-emerald-700", "bg-emerald-500"),
                [3] = ("Rejected", "bg-red-50 text-red-600", "bg-red-500"),
            };
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 font-sans">

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
            <p class="text-xs font-semibold text-primary-600 uppercase tracking-widest mb-1">Instructor Panel</p>
            <h1 class="font-display text-3xl font-extrabold text-slate-900">Dashboard Overview</h1>
            <p class="text-slate-500 text-sm mt-1">Manage courses and track your financial growth</p>
        </div>
        <a asp-page="/Teacher/Courses/Create"
           class="inline-flex items-center gap-2 px-6 py-3 bg-slate-900 text-white text-sm font-bold rounded-xl
                  hover:bg-primary-600 transition-all shadow-xl shadow-slate-900/20 shrink-0 no-underline">
            <i class="fas fa-plus text-xs"></i> Create Course
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 mb-6 font-semibold shadow-sm">
            <i class="fas fa-exclamation-circle text-red-500 shrink-0 text-lg"></i> @Model.ErrorMessage
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="flex items-center gap-3 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-sm text-emerald-700 mb-6 font-semibold shadow-sm">
            <i class="fas fa-check-circle text-emerald-500 shrink-0 text-lg"></i> @TempData["Success"]
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-3xl p-8 shadow-xl relative overflow-hidden transform transition-all hover:-translate-y-1">
            <div class="absolute -right-4 -bottom-4 opacity-10"><i class="fas fa-wallet text-9xl text-white"></i></div>
            <p class="text-slate-300 text-sm font-semibold mb-2 relative z-10">Total Gross Revenue</p>
            <h2 class="text-4xl sm:text-5xl font-black text-white relative z-10 tracking-tight">@Model.TotalRevenue.ToString("N0") ₫</h2>
            <div class="mt-6 flex items-center gap-2 text-emerald-400 text-xs font-bold relative z-10 uppercase tracking-wider">
                <i class="fas fa-chart-line"></i> Lifetime earnings
            </div>
        </div>

        <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-sm relative overflow-hidden transform transition-all hover:-translate-y-1">
            <div class="w-14 h-14 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center text-2xl absolute top-8 right-8 shadow-inner">
                <i class="fas fa-users"></i>
            </div>
            <p class="text-slate-500 text-sm font-semibold mb-2">Total Students</p>
            <h2 class="text-4xl sm:text-5xl font-black text-slate-900 tracking-tight">@Model.TotalStudents.ToString("N0")</h2>
            <div class="mt-6 flex items-center gap-2 text-indigo-600 text-xs font-bold uppercase tracking-wider">
                <i class="fas fa-user-graduate"></i> Unique learners
            </div>
        </div>

        <div class="bg-white rounded-3xl p-8 border border-slate-200 shadow-sm relative overflow-hidden transform transition-all hover:-translate-y-1">
            <div class="w-14 h-14 bg-primary-50 text-primary-600 rounded-2xl flex items-center justify-center text-2xl absolute top-8 right-8 shadow-inner">
                <i class="fas fa-clipboard-list"></i>
            </div>
            <p class="text-slate-500 text-sm font-semibold mb-2">Total Enrollments</p>
            <h2 class="text-4xl sm:text-5xl font-black text-slate-900 tracking-tight">@Model.TotalEnrollments.ToString("N0")</h2>
            <div class="mt-6 flex items-center gap-2 text-primary-600 text-xs font-bold uppercase tracking-wider">
                <i class="fas fa-book"></i> Course subscriptions
            </div>
        </div>
    </div>

    @if (Model.Courses?.Any() == true)
    {
        <div class="flex items-center justify-between mb-4 mt-8">
            <h3 class="font-extrabold text-slate-900 text-xl tracking-tight">Course Portfolio</h3>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            @{
                var total = Model.Courses.Count;
                var published = Model.Courses.Count(c => c.Status == 2);
                var pending = Model.Courses.Count(c => c.Status == 1);
                var draft = Model.Courses.Count(c => c.Status == 0);
            }
            @foreach (var s in new[] {
        new { Label = "Total Courses", Value = total.ToString(),     Icon = "fa-layer-group",  Bg = "bg-slate-100",  Cl = "text-slate-600"   },
        new { Label = "Published",     Value = published.ToString(), Icon = "fa-check-circle", Bg = "bg-emerald-50", Cl = "text-emerald-600" },
        new { Label = "Pending",       Value = pending.ToString(),   Icon = "fa-clock",        Bg = "bg-blue-50",    Cl = "text-blue-600"    },
        new { Label = "Drafts",        Value = draft.ToString(),     Icon = "fa-pencil-alt",   Bg = "bg-zinc-100",   Cl = "text-zinc-500"    },
        })
            {
                <div class="bg-white rounded-2xl border border-slate-200 px-6 py-5 flex items-center gap-4 shadow-sm hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 @s.Bg rounded-xl flex items-center justify-center shrink-0">
                        <i class="fas @s.Icon @s.Cl text-lg"></i>
                    </div>
                    <div>
                        <p class="text-2xl font-black text-slate-900 leading-tight">@s.Value</p>
                        <p class="text-xs text-slate-500 font-bold uppercase tracking-wider mt-0.5">@s.Label</p>
                    </div>
                </div>
            }
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var c in Model.Courses)
            {
                var (statusLabel, statusCls, dotCls) = statusMap.TryGetValue(c.Status, out var sv)
                ? sv : ("Unknown", "bg-slate-100 text-slate-500", "bg-slate-400");

                <div class="bg-white rounded-3xl border border-slate-200 shadow-sm hover:shadow-xl hover:-translate-y-1
                            transition-all duration-300 overflow-hidden flex flex-col group">

                    <div class="relative h-48 bg-slate-100 overflow-hidden shrink-0">
                        @if (!string.IsNullOrEmpty(c.Image))
                        {
                            <img src="@c.Image" alt="@c.Title"
                                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center">
                                <i class="fas fa-book-open text-slate-200 text-5xl"></i>
                            </div>
                        }

                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-transparent to-transparent"></div>

                        <span class="absolute top-3 left-3 inline-flex items-center gap-1.5 px-3 py-1.5 @statusCls text-[10px] font-black uppercase tracking-wider rounded-full shadow-sm backdrop-blur-md bg-white/90">
                            <span class="w-1.5 h-1.5 rounded-full @dotCls animate-pulse"></span>
                            @statusLabel
                        </span>
                        <span class="absolute bottom-3 right-3 bg-slate-900/80 backdrop-blur-sm px-3 py-1.5 rounded-lg text-xs font-black text-white shadow-sm border border-white/10">
                            @(c.Price == 0 ? "FREE" : c.Price.ToString("N0") + " ₫")
                        </span>
                    </div>

                    <div class="p-5 flex flex-col flex-1">
                        <h3 class="text-base font-bold text-slate-900 line-clamp-2 leading-snug mb-2 group-hover:text-primary-600 transition-colors">@c.Title</h3>
                        @if (!string.IsNullOrEmpty(c.Description))
                        {
                            <p class="text-sm text-slate-500 line-clamp-2 leading-relaxed mb-4">@c.Description</p>
                        }

                        <div class="mt-auto flex items-center gap-2 pt-4 border-t border-slate-100">
                            <a asp-page="/Teacher/Courses/Edit" asp-route-courseId="@c.CourseId"
                               class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2.5 bg-slate-50 text-slate-700
                                      text-xs font-bold rounded-xl hover:bg-slate-200 transition-colors no-underline">
                                <i class="fas fa-pencil-alt text-[10px]"></i> Edit
                            </a>

                            <a asp-page="/Teacher/Courses/Detail" asp-route-courseId="@c.CourseId"
                               class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2.5 bg-primary-50 text-primary-700
                                      text-xs font-bold rounded-xl hover:bg-primary-100 transition-colors no-underline">
                                <i class="fas fa-eye text-[10px]"></i> View
                            </a>

                            @if (c.Status == 0 || c.Status == 3)
                            {
                                <form method="post" asp-page-handler="Submit" class="flex-1">
                                    <input type="hidden" name="courseId" value="@c.CourseId" />
                                    <button type="submit"
                                            class="w-full inline-flex items-center justify-center gap-1.5 px-3 py-2.5 bg-emerald-50 text-emerald-700
                                                   text-xs font-bold rounded-xl hover:bg-emerald-100 transition-colors">
                                        <i class="fas fa-paper-plane text-[10px]"></i> Submit
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bg-white rounded-3xl border border-slate-200 py-24 text-center shadow-sm relative overflow-hidden">
            <div class="absolute inset-0 bg-slate-50/50"></div>
            <div class="relative z-10">
                <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-6 shadow-md border border-slate-100">
                    <i class="fas fa-rocket text-primary-500 text-3xl"></i>
                </div>
                <h3 class="text-xl font-extrabold text-slate-900 mb-2">No courses yet</h3>
                <p class="text-base text-slate-500 mb-8 max-w-sm mx-auto">Create your first course and start sharing your knowledge with students worldwide.</p>
                <a asp-page="/Teacher/Courses/Create"
                   class="inline-flex items-center gap-2 px-8 py-3.5 bg-primary-600 text-white text-base font-bold rounded-xl
                          hover:bg-primary-700 transition-all no-underline shadow-xl shadow-primary-500/20 transform hover:-translate-y-0.5">
                    <i class="fas fa-plus text-sm"></i> Create your first course
                </a>
            </div>
        </div>
    }
</div>