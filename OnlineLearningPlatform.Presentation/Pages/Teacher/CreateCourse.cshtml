@page
@model OnlineLearningPlatform.Presentation.Pages.Teacher.CreateCourseModel
@{
    Layout = "~/Pages/Teacher/_TeacherLayout.cshtml";
    ViewData["Title"] = "Create Course";
}

<div x-data="courseWizard()" x-cloak class="max-w-3xl mx-auto">
    <!-- Stepper -->
    <div class="flex items-center justify-center gap-0 mb-10 anim-fade-down">
        <template x-for="(s, idx) in steps" :key="idx">
            <div class="flex items-center">
                <div class="flex flex-col items-center gap-1.5">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold transition-all duration-300 border-2"
                         :class="step > idx+1 ? 'bg-emerald-500 border-emerald-500 text-white' :
                                 step === idx+1 ? 'bg-gradient-to-r from-ocean-500 to-cyan-500 border-ocean-500 text-white shadow-lg shadow-ocean-200' :
                                 'border-gray-200 text-gray-400 bg-white'">
                        <template x-if="step > idx+1"><i class="bi bi-check-lg"></i></template>
                        <template x-if="step <= idx+1"><span x-text="idx+1"></span></template>
                    </div>
                    <span class="text-[10px] font-bold uppercase tracking-wider"
                          :class="step === idx+1 ? 'text-ocean-600' : step > idx+1 ? 'text-emerald-600' : 'text-gray-400'"
                          x-text="s"></span>
                </div>
                <template x-if="idx < steps.length - 1">
                    <div class="w-16 h-0.5 mx-2 rounded-full transition-all duration-500"
                         :class="step > idx+1 ? 'bg-emerald-400' : 'bg-gray-200'"></div>
                </template>
            </div>
        </template>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl mb-5 text-sm anim-scale">@Model.ErrorMessage</div>
    }

    <form method="post" enctype="multipart/form-data" id="createCourseForm">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-lg shadow-gray-200/30 overflow-hidden">

            <!-- Step 1: Basic Info -->
            <div x-show="step === 1" x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="opacity-0 translate-x-4" x-transition:enter-end="opacity-100 translate-x-0"
                 class="p-7 space-y-5">
                <div class="text-center mb-2">
                    <div class="w-14 h-14 bg-ocean-50 rounded-2xl flex items-center justify-center mx-auto mb-3">
                        <i class="bi bi-pencil-square text-2xl text-ocean-500"></i>
                    </div>
                    <h3 class="text-xl font-extrabold text-gray-900">Basic Information</h3>
                    <p class="text-sm text-gray-400">Give your course a title and description</p>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Course Title <span class="text-red-400">*</span></label>
                    <input asp-for="Request.Title" x-model="title" required placeholder="e.g., Web Development Masterclass"
                           class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:border-ocean-400 focus:ring-2 focus:ring-ocean-100 outline-none transition" />
                    <span asp-validation-for="Request.Title" class="text-red-500 text-xs"></span>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Description <span class="text-red-400">*</span></label>
                    <textarea asp-for="Request.Description" x-model="description" rows="5" required
                              placeholder="Describe what students will learn..."
                              class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:border-ocean-400 focus:ring-2 focus:ring-ocean-100 outline-none transition resize-none"></textarea>
                    <span asp-validation-for="Request.Description" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <!-- Step 2: Details -->
            <div x-show="step === 2" x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="opacity-0 translate-x-4" x-transition:enter-end="opacity-100 translate-x-0"
                 class="p-7 space-y-5" style="display:none">
                <div class="text-center mb-2">
                    <div class="w-14 h-14 bg-cyan-50 rounded-2xl flex items-center justify-center mx-auto mb-3">
                        <i class="bi bi-gear text-2xl text-cyan-500"></i>
                    </div>
                    <h3 class="text-xl font-extrabold text-gray-900">Course Details</h3>
                    <p class="text-sm text-gray-400">Set pricing, level, and cover image</p>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Price (VND) <span class="text-red-400">*</span></label>
                        <div class="relative">
                            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm">đ</span>
                            <input asp-for="Request.Price" x-model="price" type="number" required placeholder="499000"
                                   class="w-full pl-8 pr-4 py-3 rounded-xl border border-gray-200 text-sm focus:border-ocean-400 focus:ring-2 focus:ring-ocean-100 outline-none transition" />
                        </div>
                        <span asp-validation-for="Request.Price" class="text-red-500 text-xs"></span>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Level</label>
                        <select asp-for="Request.Level"
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:border-ocean-400 outline-none transition bg-white">
                            <option value="0">🟢 Beginner</option>
                            <option value="1">🟡 Intermediate</option>
                            <option value="2">🔴 Advanced</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Cover Image</label>
                    <div class="border-2 border-dashed border-gray-200 rounded-xl p-6 text-center hover:border-ocean-300 transition">
                        <i class="bi bi-cloud-arrow-up text-3xl text-gray-300 mb-2 block"></i>
                        <p class="text-sm text-gray-400 mb-2">Drag & drop or click to upload</p>
                        <input asp-for="Request.ImageFile" type="file" accept="image/*"
                               class="text-xs file:mr-2 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-ocean-50 file:text-ocean-600 hover:file:bg-ocean-100 cursor-pointer" />
                    </div>
                </div>
            </div>

            <!-- Step 3: Review -->
            <div x-show="step === 3" x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="opacity-0 translate-x-4" x-transition:enter-end="opacity-100 translate-x-0"
                 class="p-7 space-y-5" style="display:none">
                <div class="text-center mb-2">
                    <div class="w-14 h-14 bg-emerald-50 rounded-2xl flex items-center justify-center mx-auto mb-3">
                        <i class="bi bi-check-circle text-2xl text-emerald-500"></i>
                    </div>
                    <h3 class="text-xl font-extrabold text-gray-900">Review & Create</h3>
                    <p class="text-sm text-gray-400">Review your course details before creating as a draft</p>
                </div>

                <div class="bg-gray-50 rounded-xl p-5 space-y-3">
                    <div class="flex justify-between items-start">
                        <span class="text-sm text-gray-500">Title</span>
                        <span class="text-sm font-bold text-gray-900 text-right max-w-[60%]" x-text="title || '—'"></span>
                    </div>
                    <div class="w-full h-px bg-gray-200"></div>
                    <div class="flex justify-between items-start">
                        <span class="text-sm text-gray-500">Description</span>
                        <span class="text-sm text-gray-700 text-right max-w-[60%] line-clamp-3" x-text="description || '—'"></span>
                    </div>
                    <div class="w-full h-px bg-gray-200"></div>
                    <div class="flex justify-between">
                        <span class="text-sm text-gray-500">Price</span>
                        <span class="text-sm font-bold text-ocean-600" x-text="(price ? Number(price).toLocaleString() + ' đ' : '—')"></span>
                    </div>
                </div>

                <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-700">
                    <i class="bi bi-info-circle mr-1"></i>
                    Your course will be saved as a <strong>Draft</strong>. Add modules & lessons in the management page, then submit for admin review.
                </div>
            </div>

            <!-- Footer Buttons -->
            <div class="flex items-center justify-between px-7 py-5 border-t border-gray-100 bg-gray-50/50">
                <button type="button" @@click="prev()" x-show="step > 1"
                        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold text-gray-600 border border-gray-200 hover:bg-gray-100 transition">
                    <i class="bi bi-arrow-left"></i> Back
                </button>
                <a asp-page="/Teacher/Dashboard" x-show="step === 1"
                   class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold text-gray-600 border border-gray-200 hover:bg-gray-100 transition">
                    Cancel
                </a>

                <button type="button" @@click="next()" x-show="step < 3"
                        class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold text-white bg-gradient-to-r from-ocean-500 to-cyan-500 shadow-md hover:shadow-lg hover:scale-[1.02] transition-all">
                    Next <i class="bi bi-arrow-right"></i>
                </button>
                <button type="submit" x-show="step === 3"
                        class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold text-white bg-gradient-to-r from-emerald-500 to-green-500 shadow-md hover:shadow-lg hover:scale-[1.02] transition-all">
                    <i class="bi bi-check-lg"></i> Create Draft Course
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function courseWizard() {
            return {
                step: 1,
                steps: ['Info', 'Details', 'Review'],
                title: '', description: '', price: '',
                next() {
                    if (this.step === 1 && (!this.title.trim() || !this.description.trim())) {
                        alert('Please fill in title and description'); return;
                    }
                    if (this.step < 3) this.step++;
                },
                prev() { if (this.step > 1) this.step--; }
            }
        }
    </script>
}
