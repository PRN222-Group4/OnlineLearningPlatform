@page
@model OnlineLearningPlatform.Presentation.Pages.Teacher.CreateCourseModel
@{
    Layout = "~/Pages/Teacher/_TeacherLayout.cshtml";
    ViewData["Title"] = "Create Course";
}

<div class="container">
    <div class="mb-4">
        <h2>Create Course</h2>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post" enctype="multipart/form-data" class="row g-3">
        <div class="col-12">
            <label asp-for="Request.Title" class="form-label">Title</label>
            <input asp-for="Request.Title" class="form-control" />
            <span asp-validation-for="Request.Title" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="Request.Description" class="form-label">Description</label>
            <textarea asp-for="Request.Description" class="form-control" rows="5"></textarea>
            <span asp-validation-for="Request.Description" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Request.Price" class="form-label">Price (VND)</label>
            <input asp-for="Request.Price" class="form-control" />
            <span asp-validation-for="Request.Price" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Request.Level" class="form-label">Level</label>
            <select asp-for="Request.Level" class="form-select">
                <option value="0">Beginner</option>
                <option value="1">Intermediate</option>
                <option value="2">Advanced</option>
            </select>
        </div>

        <div class="col-md-4">
            <label asp-for="Request.ImageFile" class="form-label">Image</label>
            <input asp-for="Request.ImageFile" type="file" class="form-control" />
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">Create course</button>
            <a asp-page="/Teacher/Dashboard" class="btn btn-outline-secondary ms-2">Cancel</a>
        </div>
    </form>

</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
