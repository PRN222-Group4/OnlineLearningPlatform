@page
@model OnlineLearningPlatform.Presentation.Pages.Admin.Courses.PendingModel
@{
    ViewData["Title"] = "Pending Course Reviews";
}

<div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-bold text-zinc-900 tracking-tight">Pending Reviews</h1>
            <p class="text-sm text-zinc-500 mt-1">Review and approve or reject instructor-submitted courses</p>
        </div>
        <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-amber-50 border border-amber-100">
            <i class="fas fa-clock text-amber-500"></i>
            <span class="text-sm font-semibold text-amber-700">@Model.PendingCourses.Count pending</span>
        </div>
    </div>

    @if (!Model.PendingCourses.Any())
    {
        <div class="bg-white rounded-2xl shadow-sm border border-zinc-100 p-16 text-center">
            <div class="w-16 h-16 rounded-full bg-emerald-50 text-emerald-400 flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-check-double text-2xl"></i>
            </div>
            <h3 class="text-lg font-bold text-zinc-900">All caught up!</h3>
            <p class="text-sm text-zinc-500 mt-1">There are no courses pending review at the moment.</p>
        </div>
    }
    else
    {
        <div class="grid gap-4">
            @foreach (var course in Model.PendingCourses)
            {
                var levelLabels = new[] { "Beginner", "Intermediate", "Advanced", "All Levels" };
                var levelLabel = course.Level >= 0 && course.Level < levelLabels.Length ? levelLabels[course.Level] : "Unknown";

                <div class="bg-white rounded-2xl shadow-sm border border-zinc-100 overflow-hidden hover:shadow-md transition-shadow group">
                    <div class="flex">
                        <div class="w-48 shrink-0 bg-zinc-100">
                            @if (!string.IsNullOrEmpty(course.Image))
                            {
                                <img src="@course.Image" alt="@course.Title" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center text-zinc-300 min-h-[120px]">
                                    <i class="fas fa-image text-3xl"></i>
                                </div>
                            }
                        </div>

                        <div class="flex-1 p-5">
                            <div class="flex items-start justify-between">
                                <div class="flex-1">
                                    <h3 class="font-bold text-zinc-900 text-lg group-hover:text-indigo-600 transition-colors">
                                        @course.Title
                                    </h3>
                                    @if (!string.IsNullOrEmpty(course.Subtitle))
                                    {
                                        <p class="text-sm text-zinc-500 mt-0.5">@course.Subtitle</p>
                                    }
                                </div>
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 text-amber-600 text-xs font-bold border border-amber-100">
                                    <i class="fas fa-clock text-[10px]"></i> Pending
                                </span>
                            </div>

                            <div class="flex items-center gap-4 mt-3 text-xs text-zinc-500">
                                <span class="flex items-center gap-1.5">
                                    <i class="fas fa-signal w-3 text-center"></i> @levelLabel
                                </span>
                                <span class="flex items-center gap-1.5">
                                    <i class="fas fa-tag w-3 text-center"></i> @course.Price.ToString("N0") VND
                                </span>
                                @if (course.SubmittedAt.HasValue)
                                {
                                    <span class="flex items-center gap-1.5">
                                        <i class="far fa-calendar w-3 text-center"></i> Submitted @course.SubmittedAt.Value.ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                }
                            </div>

                            <div class="flex items-center justify-end mt-4">
                                <a asp-page="/Admin/Courses/Review" asp-route-courseId="@course.CourseId"
                                   class="inline-flex items-center gap-2 px-5 py-2 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 shadow-sm transition">
                                    <i class="fas fa-eye text-xs"></i> Review
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const levelLabels = ['Beginner', 'Intermediate', 'Advanced', 'All Levels'];

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/realtimeHub")
            .withAutomaticReconnect()
            .build();

        connection.on("NewPendingCourse", (data) => {
            showToast(`📚 New course: "${data.title}"`, 'amber');
            setTimeout(() => refreshPendingList(), 1500);
        });

        connection.on("CourseStatusChanged", () => {
            showToast('Course status updated', 'indigo');
            setTimeout(() => refreshPendingList(), 1000);
        });

        connection.start()
            .then(() => connection.invoke("JoinAdminGroup").catch(console.error))
            .catch(err => console.error("SignalR error:", err));

        async function refreshPendingList() {
            try {
                const resp = await fetch('/Admin/Courses/Pending?handler=PendingJson');
                const courses = await resp.json();

                document.querySelector('.text-amber-700').textContent = `${courses.length} pending`;

                const container = document.querySelector('.max-w-6xl');
                if (!container) { location.reload(); return; }

                if (courses.length === 0) {
                    // Xóa grid nếu có, show empty state
                    const grid = container.querySelector('.grid');
                    if (grid) {
                        grid.outerHTML = `
                            <div class="bg-white rounded-2xl shadow-sm border border-zinc-100 p-16 text-center">
                                <div class="w-16 h-16 rounded-full bg-emerald-50 text-emerald-400 flex items-center justify-center mx-auto mb-4">
                                    <i class="fas fa-check-double text-2xl"></i>
                                </div>
                                <h3 class="text-lg font-bold text-zinc-900">All caught up!</h3>
                                <p class="text-sm text-zinc-500 mt-1">There are no courses pending review at the moment.</p>
                            </div>`;
                    }
                    return;
                }

                let grid = container.querySelector('.grid');
                if (!grid) {
                    // Nếu đang ở empty state thì tạo grid mới
                    const emptyDiv = container.querySelector('.bg-white.rounded-2xl');
                    if (emptyDiv) {
                        emptyDiv.outerHTML = `<div class="grid gap-4"></div>`;
                        grid = container.querySelector('.grid');
                    }
                }
                if (!grid) { location.reload(); return; }

                grid.innerHTML = courses.map(c => `
                    <div class="bg-white rounded-2xl shadow-sm border border-zinc-100 overflow-hidden hover:shadow-md transition-shadow group">
                        <div class="flex">
                            <div class="w-48 shrink-0 bg-zinc-100">
                                ${c.image
                                    ? `<img src="${c.image}" alt="${c.title}" class="w-full h-full object-cover" />`
                                    : `<div class="w-full h-full flex items-center justify-center text-zinc-300 min-h-[120px]"><i class="fas fa-image text-3xl"></i></div>`}
                            </div>
                            <div class="flex-1 p-5">
                                <div class="flex items-start justify-between">
                                    <div class="flex-1">
                                        <h3 class="font-bold text-zinc-900 text-lg group-hover:text-indigo-600 transition-colors">${c.title}</h3>
                                        ${c.subtitle ? `<p class="text-sm text-zinc-500 mt-0.5">${c.subtitle}</p>` : ''}
                                    </div>
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 text-amber-600 text-xs font-bold border border-amber-100">
                                        <i class="fas fa-clock text-[10px]"></i> Pending
                                    </span>
                                </div>
                                <div class="flex items-center gap-4 mt-3 text-xs text-zinc-500">
                                    <span class="flex items-center gap-1.5"><i class="fas fa-signal w-3 text-center"></i> ${levelLabels[c.level] || 'Unknown'}</span>
                                    <span class="flex items-center gap-1.5"><i class="fas fa-tag w-3 text-center"></i> ${c.price.toLocaleString('vi-VN')} VND</span>
                                    ${c.submittedAt ? `<span class="flex items-center gap-1.5"><i class="far fa-calendar w-3 text-center"></i> ${new Date(c.submittedAt).toLocaleDateString('vi-VN')}</span>` : ''}
                                </div>
                                <div class="flex items-center justify-end mt-4">
                                    <a href="/Admin/Courses/Review/${c.courseId}" class="inline-flex items-center gap-2 px-5 py-2 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 shadow-sm transition">
                                        <i class="fas fa-eye text-xs"></i> Review
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>`).join('');
            } catch(e) {
                console.error('Refresh failed:', e);
                location.reload();
            }
        }

        function showToast(message, color) {
            const colors = {
                amber: 'bg-amber-50 border-amber-200 text-amber-700',
                indigo: 'bg-indigo-50 border-indigo-200 text-indigo-700'
            };
            const toast = document.createElement('div');
            toast.className = `fixed top-5 right-5 z-[200] flex items-center gap-3 px-5 py-3 rounded-xl shadow-lg border text-sm font-medium ${colors[color]} transition-all`;
            toast.innerHTML = `<i class="fas fa-bell"></i> ${message}`;
            document.body.appendChild(toast);
            setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 4000);
        }
    </script>
}
