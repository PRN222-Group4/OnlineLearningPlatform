@page "{id:guid}"
@model OnlineLearningPlatform.Presentation.Pages.Admin.CoursesEditModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Admin - Edit Course";
}

<div class="container-fluid">
    <h3>Edit Course</h3>
    <form method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Request.CourseId" />
        <div class="mb-3">
            <label class="form-label">Title</label>
            <input class="form-control" asp-for="Request.Title" />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea class="form-control" asp-for="Request.Description"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Price</label>
            <input class="form-control" asp-for="Request.Price" />
        </div>
        <button class="btn btn-primary" type="submit">Save</button>
    </form>
</div>