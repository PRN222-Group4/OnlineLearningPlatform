@page
@model OnlineLearningPlatform.Presentation.Pages.Admin.OverviewModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Admin Overview";
}

<!-- ══════════════ STAT CARDS ══════════════ -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">

    <!-- Total Users -->
    <div class="bg-white rounded-xl border border-zinc-200 p-6 hover:shadow-md transition-shadow duration-300">
        <div class="flex items-center justify-between mb-4">
            <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wider">Total Users</p>
            <div class="w-11 h-11 bg-indigo-100 rounded-xl flex items-center justify-center">
                <i class="fas fa-users text-indigo-600 text-lg"></i>
            </div>
        </div>
        <div class="text-3xl font-bold text-zinc-900 mb-1" id="statUsers">@Model.TotalUsers.ToString("N0")</div>
        <div class="flex items-center text-xs text-zinc-400 mt-1">
            <i class="fas fa-circle text-[6px] mr-1.5"></i>
            Registered accounts
        </div>
    </div>

    <!-- Total Revenue -->
    <div class="bg-white rounded-xl border border-zinc-200 p-6 hover:shadow-md transition-shadow duration-300">
        <div class="flex items-center justify-between mb-4">
            <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wider">Total Revenue</p>
            <div class="w-11 h-11 bg-emerald-100 rounded-xl flex items-center justify-center">
                <i class="fas fa-money-bill-wave text-emerald-600 text-lg"></i>
            </div>
        </div>
        <div class="text-3xl font-bold text-zinc-900 mb-1" id="statRevenue">@Model.TotalRevenue.ToString("N0")<span class="text-base font-medium text-zinc-400 ml-1">₫</></div>
        <div class="flex items-center text-xs text-zinc-400 mt-1">
            <i class="fas fa-circle text-[6px] mr-1.5"></i>
            From all payments
        </div>
    </div>

    <!-- Total Courses -->
    <div class="bg-white rounded-xl border border-zinc-200 p-6 hover:shadow-md transition-shadow duration-300">
        <div class="flex items-center justify-between mb-4">
            <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wider">Total Courses</p>
            <div class="w-11 h-11 bg-amber-100 rounded-xl flex items-center justify-center">
                <i class="fas fa-book-open text-amber-600 text-lg"></i>
            </div>
        </div>
        <div class="text-3xl font-bold text-zinc-900 mb-1" id="statCourses">@Model.TotalCourses.ToString("N0")</div>
        <div class="flex items-center text-xs text-zinc-400 mt-1">
            <i class="fas fa-circle text-[6px] mr-1.5"></i>
            Published & pending
        </div>
    </div>

    <!-- Enrollments -->
    <div class="bg-white rounded-xl border border-zinc-200 p-6 hover:shadow-md transition-shadow duration-300">
        <div class="flex items-center justify-between mb-4">
            <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wider">Enrollments</p>
            <div class="w-11 h-11 bg-blue-100 rounded-xl flex items-center justify-center">
                <i class="fas fa-graduation-cap text-blue-600 text-lg"></i>
            </div>
        </div>
        <div class="text-3xl font-bold text-zinc-900 mb-1" id="statEnrollments">@Model.TotalEnrollments.ToString("N0")</div>
        <div class="flex items-center text-xs text-zinc-400 mt-1">
            <i class="fas fa-circle text-[6px] mr-1.5"></i>
            Total enrollments
        </div>
    </div>
</div>

<!-- ══════════════ TOP STATS ROW ══════════════ -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

    <!-- Top Course -->
    <div class="bg-white rounded-xl border border-zinc-200 p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 bg-amber-100 rounded-lg flex items-center justify-center shrink-0">
                <i class="fas fa-trophy text-amber-500 text-sm"></i>
            </div>
            <h3 class="text-sm font-semibold text-zinc-700 uppercase tracking-wider">Top Course by Enrollments</h3>
        </div>
        @if (!string.IsNullOrEmpty(Model.TopCourseTitle))
        {
            <p class="text-base font-bold text-zinc-900 mb-1 truncate">@Model.TopCourseTitle</p>
            <div class="flex items-center gap-2 mt-2">
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-700">
                    <i class="fas fa-user-graduate text-[10px]"></i>
                    @Model.TopCourseEnrolls enrollments
                </span>
            </div>
        }
        else
        {
            <p class="text-sm text-zinc-400 italic">No data available</p>
        }
    </div>

    <!-- Top Instructor -->
    <div class="bg-white rounded-xl border border-zinc-200 p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 bg-indigo-100 rounded-lg flex items-center justify-center shrink-0">
                <i class="fas fa-chalkboard-teacher text-indigo-500 text-sm"></i>
            </div>
            <h3 class="text-sm font-semibold text-zinc-700 uppercase tracking-wider">Top Instructor by Students</h3>
        </div>
        @if (!string.IsNullOrEmpty(Model.TopInstructorName))
        {
            <p class="text-base font-bold text-zinc-900 mb-1">@Model.TopInstructorName</p>
            <div class="flex items-center gap-2 mt-2">
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-indigo-100 text-indigo-700">
                    <i class="fas fa-users text-[10px]"></i>
                    @Model.TopInstructorStudents students
                </span>
            </div>
        }
        else
        {
            <p class="text-sm text-zinc-400 italic">No data available</p>
        }
    </div>
</div>

<!-- ══════════════ RECENT PAYMENTS TABLE ══════════════ -->
<div class="bg-white rounded-xl border border-zinc-200 overflow-hidden">

    <!-- Table Header -->
    <div class="px-6 py-4 border-b border-zinc-100 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-zinc-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-receipt text-zinc-500 text-sm"></i>
            </div>
            <h2 class="text-base font-semibold text-zinc-900">Recent Payments</h2>
        </div>
        <span class="text-xs text-zinc-400 font-medium">
            @(Model.RecentPayments?.Count ?? 0) records
        </span>
    </div>

    <!-- Table -->
    @if (Model.RecentPayments != null && Model.RecentPayments.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-zinc-50 border-b border-zinc-100">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider">Payment</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider">Student</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider">Course</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider">Amount</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider">Dates</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-zinc-100">
                    @foreach (var p in Model.RecentPayments)
                    {
                        <tr class="hover:bg-zinc-50 transition-colors duration-150">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-zinc-500">
                                <div class="text-xs font-semibold text-zinc-700">#@p.PaymentId.ToString().Substring(0, 8)</div>
                                <div class="text-[11px] text-zinc-400">Order @p.OrderCode</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-2.5">
                                    <div class="w-7 h-7 rounded-full bg-indigo-100 flex items-center justify-center shrink-0">
                                        <i class="fas fa-user text-indigo-400 text-[10px]"></i>
                                    </div>
                                    <div>
                                        <div class="text-sm font-medium text-zinc-800">@(p.StudentName ?? "Unknown")</div>
                                        <div class="text-[11px] text-zinc-400">@(p.UserEmail ?? "—")</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-zinc-700">
                                @(p.CourseTitle ?? "—")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="text-sm font-semibold text-zinc-900">@p.Amount.ToString("N0") ₫</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (p.Status == 1)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-700">
                                        <i class="fas fa-check text-[9px]"></i> Paid
                                    </span>
                                }
                                else if (p.Status == 2)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-700">
                                        <i class="fas fa-clock text-[9px]"></i> Pending
                                    </span>
                                }
                                else if (p.Status == 0)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-rose-100 text-rose-700">
                                        <i class="fas fa-times text-[9px]"></i> Failed
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-zinc-100 text-zinc-600">
                                        <i class="fas fa-ban text-[9px]"></i> Expired
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-[11px] text-zinc-500 leading-5">
                                <div>Created: @p.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                <div>Paid: @(p.PaidAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
                                <div>Expired: @(p.ExpiredAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="px-6 py-12 text-center">
            <div class="w-12 h-12 bg-zinc-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <i class="fas fa-inbox text-zinc-400 text-xl"></i>
            </div>
            <p class="text-sm text-zinc-400 font-medium">No payments yet</p>
        </div>
    }
</div>
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/realtimeHub")
            .withAutomaticReconnect()
            .build();

        connection.start()
            .then(() => {
                connection.invoke("JoinAdminGroup").catch(err => console.error(err));
            })
            .catch(err => console.error("SignalR error:", err));

        connection.on("NewPendingCourse", (data) => {
            showToast(`📚 New course submitted: "${data.title}"`, 'amber');
            refreshStats();
        });

        connection.on("CourseStatusChanged", () => {
            refreshStats();
        });

        connection.on("WalletUpdated", (data) => {
            showToast(`💰 New enrollment! ${data?.studentEmail ?? ''}`, 'emerald');
            refreshStats();
            if (data?.studentEmail) prependPaymentRow(data);
        });

        async function refreshStats() {
            try {
                const resp = await fetch('/Admin/Overview?handler=StatsJson');
                const data = await resp.json();
                document.getElementById('statUsers').firstChild.textContent = data.totalUsers.toLocaleString('vi-VN');
                document.getElementById('statCourses').firstChild.textContent = data.totalCourses.toLocaleString('vi-VN');
                document.getElementById('statEnrollments').firstChild.textContent = data.totalEnrollments.toLocaleString('vi-VN');
                document.getElementById('statRevenue').firstChild.textContent = data.totalRevenue.toLocaleString('vi-VN');
            } catch(e) {
                console.error('Refresh stats failed:', e);
            }
        }

        function prependPaymentRow(data) {
            const tbody = document.querySelector('tbody');
            if (!tbody) return;

            const now = new Date();
            const timeStr = now.toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric' })
                + ' ' + now.toLocaleTimeString('vi-VN', { hour:'2-digit', minute:'2-digit' });

            const tr = document.createElement('tr');
            tr.className = 'hover:bg-zinc-50 transition-colors duration-150 bg-emerald-50';
            tr.innerHTML = `
                <td class="px-6 py-4 whitespace-nowrap text-sm text-zinc-500">
                    <div class="text-xs font-semibold text-zinc-700">NEW</div>
                    <div class="text-[11px] text-zinc-400">Just now</div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center gap-2.5">
                        <div class="w-7 h-7 rounded-full bg-indigo-100 flex items-center justify-center shrink-0">
                            <i class="fas fa-user text-indigo-400 text-[10px]"></i>
                        </div>
                        <div>
                            <div class="text-sm font-medium text-zinc-800">—</div>
                            <div class="text-[11px] text-zinc-400">${data.studentEmail}</div>
                        </div>
                    </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-zinc-700">${data.courseTitle ?? '—'}</td>
                <td class="px-6 py-4 whitespace-nowrap">
                    <span class="text-sm font-semibold text-emerald-600">+${Number(data.amount).toLocaleString('vi-VN')} ₫</span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-700">
                        <i class="fas fa-check text-[9px]"></i> Paid
                    </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-[11px] text-zinc-500 leading-5">
                    <div>Created: ${timeStr}</div>
                    <div>Paid: ${timeStr}</div>
                </td>`;

            tbody.insertBefore(tr, tbody.firstChild);

            // Xóa row cuối nếu quá 10
            const rows = tbody.querySelectorAll('tr');
            if (rows.length > 10) rows[rows.length - 1].remove();

            // Fade out highlight sau 4s
            setTimeout(() => tr.classList.remove('bg-emerald-50'), 4000);
        }

        function showToast(message, color) {
            const colors = {
                amber: 'bg-amber-50 border-amber-200 text-amber-700',
                indigo: 'bg-indigo-50 border-indigo-200 text-indigo-700',
                emerald: 'bg-emerald-50 border-emerald-200 text-emerald-700'
            };
            const toast = document.createElement('div');
            toast.className = `fixed top-5 right-5 z-[200] flex items-center gap-3 px-5 py-3 rounded-xl shadow-lg border text-sm font-medium ${colors[color] || colors.indigo} transition-all`;
            toast.innerHTML = `<i class="fas fa-bell"></i> ${message}`;
            document.body.appendChild(toast);
            setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 4000);
        }
    </script>
}