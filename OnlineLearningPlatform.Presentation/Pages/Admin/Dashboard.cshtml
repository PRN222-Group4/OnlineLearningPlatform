//     'revenueChart',
//     'enrollmentChart',
//     'roleChart',
//     'topCoursesChart'
// ];

// const observer = new ResizeObserver(() => {
//     charts.forEach(id => {
//         const chart = echarts.getInstanceByDom(document.getElementById(id));
//         chart?.resize();
//     });
// });

// observer.observe(document.body);
