<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    @{
        var totalRevenue = Model.Data.RevenueData.Sum();
        var totalEnrolls = Model.Data.EnrollmentData.Sum();
        var totalUsers = Model.Data.AdminCount + Model.Data.InstructorCount + Model.Data.StudentCount;
        var topEnrolls = Model.Data.TopCourseEnrolls.Any() ? Model.Data.TopCourseEnrolls.Max() : 0;

        string GrowthBadge(decimal? growth)
        {
            if (growth == null) return "<span class='text-xs text-zinc-400'>No prev data</span>";
            var color = growth >= 0 ? "text-emerald-600 bg-emerald-50" : "text-rose-600 bg-rose-50";
            var icon = growth >= 0 ? "fa-arrow-up" : "fa-arrow-down";
            return $"<span class='inline-flex items-center gap-1 text-xs font-bold px-2 py-0.5 rounded-full {color}'><i class='fas {icon} text-[10px]'></i>{Math.Abs(growth.Value)}%</span>";
        }
    }

    <div class="bg-white rounded-xl border border-zinc-200 px-5 py-4 flex items-center gap-4">
        <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center shrink-0">
            <i class="fas fa-money-bill-wave text-emerald-600"></i>
        </div>
        <div>
            <p class="text-xs text-zinc-400 font-medium">Gross Revenue</p>
            <p class="text-lg font-bold text-zinc-900">@totalRevenue.ToString("N0") ₫</p>
            @Html.Raw(GrowthBadge(Model.Data.RevenueGrowth))
        </div>
    </div>

    <div class="bg-white rounded-xl border border-zinc-200 px-5 py-4 flex items-center gap-4">
        <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center shrink-0">
            <i class="fas fa-graduation-cap text-blue-600"></i>
        </div>
        <div>
            <p class="text-xs text-zinc-400 font-medium">Total Enrollments</p>
            <p class="text-lg font-bold text-zinc-900">@totalEnrolls.ToString("N0")</p>
            @Html.Raw(GrowthBadge(Model.Data.EnrollmentGrowth))
        </div>
    </div>

    <div class="bg-white rounded-xl border border-zinc-200 px-5 py-4 flex items-center gap-4">
        <div class="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center shrink-0">
            <i class="fas fa-users text-indigo-600"></i>
        </div>
        <div>
            <p class="text-xs text-zinc-400 font-medium">Total Users</p>
            <p class="text-lg font-bold text-zinc-900">@totalUsers.ToString("N0")</p>
            <span class="text-xs text-zinc-400">All time</span>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-zinc-200 px-5 py-4 flex items-center gap-4">
        <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center shrink-0">
            <i class="fas fa-trophy text-amber-600"></i>
        </div>
        <div>
            <p class="text-xs text-zinc-400 font-medium">Top Course Enrolls</p>
            <p class="text-lg font-bold text-zinc-900">@topEnrolls.ToString("N0")</p>
            <span class="text-xs text-zinc-400">All time</span>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

    <div class="bg-white rounded-xl border border-zinc-200 p-6">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-chart-line text-emerald-600 text-sm"></i>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-zinc-900">Financial Growth</h3>
                    <p class="text-xs text-zinc-400">Gross vs Net vs Instructors — @Model.Year</p>
                </div>
            </div>
            <div class="hidden sm:flex items-center gap-3 text-[10px] font-bold uppercase text-zinc-500">
                <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-emerald-500"></span> Gross</span>
                <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-indigo-500"></span> Net (30%)</span>
                <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-amber-500"></span> Instructors</span>
            </div>
        </div>
        <div id="revenueChart" style="height: 300px; width: 100%;"></div>
    </div>

    <div class="bg-white rounded-xl border border-zinc-200 p-6">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-chart-bar text-blue-600 text-sm"></i>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-zinc-900">Enrollments</h3>
                    <p class="text-xs text-zinc-400">Monthly new enrollments — @Model.Year</p>
                </div>
            </div>
        </div>
        <div id="enrollmentChart" style="height: 300px; width: 100%;"></div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <div class="bg-white rounded-xl border border-zinc-200 p-6 overflow-hidden min-h-0">
        <div class="flex items-center gap-2 mb-4">
            <div class="w-8 h-8 bg-indigo-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-chart-pie text-indigo-600 text-sm"></i>
            </div>
            <div>
                <h3 class="text-sm font-semibold text-zinc-900">User Distribution</h3>
                <p class="text-xs text-zinc-400">By role — all time</p>
            </div>
        </div>
        <div id="roleChart" style="height: 260px; width: 100%;"></div>
        <div class="flex justify-center gap-5 mt-3">
            <div class="flex items-center gap-1.5 text-xs text-zinc-500">
                <span class="w-2.5 h-2.5 rounded-full bg-rose-400 inline-block"></span> Admin (@Model.Data.AdminCount)
            </div>
            <div class="flex items-center gap-1.5 text-xs text-zinc-500">
                <span class="w-2.5 h-2.5 rounded-full bg-amber-400 inline-block"></span> Instructor (@Model.Data.InstructorCount)
            </div>
            <div class="flex items-center gap-1.5 text-xs text-zinc-500">
                <span class="w-2.5 h-2.5 rounded-full bg-indigo-400 inline-block"></span> Student (@Model.Data.StudentCount)
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-zinc-200 p-6 overflow-hidden min-h-0">
        <div class="flex items-center gap-2 mb-4">
            <div class="w-8 h-8 bg-amber-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-trophy text-amber-600 text-sm"></i>
            </div>
            <div>
                <h3 class="text-sm font-semibold text-zinc-900">Top 5 Courses</h3>
                <p class="text-xs text-zinc-400">By number of enrollments — all time</p>
            </div>
        </div>
        <div id="topCoursesChart" style="height: 260px; width: 100%;"></div>
    </div>
</div>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
    <!-- Top Instructors by Revenue -->
    <div class="bg-white rounded-xl border border-zinc-200 p-6 overflow-hidden">
        <div class="flex items-center gap-2 mb-4">
            <div class="w-8 h-8 bg-purple-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-chalkboard-teacher text-purple-600 text-sm"></i>
            </div>
            <div>
                <h3 class="text-sm font-semibold text-zinc-900">Top Instructors</h3>
                <p class="text-xs text-zinc-400">By revenue — selected period</p>
            </div>
        </div>
        <div id="topInstructorsChart" style="height: 260px; width: 100%;"></div>
    </div>

    <!-- Top Courses by Revenue -->
    <div class="bg-white rounded-xl border border-zinc-200 p-6 overflow-hidden">
        <div class="flex items-center gap-2 mb-4">
            <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-money-bill-wave text-emerald-600 text-sm"></i>
            </div>
            <div>
                <h3 class="text-sm font-semibold text-zinc-900">Top Courses by Revenue</h3>
                <p class="text-xs text-zinc-400">Highest earning courses — selected period</p>
            </div>
        </div>
        <div id="topCourseRevenueChart" style="height: 260px; width: 100%;"></div>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
        <div class="bg-white rounded-xl border border-zinc-200 p-6 overflow-hidden">
            <div class="flex items-center gap-2 mb-4">
                <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-user-graduate text-blue-600 text-sm"></i>
                </div>
                <div>
                    <h3 class="text-sm font-semibold text-zinc-900">Top Instructors by Students</h3>
                    <p class="text-xs text-zinc-400">Most enrolled instructors — all time</p>
                </div>
            </div>
            <div id="topInstructorEnrollChart" style="height: 260px; width: 100%;"></div>
        </div>
    </div>
    <div class="bg-white rounded-xl border border-zinc-200 p-6 overflow-hidden">
        <div class="flex items-center gap-2 mb-4">
            <div class="w-8 h-8 bg-rose-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-user-plus text-rose-600 text-sm"></i>
            </div>
            <div>
                <h3 class="text-sm font-semibold text-zinc-900">User Growth</h3>
                <p class="text-xs text-zinc-400">New registrations vs same period last year</p>
            </div>
        </div>
        <div id="userGrowthChart" style="height: 260px; width: 100%;"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
    <script>

        const userGrowthData     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.UserGrowthData));
        const prevUserGrowthData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.PrevUserGrowthData));
        const topInstructorEnrollNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.TopInstructorEnrollNames));
        const topInstructorEnrollData  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.TopInstructorEnrollData));
        const prevRevenueData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.PrevRevenueData));
        const prevEnrollData  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.PrevEnrollmentData));
        const prevLabel       = '@Model.Data.PrevPeriodLabel';
        const currentLabel    = '@(Model.Quarter.HasValue ? $"Q{Model.Quarter} {Model.Year}" : Model.Year.ToString())';

        const topInstructorNames   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.TopInstructorNames));
        const topInstructorRevenue = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.TopInstructorRevenue));
        const topCourseRevTitles   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.TopCourseRevenueTitle));
        const topCourseRevData     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.TopCourseRevenueData));
        // ── Data from server ──────────────────────────────────────────────────────
        const months      = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.RevenueMonths));
        const revenueData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.RevenueData));

        // TÍNH TOÁN ĐA ĐƯỜNG NGAY TRÊN JAVASCRIPT
        const netData = revenueData.map(v => v * 0.3);
        const instructorData = revenueData.map(v => v * 0.7);

        const enrollData  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.EnrollmentData));
        const roleData    = [
            { value: @Model.Data.AdminCount,      name: 'Admin' },
            { value: @Model.Data.InstructorCount, name: 'Instructor' },
            { value: @Model.Data.StudentCount,    name: 'Student' }
        ];
        const topTitles  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.TopCourseTitles));
        const topEnrolls = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.TopCourseEnrolls));

        // ── Shared style ──────────────────────────────────────────────────────────
        const tooltip = { trigger: 'axis', backgroundColor: '#fff', borderColor: '#e4e4e7', borderWidth: 1, textStyle: { color: '#3f3f46', fontSize: 12 } };
        const grid    = { left: 12, right: 12, top: 10, bottom: 6, containLabel: true };

        const xAxisBase = {
            type: 'category',
            data: months,
            axisLine: { lineStyle: { color: '#e4e4e7' } },
            axisLabel: { color: '#a1a1aa', fontSize: 10, interval: 0, rotate: 30 },
            splitLine: { show: false }
        };
        const yAxisBase = {
            type: 'value',
            axisLabel: { color: '#a1a1aa', fontSize: 10 },
            splitLine: { lineStyle: { color: '#f4f4f5', type: 'dashed' } },
            axisLine: { show: false }
        };

        // ── 1. UPGRADED Multi-line Revenue Chart ─────────────────────────────────────────────────
        echarts.init(document.getElementById('revenueChart')).setOption({
            tooltip: {
                trigger: 'axis',
                backgroundColor: '#fff',
                borderColor: '#e4e4e7',
                borderWidth: 1,
                textStyle: { color: '#3f3f46', fontSize: 12 },
                formatter: function(params) {
                    let res = `<div class="font-bold mb-1">${params[0].name}</div>`;
                    params.forEach(p => {
                        res += `<div class="flex justify-between gap-4">
                                  <span><span style="display:inline-block;margin-right:4px;border-radius:10px;width:10px;height:10px;background-color:${p.color};"></span>${p.seriesName}</span>
                                  <span class="font-bold">${Number(p.value).toLocaleString('vi-VN')} ₫</span>
                                </div>`;
                    });
                    return res;
                }
            },
            grid,
            xAxis: xAxisBase,
            yAxis: { ...yAxisBase, axisLabel: { ...yAxisBase.axisLabel, formatter: v => v >= 1000000 ? (v/1000000).toFixed(1)+'M' : v >= 1000 ? (v/1000).toFixed(0)+'K' : v } },
                    series: [
            {
                name: `Gross ${currentLabel}`,
                data: revenueData, type: 'line', smooth: true,
                symbol: 'circle', symbolSize: 6,
                lineStyle: { color: '#10b981', width: 3 },
                itemStyle: { color: '#10b981', borderColor: '#fff', borderWidth: 2 }
            },
            {
                name: `Net ${currentLabel} (30%)`,
                data: netData, type: 'line', smooth: true,
                symbol: 'circle', symbolSize: 6,
                lineStyle: { color: '#6366f1', width: 2.5, type: 'dashed' },
                itemStyle: { color: '#6366f1', borderColor: '#fff', borderWidth: 2 }
            },
            {
                name: `Gross ${prevLabel}`,
                data: prevRevenueData.map(v => v), type: 'line', smooth: true,
                symbol: 'circle', symbolSize: 5,
                lineStyle: { color: '#10b981', width: 1.5, type: 'dotted', opacity: 0.6 },
                itemStyle: { color: '#10b981', opacity: 0.5 }
            }
        ]
        });

        echarts.init(document.getElementById('enrollmentChart')).setOption({
            tooltip: { ...tooltip, formatter: p => `${p[0].name}<br/><b>${p[0].value} enrollments</b>` },
            grid,
            xAxis: xAxisBase,
            yAxis: { ...yAxisBase, minInterval: 1 },
                    series: [
            {
                name: currentLabel,
                data: enrollData, type: 'bar', barMaxWidth: '30%', borderRadius: [6, 6, 0, 0],
