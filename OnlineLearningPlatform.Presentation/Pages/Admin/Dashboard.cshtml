        //     'enrollmentChart',
        //     'roleChart',
        //     'topCoursesChart'
        // ];

        // const resizeObserver = new ResizeObserver(() => {
        //     chartIds.forEach(id => {
        //         const el = document.getElementById(id);
        //         const chart = echarts.getInstanceByDom(el);
        //         chart?.resize();
        //     });
        // });

       
        // resizeObserver.observe(document.querySelector('.main-content') || document.body);
    </script>
}
