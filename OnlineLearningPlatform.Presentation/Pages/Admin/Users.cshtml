@page
@model OnlineLearningPlatform.Presentation.Pages.Admin.UsersModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Users Management";

    string RoleBadge(string role) => role switch
    {
        "Admin"      => "bg-rose-100 text-rose-700",
        "Instructor" => "bg-amber-100 text-amber-700",
        _            => "bg-emerald-100 text-emerald-700"
    };
    string AvatarBg(string role) => role switch
    {
        "Admin"      => "bg-rose-500",
        "Instructor" => "bg-amber-500",
        _            => "bg-indigo-500"
    };
}

<!-- ══════ TOAST ══════ -->
@if (!string.IsNullOrEmpty(Model.ToastMessage))
{
    <div id="toast"
         class="fixed top-5 right-5 z-[100] flex items-center gap-3 px-5 py-3 rounded-xl shadow-lg border text-sm font-medium
                @(Model.ToastType == "success" ? "bg-emerald-50 border-emerald-200 text-emerald-700" : "bg-red-50 border-red-200 text-red-700")">
        <i class="fas @(Model.ToastType == "success" ? "fa-check-circle text-emerald-500" : "fa-times-circle text-red-500")"></i>
        @Model.ToastMessage
    </div>
    <script>setTimeout(() => document.getElementById('toast')?.remove(), 3000);</script>
}

<!-- ══════ MAIN CARD ══════ -->
<div class="bg-white rounded-xl border border-zinc-200 overflow-hidden">

    <!-- Header -->
    <div class="px-6 py-4 border-b border-zinc-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div class="flex items-center gap-3">
            <div class="w-9 h-9 bg-indigo-100 rounded-lg flex items-center justify-center shrink-0">
                <i class="fas fa-users text-indigo-600 text-sm"></i>
            </div>
            <div>
                <h2 class="text-base font-semibold text-zinc-900">Users Management</h2>
                <p class="text-xs text-zinc-400">@Model.Data.TotalCount total users</p>
            </div>
        </div>
    </div>

    <!-- Search & Filter -->
    <div class="px-6 py-3 bg-zinc-50 border-b border-zinc-100">
        <form method="get" class="flex flex-wrap gap-3">
            <div class="relative flex-1 min-w-[200px]">
                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-zinc-400 text-xs"></i>
                <input type="text" name="Search" value="@Model.Search" placeholder="Search name or email..."
                       class="w-full pl-8 pr-4 py-2 text-sm border border-zinc-200 rounded-lg bg-white text-zinc-800 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-indigo-300 transition" />
            </div>
            <select name="Role"
                    class="px-3 py-2 text-sm border border-zinc-200 rounded-lg bg-white text-zinc-700 focus:outline-none focus:ring-2 focus:ring-indigo-300 transition">
                <option value="all"        selected="@(string.IsNullOrEmpty(Model.Role) || Model.Role == "all")">All Roles</option>
                <option value="Admin"      selected="@(Model.Role == "Admin")">Admin</option>
                <option value="Instructor" selected="@(Model.Role == "Instructor")">Instructor</option>
                <option value="Student"    selected="@(Model.Role == "Student")">Student</option>
            </select>
            <input type="hidden" name="PageIndex" value="1" />
            <button type="submit"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors">
                <i class="fas fa-search text-xs"></i> Search
            </button>
            @if (!string.IsNullOrEmpty(Model.Search) || (!string.IsNullOrEmpty(Model.Role) && Model.Role != "all"))
            {
                <a asp-page="/Admin/Users"
                   class="inline-flex items-center gap-2 px-4 py-2 bg-zinc-100 text-zinc-600 text-sm font-medium rounded-lg hover:bg-zinc-200 transition-colors">
                    <i class="fas fa-times text-xs"></i> Clear
                </a>
            }
        </form>
    </div>

    <!-- Table -->
    @if (Model.Data.Users.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-zinc-50 border-b border-zinc-100">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider">User</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider">Email</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider">Role</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider">Registered</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-zinc-100">
                    @foreach (var user in Model.Data.Users)
                    {
                        <tr class="hover:bg-zinc-50 transition-colors duration-150">

                            <!-- Avatar + Name -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                    @if (!string.IsNullOrEmpty(user.Image))
                                    {
                                        <img src="@user.Image" alt="@user.FullName"
                                             class="w-9 h-9 rounded-full object-cover border border-zinc-200 shrink-0" />
                                    }
                                    else
                                    {
                                        <div class="w-9 h-9 rounded-full @AvatarBg(user.RoleName) flex items-center justify-center text-white font-semibold text-xs shrink-0">
                                            @user.Initials
                                        </div>
                                    }
                                    <div>
                                        <p class="text-sm font-semibold text-zinc-900">@user.FullName</p>
                                        @if (!string.IsNullOrEmpty(user.Title))
                                        {
                                            <p class="text-xs text-zinc-400">@user.Title</p>
                                        }
                                    </div>
                                </div>
                            </td>

                            <!-- Email -->
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-zinc-500">@user.Email</td>

                            <!-- Role -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold @RoleBadge(user.RoleName)">
                                    @user.RoleName
                                </span>
                            </td>

                            <!-- Status (Verified = active, !Verified = banned) -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (user.IsVerified)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-700">
                                        <i class="fas fa-check text-[9px]"></i> Active
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-600">
                                        <i class="fas fa-ban text-[9px]"></i> Banned
                                    </span>
                                }
                            </td>

                            <!-- Registered -->
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-zinc-500">
                                @user.CreatedAt.ToString("dd/MM/yyyy")
                            </td>

                            <!-- Actions -->
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-2">
                                    <!-- View Detail -->
                                    <button type="button"
                                            onclick="openViewModal('@user.UserId','@user.FullName','@user.Email','@user.RoleName','@(user.IsVerified ? "Active" : "Banned")','@user.PhoneNumber','@user.Title','@user.Bio','@user.Image','@user.Initials','@user.CreatedAt.ToString("dd/MM/yyyy")')"
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-zinc-50 text-zinc-600 text-xs font-medium rounded-lg hover:bg-zinc-200 transition-colors border border-zinc-200">
                                        <i class="fas fa-eye"></i>
                                    </button>

                                    <!-- Edit -->
                                    <button type="button"
                                            onclick="openEditModal('@user.UserId','@user.FullName','@user.PhoneNumber','@user.Bio','@user.Title','@user.Role')"
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-50 text-blue-600 text-xs font-medium rounded-lg hover:bg-blue-600 hover:text-white transition-colors">
                                        <i class="fas fa-edit"></i>
                                    </button>

                                    <!-- Ban / Unban -->
                                    <form method="post" asp-page-handler="ToggleBan">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <button type="submit"
                                                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg transition-colors
                                                       @(user.IsVerified
                                                         ? "bg-amber-50 text-amber-600 hover:bg-amber-500 hover:text-white"
                                                         : "bg-emerald-50 text-emerald-600 hover:bg-emerald-500 hover:text-white")"
                                                title="@(user.IsVerified ? "Ban user" : "Unban user")">
                                            <i class="fas @(user.IsVerified ? "fa-ban" : "fa-check-circle")"></i>
                                        </button>
                                    </form>

                                    <!-- Delete -->
                                    <button type="button"
                                            onclick="openDeleteModal('@user.UserId','@user.FullName')"
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-red-50 text-red-500 text-xs font-medium rounded-lg hover:bg-red-500 hover:text-white transition-colors">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-4 border-t border-zinc-100 flex items-center justify-between flex-wrap gap-3">
            <p class="text-sm text-zinc-400">
                Showing
                <span class="font-medium text-zinc-700">@(((Model.Data.Page - 1) * Model.Data.PageSize) + 1)</span>
                –
                <span class="font-medium text-zinc-700">@Math.Min(Model.Data.Page * Model.Data.PageSize, Model.Data.TotalCount)</span>
                of <span class="font-medium text-zinc-700">@Model.Data.TotalCount</span> users
            </p>
            <div class="flex gap-1 flex-wrap">
                @if (Model.Data.Page > 1)
                {
                    <a asp-page="/Admin/Users" asp-route-PageIndex="@(Model.Data.Page-1)" asp-route-Search="@Model.Search" asp-route-Role="@Model.Role"
                       class="px-3 py-2 text-sm text-zinc-700 bg-white border border-zinc-300 rounded-lg hover:bg-zinc-50 transition-colors">
                        <i class="fas fa-chevron-left text-xs"></i>
                    </a>
                }
                @for (int i = 1; i <= Model.Data.TotalPages; i++)
                {
                    if (i == 1 || i == Model.Data.TotalPages || Math.Abs(i - Model.Data.Page) <= 1)
                    {
                        <a asp-page="/Admin/Users" asp-route-PageIndex="@i" asp-route-Search="@Model.Search" asp-route-Role="@Model.Role"
                           class="px-3 py-2 text-sm rounded-lg border transition-colors
                                  @(i == Model.Data.Page ? "bg-indigo-600 text-white border-indigo-600" : "text-zinc-700 bg-white border-zinc-300 hover:bg-zinc-50")">
                            @i
                        </a>
                    }
                    else if (Math.Abs(i - Model.Data.Page) == 2)
                    {
                        <span class="px-2 py-2 text-sm text-zinc-400">…</span>
                    }
                }
                @if (Model.Data.Page < Model.Data.TotalPages)
                {
                    <a asp-page="/Admin/Users" asp-route-PageIndex="@(Model.Data.Page+1)" asp-route-Search="@Model.Search" asp-route-Role="@Model.Role"
                       class="px-3 py-2 text-sm text-zinc-700 bg-white border border-zinc-300 rounded-lg hover:bg-zinc-50 transition-colors">
                        <i class="fas fa-chevron-right text-xs"></i>
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="px-6 py-16 text-center">
            <div class="w-14 h-14 bg-zinc-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <i class="fas fa-users text-zinc-400 text-xl"></i>
            </div>
            <p class="text-sm font-medium text-zinc-500">No users found</p>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <p class="text-xs text-zinc-400 mt-1">Try a different search term</p>
            }
        </div>
    }
</div>

<!-- ══════════════════════════════════════════
     MODAL: VIEW DETAIL
══════════════════════════════════════════ -->
<div id="viewModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/30 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-2xl border border-zinc-100 w-full max-w-md">
        <div class="flex items-center justify-between px-6 py-4 border-b border-zinc-100">
            <h3 class="text-base font-semibold text-zinc-900">User Detail</h3>
            <button onclick="closeModal('viewModal')" class="p-1.5 rounded-lg text-zinc-400 hover:bg-zinc-100 transition-colors">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="px-6 py-5">
            <!-- Avatar -->
            <div class="flex flex-col items-center mb-5">
                <div id="vImgWrap" class="w-20 h-20 rounded-full overflow-hidden mb-3 border-2 border-zinc-200">
                    <img id="vImg" src="" class="w-full h-full object-cover hidden" />
                    <div id="vInitials" class="w-full h-full flex items-center justify-center text-white font-bold text-2xl"></div>
                </div>
                <p id="vName" class="text-lg font-bold text-zinc-900"></p>
                <p id="vTitle" class="text-xs text-zinc-400 mt-0.5"></p>
            </div>
            <!-- Info grid -->
            <div class="space-y-3 text-sm">
                <div class="flex justify-between py-2 border-b border-zinc-50">
                    <span class="text-zinc-400 font-medium">Email</span>
                    <span id="vEmail" class="text-zinc-800 font-medium"></span>
                </div>
                <div class="flex justify-between py-2 border-b border-zinc-50">
                    <span class="text-zinc-400 font-medium">Role</span>
                    <span id="vRole" class="text-zinc-800 font-medium"></span>
                </div>
                <div class="flex justify-between py-2 border-b border-zinc-50">
                    <span class="text-zinc-400 font-medium">Status</span>
                    <span id="vStatus"></span>
                </div>
                <div class="flex justify-between py-2 border-b border-zinc-50">
                    <span class="text-zinc-400 font-medium">Phone</span>
                    <span id="vPhone" class="text-zinc-800"></span>
                </div>
                <div class="flex justify-between py-2 border-b border-zinc-50">
                    <span class="text-zinc-400 font-medium">Registered</span>
                    <span id="vCreated" class="text-zinc-800"></span>
                </div>
                <div class="py-2">
                    <span class="text-zinc-400 font-medium block mb-1">Bio</span>
                    <p id="vBio" class="text-zinc-700 text-xs leading-relaxed"></p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════════════════════════════════
     MODAL: EDIT USER
══════════════════════════════════════════ -->
<div id="editModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/30 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-2xl border border-zinc-100 w-full max-w-md">
        <div class="flex items-center justify-between px-6 py-4 border-b border-zinc-100">
            <h3 class="text-base font-semibold text-zinc-900">Edit User</h3>
            <button onclick="closeModal('editModal')" class="p-1.5 rounded-lg text-zinc-400 hover:bg-zinc-100 transition-colors">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <form method="post" asp-page-handler="Edit" class="px-6 py-5 space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="EditUserId" id="editUserId" />

            <div>
                <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Full Name</label>
                <input type="text" name="EditFullName" id="editFullName" required
                       class="w-full px-3 py-2.5 text-sm border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 transition" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Phone</label>
                <input type="text" name="EditPhone" id="editPhone"
                       class="w-full px-3 py-2.5 text-sm border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 transition" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Title</label>
                <input type="text" name="EditTitle" id="editTitle"
                       class="w-full px-3 py-2.5 text-sm border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 transition" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Bio</label>
                <textarea name="EditBio" id="editBio" rows="3"
                          class="w-full px-3 py-2.5 text-sm border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 transition resize-none"></textarea>
            </div>
            <div>
                <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Role</label>
                <select name="EditRole" id="editRole"
                        class="w-full px-3 py-2.5 text-sm border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 transition">
                    <option value="0">Admin</option>
                    <option value="1">Instructor</option>
                    <option value="2">Student</option>
                </select>
            </div>
            <div class="flex gap-3 pt-2">
                <button type="button" onclick="closeModal('editModal')"
                        class="flex-1 px-4 py-2.5 text-sm font-medium text-zinc-700 bg-zinc-100 rounded-lg hover:bg-zinc-200 transition-colors">
                    Cancel
                </button>
                <button type="submit"
                        class="flex-1 px-4 py-2.5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ══════════════════════════════════════════
     MODAL: DELETE CONFIRM
══════════════════════════════════════════ -->
<div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/30 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-2xl border border-zinc-100 w-full max-w-sm">
        <div class="px-6 py-6 text-center">
            <div class="w-14 h-14 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-trash text-red-500 text-xl"></i>
            </div>
            <h3 class="text-base font-semibold text-zinc-900 mb-1">Delete User</h3>
            <p class="text-sm text-zinc-500 mb-5">
                Are you sure you want to delete <span id="deleteUserName" class="font-semibold text-zinc-800"></span>?
                This action cannot be undone.
            </p>
            <div class="flex gap-3">
                <button onclick="closeModal('deleteModal')"
                        class="flex-1 px-4 py-2.5 text-sm font-medium text-zinc-700 bg-zinc-100 rounded-lg hover:bg-zinc-200 transition-colors">
                    Cancel
                </button>
                <form id="deleteForm" method="post" asp-page-handler="Delete" class="flex-1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteUserId" name="userId" />
                    <button type="submit"
                            class="w-full px-4 py-2.5 text-sm font-medium text-white bg-red-500 rounded-lg hover:bg-red-600 transition-colors">
                        Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Helpers ──────────────────────────────────────────────
    function openModal(id) {
        const el = document.getElementById(id);
        el.classList.remove('hidden');
        el.classList.add('flex');
    }
    function closeModal(id) {
        const el = document.getElementById(id);
        el.classList.add('hidden');
        el.classList.remove('flex');
    }
    // Close on backdrop click
    ['viewModal','editModal','deleteModal'].forEach(id => {
        document.getElementById(id).addEventListener('click', e => { if (e.target.id === id) closeModal(id); });
    });

    // ── View Detail ──────────────────────────────────────────
    const avatarColors = ['bg-indigo-500','bg-amber-500','bg-rose-500','bg-emerald-500','bg-blue-500'];
    function openViewModal(id, name, email, role, status, phone, title, bio, img, initials, created) {
        document.getElementById('vName').textContent    = name;
        document.getElementById('vTitle').textContent   = title || '';
        document.getElementById('vEmail').textContent   = email;
        document.getElementById('vRole').textContent    = role;
        document.getElementById('vPhone').textContent   = phone || '—';
        document.getElementById('vBio').textContent     = bio || '—';
        document.getElementById('vCreated').textContent = created;

        const statusEl = document.getElementById('vStatus');
        if (status === 'Active') {
            statusEl.innerHTML = '<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-700"><i class="fas fa-check text-[9px]"></i> Active</span>';
        } else {
            statusEl.innerHTML = '<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-600"><i class="fas fa-ban text-[9px]"></i> Banned</span>';
        }

        const imgEl      = document.getElementById('vImg');
        const initEl     = document.getElementById('vInitials');
        const wrapEl     = document.getElementById('vImgWrap');
        if (img && img.trim() !== '') {
            imgEl.src = img; imgEl.classList.remove('hidden');
            initEl.classList.add('hidden');
            wrapEl.className = 'w-20 h-20 rounded-full overflow-hidden mb-3 border-2 border-zinc-200';
        } else {
            imgEl.classList.add('hidden');
            initEl.textContent = initials;
            const color = role === 'Admin' ? 'bg-rose-500' : role === 'Instructor' ? 'bg-amber-500' : 'bg-indigo-500';
            initEl.classList.remove('hidden');
            wrapEl.className = `w-20 h-20 rounded-full overflow-hidden mb-3 border-2 border-zinc-200 ${color}`;
        }
        openModal('viewModal');
    }

    // ── Edit ─────────────────────────────────────────────────
    function openEditModal(id, name, phone, bio, title, role) {
        document.getElementById('editUserId').value    = id;
        document.getElementById('editFullName').value  = name;
        document.getElementById('editPhone').value     = phone || '';
        document.getElementById('editBio').value       = bio || '';
        document.getElementById('editTitle').value     = title || '';
        document.getElementById('editRole').value      = role;
        openModal('editModal');
    }

    // ── Delete ────────────────────────────────────────────────
    function openDeleteModal(id, name) {
        document.getElementById('deleteUserName').textContent = name;
        document.getElementById('deleteUserId').value         = id;
        openModal('deleteModal');
    }
</script>
}
