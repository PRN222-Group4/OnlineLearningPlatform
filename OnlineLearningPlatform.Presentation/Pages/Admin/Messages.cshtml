@page
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Messages";

    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-8 h-[calc(100vh-4rem)]">
    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 h-full flex overflow-hidden"
         x-data="chatApplication('@currentUserId')">

        <div class="w-full md:w-80 lg:w-96 border-r border-slate-100 flex flex-col shrink-0 bg-slate-50/50"
             :class="currentContact ? 'hidden md:flex' : 'flex'">

            <div class="p-5 border-b border-slate-100 bg-white">
                <h2 class="text-xl font-extrabold text-slate-900 tracking-tight mb-4">Messages</h2>
                <div class="relative">
                    <i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input type="text" placeholder="Search contacts..." x-model="contactSearch"
                           class="w-full pl-10 pr-4 py-2.5 bg-slate-100 border-transparent rounded-xl text-sm focus:bg-white focus:border-indigo-300 focus:ring-4 focus:ring-indigo-100 transition-all outline-none">
                </div>
            </div>

            <div class="flex-1 overflow-y-auto sidebar-scroll">
                <template x-for="contact in filteredContacts" :key="contact.id">
                    <button @@click="selectContact(contact)"
                            class="w-full p-4 flex items-center gap-3 hover:bg-slate-100 transition-colors border-b border-slate-50 relative"
                            :class="currentContact?.id === contact.id ? 'bg-indigo-50/50' : ''">
                        <div class="relative shrink-0">
                            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-indigo-100 to-purple-100 flex items-center justify-center text-indigo-700 font-bold border border-white shadow-sm" x-text="contact.name.charAt(0)"></div>
                            <span class="absolute bottom-0 right-0 w-3 h-3 bg-emerald-500 border-2 border-white rounded-full" x-show="contact.isOnline"></span>
                        </div>
                        <div class="flex-1 min-w-0 text-left">
                            <div class="flex justify-between items-baseline mb-0.5">
                                <h3 class="text-sm font-bold text-slate-900 truncate" x-text="contact.name"></h3>
                                <span class="text-[10px] text-slate-400 font-medium" x-text="contact.lastTime"></span>
                            </div>
                            <p class="text-xs text-slate-500 truncate" x-text="contact.lastMessage.startsWith('[IMG]') ? '📷 Sent an image' : contact.lastMessage"></p>
                        </div>
                        <div class="w-2.5 h-2.5 bg-rose-500 rounded-full" x-show="contact.unread > 0"></div>
                    </button>
                </template>
            </div>
        </div>

        <div class="flex-1 flex flex-col bg-white" :class="!currentContact ? 'hidden md:flex' : 'flex'">
            <div x-show="!currentContact" class="flex-1 flex flex-col items-center justify-center text-center p-8">
                <div class="w-24 h-24 bg-slate-50 rounded-full flex items-center justify-center mb-4 border border-slate-100">
                    <i class="far fa-comments text-4xl text-slate-300"></i>
                </div>
                <h3 class="text-xl font-bold text-slate-700">Your Messages</h3>
                <p class="text-slate-500 mt-2 max-w-sm">Select a conversation to start chatting.</p>
            </div>

            <template x-if="currentContact">
                <div class="flex flex-col h-full">
                    <div class="h-16 px-6 border-b border-slate-100 flex items-center justify-between shrink-0 shadow-sm z-10 relative">
                        <div class="flex items-center gap-3">
                            <button @@click="currentContact = null" class="md:hidden w-8 h-8 flex items-center justify-center text-slate-400 hover:text-slate-600">
                                <i class="fas fa-chevron-left"></i>
                            </button>
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-100 to-purple-100 flex items-center justify-center text-indigo-700 font-bold" x-text="currentContact.name.charAt(0)"></div>
                            <div>
                                <h3 class="text-sm font-bold text-slate-900" x-text="currentContact.name"></h3>
                                <p class="text-xs text-emerald-500 font-medium" x-show="currentContact.isOnline">Online</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <input type="text" placeholder="Search in chat..." x-model="messageSearch" class="hidden sm:block text-xs px-3 py-1.5 bg-slate-100 border-none rounded-lg focus:ring-2 focus:ring-indigo-200 w-40 transition-all focus:w-56 outline-none">
                        </div>
                    </div>

                    <div class="flex-1 overflow-y-auto p-6 space-y-4 bg-slate-50/30" id="chat-container">
                        <template x-for="msg in filteredMessages" :key="msg.id">
                            <div class="flex flex-col" :class="msg.senderId === myUserId ? 'items-end' : 'items-start'">
                                <div class="max-w-[75%] rounded-2xl px-5 py-3 shadow-sm relative group"
                                     :class="msg.senderId === myUserId ? 'bg-indigo-600 text-white rounded-br-sm' : 'bg-white border border-slate-200 text-slate-700 rounded-bl-sm'">

                                    <template x-if="msg.content.startsWith('[IMG]')">
                                        <img :src="msg.content.replace('[IMG]', '')" class="rounded-lg max-h-64 object-cover cursor-pointer hover:opacity-90 transition-opacity" onclick="window.open(this.src, '_blank')" />
                                    </template>

                                    <template x-if="!msg.content.startsWith('[IMG]')">
                                        <p class="text-sm leading-relaxed whitespace-pre-wrap" x-text="msg.content"></p>
                                    </template>

                                </div>
                                <span class="text-[10px] font-medium text-slate-400 mt-1" x-text="msg.time"></span>
                            </div>
                        </template>
                    </div>

                    <div class="p-4 bg-white border-t border-slate-100 shrink-0 relative">
                        <div x-show="isUploading" class="absolute -top-8 left-4 text-xs font-bold text-indigo-500 bg-indigo-50 px-3 py-1 rounded-t-lg animate-pulse">
                            <i class="fas fa-spinner fa-spin mr-1"></i> Uploading to S3...
                        </div>
                        <div class="p-4 bg-white border-t border-slate-100 shrink-0 w-full relative">
                            <div x-show="isUploading" class="absolute -top-8 left-4 text-xs font-bold text-indigo-500 bg-indigo-50 px-3 py-1 rounded-t-lg animate-pulse">
                                <i class="fas fa-spinner fa-spin mr-1"></i> Uploading to S3...
                            </div>

                            <form x-on:submit.prevent="sendMessage" class="flex flex-row items-end gap-3 w-full">
                                <div class="flex-1 bg-slate-100 rounded-2xl flex flex-row items-end px-3 py-1.5 min-w-0 border border-transparent focus-within:bg-white focus-within:border-indigo-300 focus-within:ring-4 focus-within:ring-indigo-100 transition-all">

                                    <label class="w-10 h-10 shrink-0 rounded-full hover:bg-slate-200 flex items-center justify-center text-slate-400 hover:text-indigo-600 cursor-pointer transition-colors mb-1 -ml-1">
                                        <i class="fas fa-paperclip"></i>
                                        <input type="file" accept="image/*" class="hidden" @@change="uploadImage" :disabled="isUploading">
                                    </label>

                                    <textarea x-model="newMessage" rows="1" placeholder="Type your message... (Win + . for Emoji)"
                                              class="flex-1 bg-transparent border-none focus:ring-0 resize-none py-3 px-2 text-sm outline-none max-h-32 min-h-[44px] w-full"
                                              @@keydown.enter.prevent="if(!event.shiftKey) sendMessage()"></textarea>
                                </div>

                                <button type="submit" :disabled="(!newMessage.trim() && !isUploading) || isUploading"
                                        class="w-12 h-12 shrink-0 rounded-2xl bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-600 hover:to-purple-700 disabled:opacity-50 disabled:cursor-not-allowed text-white flex items-center justify-center transition-all transform hover:-translate-y-0.5 shadow-lg shadow-indigo-500/30 mb-1">
                                    <i class="fas fa-paper-plane text-sm relative -ml-1"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </template>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        function chatApplication(userId) {
            return {
                myUserId: userId,
                connection: null,
                newMessage: '',
                currentContact: null,
                contacts: [],
                messages: [],

                contactSearch: '',
                messageSearch: '',
                isUploading: false,

                get filteredContacts() {
                    if (!this.contactSearch) return this.contacts;
                    return this.contacts.filter(c => c.name.toLowerCase().includes(this.contactSearch.toLowerCase()));
                },

                get filteredMessages() {
                    if (!this.messageSearch) return this.messages;
                    return this.messages.filter(m => m.content.toLowerCase().includes(this.messageSearch.toLowerCase()));
                },

                init() {
                    fetch('/api/Messages/contacts', { headers: { 'Accept': 'application/json' }})
                        .then(res => res.json())
                        .then(data => { if(data.isSuccess) this.contacts = data.result; });

                    this.connection = new signalR.HubConnectionBuilder()
                        .withUrl("/realtimeHub")
                        .withAutomaticReconnect()
                        .build();

                    this.connection.on("ReceivePrivateMessage", (msgDto) => {
                        if (this.currentContact && (msgDto.senderId === this.currentContact.id || msgDto.senderId === this.myUserId)) {
                            this.messages.push({
                                id: msgDto.messageId,
                                senderId: msgDto.senderId,
                                content: msgDto.content,
                                time: new Date(msgDto.sentAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
                            });
                            this.scrollToBottom();

                            let c = this.contacts.find(x => x.id === this.currentContact.id);
                            if(c) c.lastMessage = msgDto.content;
                        } else {
                            window.dispatchEvent(new CustomEvent('new-notification', { detail: { from: msgDto.senderName, text: msgDto.content } }));
                        }
                    });

                    this.connection.start().then(() => {
                        this.connection.invoke("RegisterUserConnection", this.myUserId);
                    });
                },

                selectContact(contact) {
                    this.currentContact = contact;
                    contact.unread = 0;
                    this.messageSearch = '';

                    fetch(`/api/Messages/conversation/${contact.id}`, { headers: { 'Accept': 'application/json' }})
                        .then(res => res.json())
                        .then(data => {
                            if(data.isSuccess) {
                                this.messages = data.result.map(m => ({
                                    id: m.messageId,
                                    senderId: m.senderId,
                                    content: m.content,
                                    time: new Date(m.sentAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
                                }));
                                this.scrollToBottom();
                            }
                        });
                },

                sendMessage() {
                    if (!this.newMessage.trim() || !this.currentContact) return;
                    const text = this.newMessage;
                    this.newMessage = '';
                    this.connection.invoke("SendPrivateMessage", this.myUserId, this.currentContact.id, text);
                },

                async uploadImage(event) {
                    const file = event.target.files[0];
                    if(!file || !this.currentContact) return;

                    this.isUploading = true;
                    const formData = new FormData();
                    formData.append('file', file);

                    try {
                        const res = await fetch('/api/Messages/upload-image', {
                            method: 'POST',
                            body: formData
                        });
                        const data = await res.json();
                        if(data.isSuccess) {
                            const imageUrl = "[IMG]" + data.result;
                            this.connection.invoke("SendPrivateMessage", this.myUserId, this.currentContact.id, imageUrl);
                        } else {
                            alert("Upload failed: " + data.errorMessage);
                        }
                    } catch(err) {
                        alert("Upload failed!");
                    } finally {
                        this.isUploading = false;
                        event.target.value = '';
                    }
                },

                scrollToBottom() {
                    setTimeout(() => {
                        const container = document.getElementById('chat-container');
                        if (container) container.scrollTop = container.scrollHeight;
                    }, 50);
                }
            }
        }
    </script>
}