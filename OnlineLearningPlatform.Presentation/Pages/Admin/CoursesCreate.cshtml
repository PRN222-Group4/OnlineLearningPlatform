@page
@model OnlineLearningPlatform.Presentation.Pages.Admin.CoursesCreateModel
@{
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Create Course";
}

<div class="max-w-2xl mx-auto">

    <!-- Header -->
    <div class="flex items-center gap-3 mb-6">
        <a asp-page="/Admin/Courses"
           class="p-2 rounded-lg text-zinc-500 hover:bg-zinc-100 transition-colors">
            <i class="fas fa-arrow-left text-sm"></i>
        </a>
        <div class="flex items-center gap-2.5">
            <div class="w-9 h-9 bg-indigo-100 rounded-lg flex items-center justify-center">
                <i class="fas fa-plus text-indigo-600 text-sm"></i>
            </div>
            <div>
                <h2 class="text-base font-semibold text-zinc-900">Create New Course</h2>
                <p class="text-xs text-zinc-400">Fill in the details below</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-zinc-200 overflow-hidden">
        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="px-6 py-6 space-y-5">

                <!-- Title — asp-for="Request.Title" giống .cshtml.cs cũ -->
                <div>
                    <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">
                        Title <span class="text-red-400">*</span>
                    </label>
                    <input class="w-full px-3 py-2.5 text-sm border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 transition"
                           asp-for="Request.Title" placeholder="e.g. Introduction to Python" />
                    <span asp-validation-for="Request.Title" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Description -->
                <div>
                    <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Description</label>
                    <textarea class="w-full px-3 py-2.5 text-sm border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 transition resize-none"
                              asp-for="Request.Description" rows="4"
                              placeholder="Brief overview of what students will learn..."></textarea>
                </div>

                <!-- Price -->
                <div>
                    <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">
                        Price (₫) <span class="text-red-400">*</span>
                    </label>
                    <div class="relative">
                        <input class="w-full px-3 py-2.5 pr-8 text-sm border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-300 transition"
                               asp-for="Request.Price" type="number" min="0" placeholder="0" />
                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-zinc-400 text-sm font-medium">₫</span>
                    </div>
                    <span asp-validation-for="Request.Price" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <!-- Image — asp-for="Request.ImageFile" giống .cshtml.cs cũ -->
                <div>
                    <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">Thumbnail Image</label>
                    <div class="border-2 border-dashed border-zinc-200 rounded-lg p-5 text-center hover:border-indigo-300 transition-colors cursor-pointer"
                         onclick="document.getElementById('imageInput').click()">
                        <input type="file" asp-for="Request.ImageFile" accept="image/*"
                               id="imageInput" class="hidden" onchange="previewImage(this)" />
                        <div id="imagePreviewWrap" class="hidden mb-3">
                            <img id="imagePreview" class="w-36 h-24 object-cover rounded-lg mx-auto border border-zinc-200" alt="preview" />
                        </div>
                        <div id="imagePlaceholder">
                            <i class="fas fa-cloud-upload-alt text-zinc-300 text-3xl mb-2"></i>
                            <p class="text-xs text-zinc-400">Click to upload thumbnail</p>
                            <p class="text-xs text-zinc-300 mt-0.5">PNG, JPG up to 5MB</p>
                        </div>
                        <p id="imageFileName" class="text-xs text-indigo-600 font-medium mt-2 hidden"></p>
                    </div>
                </div>

                <!-- Error Summary -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="flex items-start gap-2.5 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
                        <i class="fas fa-exclamation-circle mt-0.5 shrink-0"></i>
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }
            </div>

            <!-- Footer -->
            <div class="px-6 py-4 border-t border-zinc-100 bg-zinc-50 flex items-center justify-between">
                <a asp-page="/Admin/Courses"
                   class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium text-zinc-700 bg-white border border-zinc-200 rounded-lg hover:bg-zinc-50 transition-colors">
                    <i class="fas fa-arrow-left text-xs"></i> Cancel
                </a>
                <button type="submit"
                        class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors">
                    <i class="fas fa-plus text-xs"></i> Create Course
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function previewImage(input) {
            const file = input.files?.[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('imagePreview').src = e.target.result;
                document.getElementById('imagePreviewWrap').classList.remove('hidden');
                document.getElementById('imagePlaceholder').classList.add('hidden');
                const fn = document.getElementById('imageFileName');
                fn.textContent = file.name;
                fn.classList.remove('hidden');
            };
            reader.readAsDataURL(file);
        }
    </script>
}
