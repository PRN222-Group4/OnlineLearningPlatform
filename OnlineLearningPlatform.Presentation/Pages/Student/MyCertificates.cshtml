@page
@model OnlineLearningPlatform.Presentation.Pages.Student.MyCertificatesModel
@{
    ViewData["Title"] = "My Certificates";
    var certsJson = System.Text.Json.JsonSerializer.Serialize(Model.Certificates, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
}

<div class="bg-slate-50 min-h-screen py-12 font-sans" x-data="certificateManager()">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="mb-10 text-center sm:text-left">
            <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight">My Achievements <i class="fas fa-trophy text-amber-500 ml-2"></i></h1>
            <p class="mt-3 text-lg text-slate-500">View and download your earned certificates.</p>
        </div>

        @if (!Model.Certificates.Any())
        {
            <div class="bg-white rounded-3xl p-12 text-center border border-slate-200 shadow-sm">
                <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="fas fa-award text-4xl text-slate-300"></i>
                </div>
                <h3 class="text-xl font-bold text-slate-800 mb-2">No certificates yet</h3>
                <p class="text-slate-500 mb-6">Keep learning and complete courses to earn your certificates!</p>
                <a asp-page="/Courses/Index" class="inline-flex px-6 py-3 bg-primary-600 text-white font-bold rounded-xl hover:bg-primary-700 transition">Explore Courses</a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <template x-for="cert in certificates" :key="cert.certificateId">
                    <div class="bg-white rounded-3xl border border-slate-200 overflow-hidden hover:shadow-2xl hover:shadow-amber-500/10 transition-all duration-300 group flex flex-col cursor-pointer"
                         x-on:click="openCert(cert)">
                        <div class="h-40 overflow-hidden relative border-b border-slate-100 bg-slate-100">
                            <img :src="cert.courseImage" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                            <div class="absolute bottom-4 left-4 right-4 flex justify-between items-end">
                                <span class="bg-amber-400 text-amber-950 text-xs font-black px-3 py-1 rounded-md shadow-lg shadow-amber-400/20 uppercase tracking-widest">Certified</span>
                            </div>
                        </div>

                        <div class="p-6 flex-1 flex flex-col">
                            <h3 class="text-lg font-bold text-slate-900 line-clamp-2 leading-snug mb-2" x-text="cert.courseTitle"></h3>
                            <p class="text-sm text-slate-500 mb-6 flex items-center gap-2">
                                <i class="far fa-calendar-check"></i> Issued: <span class="font-medium text-slate-700" x-text="new Date(cert.issueDate).toLocaleDateString()"></span>
                            </p>

                            <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between">
                                <span class="text-xs font-mono text-slate-400" x-text="`ID: ${cert.certificateCode}`"></span>
                                <button class="text-sm font-bold text-primary-600 group-hover:text-primary-800 transition flex items-center gap-1">
                                    View <i class="fas fa-arrow-right text-xs"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
        }
    </div>

    <div x-show="isOpen" x-cloak class="fixed inset-0 z-[100] flex items-center justify-center p-4 sm:p-6" aria-labelledby="modal-title" role="dialog" aria-modal="true">

        <div x-show="isOpen" x-transition.opacity class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm" x-on:click="isOpen = false"></div>

        <div x-show="isOpen"
             x-transition:enter="ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-8 scale-95" x-transition:enter-end="opacity-100 translate-y-0 scale-100"
             x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100 translate-y-0 scale-100" x-transition:leave-end="opacity-0 translate-y-8 scale-95"
             class="relative bg-white shadow-2xl w-full max-w-3xl rounded-sm overflow-hidden transform transition-all">

            <button x-on:click="isOpen = false" class="absolute top-4 right-4 z-10 w-8 h-8 bg-slate-100 hover:bg-rose-100 text-slate-500 hover:text-rose-600 rounded-full flex items-center justify-center transition">
                <i class="fas fa-times"></i>
            </button>

            <div id="certificate-canvas" class="p-4 sm:p-6 bg-[#fdfbf7]">
                <div class="border-[8px] border-double border-slate-300 p-6 sm:p-10 relative flex flex-col items-center text-center">

                    <div class="absolute inset-0 flex items-center justify-center opacity-[0.03] pointer-events-none">
                        <i class="fas fa-layer-group text-[250px]"></i>
                    </div>

                    <div class="absolute top-6 left-6 text-amber-500 opacity-20"><i class="fas fa-certificate text-5xl"></i></div>
                    <div class="absolute bottom-6 right-6 text-amber-500 opacity-20"><i class="fas fa-certificate text-5xl"></i></div>

                    <div class="mb-4">
                        <div class="w-12 h-12 bg-slate-900 rounded-xl flex items-center justify-center mx-auto mb-3 shadow-lg">
                            <i class="fas fa-layer-group text-white text-2xl"></i>
                        </div>
                        <h2 class="text-lg font-bold tracking-[0.2em] text-slate-800 uppercase">CourseSphere</h2>
                    </div>

                    <h1 class="text-3xl sm:text-5xl font-serif text-slate-900 mb-4 uppercase tracking-wider">Certificate of Completion</h1>

                    <p class="text-slate-500 tracking-widest uppercase text-xs mb-4">This is to proudly certify that</p>

                    <h2 class="text-3xl sm:text-4xl font-serif italic text-primary-800 border-b border-slate-300 pb-2 px-10 inline-block mb-6" x-text="selectedCert?.studentName"></h2>

                    <p class="text-slate-500 text-sm mb-3 max-w-xl mx-auto leading-relaxed">has successfully satisfied the requirements and completed the comprehensive curriculum for the course</p>

                    <h3 class="text-xl sm:text-2xl font-bold text-slate-800 mb-10 max-w-2xl mx-auto" x-text="selectedCert?.courseTitle"></h3>

                    <div class="w-full flex justify-between items-end px-2 sm:px-8 mt-auto">
                        <div class="text-center w-40 flex flex-col items-center">
                            <span class="font-serif italic text-lg text-slate-700 mb-2" x-text="selectedCert?.instructorName"></span>
                            <div class="w-full h-px bg-slate-400 mb-2"></div>
                            <p class="text-[10px] text-slate-500 uppercase tracking-wider font-bold">Course Instructor</p>
                        </div>

                        <div class="w-20 h-20 bg-amber-500 rounded-full flex flex-col items-center justify-center shadow-lg shadow-amber-500/30 text-white transform rotate-3 border-4 border-[#fdfbf7]">
                            <i class="fas fa-award text-xl mb-1"></i>
                            <span class="text-[8px] font-bold uppercase tracking-wider">Verified</span>
                        </div>

                        <div class="text-center w-40 flex flex-col items-center">
                            <span class="font-serif text-base text-slate-700 mb-2" x-text="selectedCert ? new Date(selectedCert.issueDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : ''"></span>
                            <div class="w-full h-px bg-slate-400 mb-2"></div>
                            <p class="text-[10px] text-slate-500 uppercase tracking-wider font-bold">Date of Issue</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-slate-50 p-4 border-t border-slate-200 flex justify-between items-center">
                <p class="text-xs text-slate-500 font-mono">Credential ID: <span class="font-bold text-slate-700" x-text="selectedCert?.certificateCode"></span></p>
                <button id="download-btn" @@click ="downloadPDF()" class="px-6 py-2.5 bg-slate-900 hover:bg-slate-800 text-white font-bold rounded-lg shadow-md transition flex items-center gap-2 text-sm">
                    <i class="fas fa-download"></i> Download PDF
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <script>
        function certificateManager() {
            return {
                certificates: @Html.Raw(certsJson),
                isOpen: false,
                selectedCert: null,

                openCert(cert) {
                    this.selectedCert = cert;
                    this.isOpen = true;
                },

                downloadPDF() {
                    const btn = document.getElementById('download-btn');
                    const originalText = btn.innerHTML;
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
                    btn.disabled = true;

                    const element = document.getElementById('certificate-canvas');

                    const opt = {
                        margin:       0.3,
                        filename:     `Certificate_${this.selectedCert.certificateCode}.pdf`,
                        image:        { type: 'jpeg', quality: 1 },
                        html2canvas:  { scale: 3, useCORS: true },
                        jsPDF:        { unit: 'in', format: 'a4', orientation: 'landscape' }
                    };

                    html2pdf().set(opt).from(element).save().then(() => {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    });
                }
            }
        }
    </script>
}